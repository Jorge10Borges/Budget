---
// Componente Footer.astro reutilizable
const year = new Date().getFullYear();
---
<footer class="border-t border-outline-variant/40 bg-surface-container-low py-8">
  <div class="container mx-auto flex flex-col items-start justify-between gap-6 px-6 md:flex-row md:items-center">
    <div class="flex items-center gap-3">
      <img src="/logo.svg" alt="Jorge Borges" class="h-8 w-8 rounded-full border border-primary/30 bg-white p-1 shadow-sm" loading="lazy" decoding="async" />
      <div>
        <span class="block text-base font-bold text-primary">Jorge Borges</span>
        <span class="block text-xs text-on-surface-variant">Desarrollador Full Stack · México</span>
      </div>
    </div>
    <div class="flex flex-col gap-2 md:items-end">
      <div class="flex gap-3 text-xl">
        <a href="https://github.com/devjorge" target="_blank" rel="noopener" aria-label="GitHub" class="hover:text-primary transition"><span class="material-symbols-outlined">code</span></a>
        <a href="https://www.linkedin.com/in/devjorge/" target="_blank" rel="noopener" aria-label="LinkedIn" class="hover:text-primary transition"><span class="material-symbols-outlined">work</span></a>
        <a href="mailto:info@devjorge.com" target="_blank" rel="noopener" aria-label="Email" class="hover:text-primary transition"><span class="material-symbols-outlined">mail</span></a>
        <a href="https://devjorge.com" target="_blank" rel="noopener" aria-label="Portfolio" class="hover:text-primary transition"><span class="material-symbols-outlined">public</span></a>
      </div>
      <span class="text-xs text-on-surface-variant">Portafolio: <a href="https://devjorge.com" target="_blank" rel="noopener" class="underline hover:text-primary">devjorge.com</a></span>
      <span class="text-xs text-on-surface-variant">© {year} Budget · Control de proyectos, valuaciones y finanzas operativas.</span>
    </div>
  </div>
</footer>
<style>
  footer a:hover {
    text-decoration: underline;
  }
</style>
