<nav class="fixed bottom-4 left-1/2 -translate-x-1/2 w-[92%] max-w-md z-50 bg-surface-container-low-95 backdrop-blur-sm rounded-2xl shadow-lg border border-outline-variant py-2 px-3 md:hidden">
  <div class="flex items-center justify-around">
    <a href="/" data-nav="/" class="flex flex-col items-center text-on-surface-variant hover:text-primary transition-colors">
      <span class="material-symbols-outlined">dashboard</span>
      <span class="text-[11px] font-medium uppercase tracking-wider">Dashboard</span>
    </a>
    <a href="/projects" data-nav="/projects" class="flex flex-col items-center text-on-surface-variant hover:text-primary transition-colors">
      <span class="material-symbols-outlined">folder_open</span>
      <span class="text-[11px] font-medium uppercase tracking-wider">Proyectos</span>
    </a>
  </div>
</nav>

<script>
  (function(){
    try {
      const path = location.pathname.replace(/\/$/, '') || '/';
      document.querySelectorAll('a[data-nav]').forEach(a=>{
        const target = a.getAttribute('data-nav');
        if (target === path) a.classList.add('nav-active-mobile');
      });
    } catch(e) {}
  })();
</script>
