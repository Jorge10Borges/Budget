<style>
  :root {
    --loader-color-blue: #1c395d;
    --loader-color-orange: #f19516;
    --loader-color-bg: #ffffff;
    --loader-animation-speed: 2.5s;
  }

  .loader-overlay {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
    min-height: 100vh;
    margin: 0;
    background-color: var(--loader-color-bg);
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  .loader-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .svg-container {
    width: 180px;
    height: 180px;
    position: relative;
    filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.05));
    animation: pulseContainer var(--loader-animation-speed) ease-in-out infinite;
  }

  .main-shape {
    fill: none;
    stroke: var(--loader-color-blue);
    stroke-width: 8;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 2500;
    stroke-dashoffset: 2500;
    animation: drawStroke var(--loader-animation-speed) ease-in-out infinite;
  }

  .accent-shape {
    fill: var(--loader-color-orange);
    opacity: 0;
    transform-origin: center;
    animation: slideInAccent var(--loader-animation-speed) ease-in-out infinite;
  }

  .white-details {
    fill: #ffffff;
    opacity: 0;
    animation: fadeInDetails var(--loader-animation-speed) ease-in-out infinite;
  }

  @keyframes drawStroke {
    0% {
      stroke-dashoffset: 2500;
      fill: rgba(28, 57, 93, 0);
    }

    40% {
      stroke-dashoffset: 0;
      fill: rgba(28, 57, 93, 0);
    }

    60%,
    100% {
      stroke-dashoffset: 0;
      fill: var(--loader-color-blue);
      stroke-width: 0;
    }
  }

  @keyframes slideInAccent {
    0%,
    45% {
      opacity: 0;
      transform: translate(20px, -20px) scale(0.8);
    }

    65% {
      opacity: 1;
      transform: translate(0, 0) scale(1.1);
    }

    75%,
    100% {
      opacity: 1;
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes fadeInDetails {
    0%,
    65% {
      opacity: 0;
    }

    80%,
    100% {
      opacity: 1;
    }
  }

  @keyframes pulseContainer {
    0%,
    100% {
      transform: scale(1);
    }

    50% {
      transform: scale(1.05);
    }
  }

  .loading-text {
    margin-top: 30px;
    font-size: 14px;
    font-weight: 600;
    color: var(--loader-color-blue);
    letter-spacing: 4px;
    text-transform: uppercase;
    position: relative;
    overflow: hidden;
  }

  .loading-text::after {
    content: '';
    position: absolute;
    left: -100%;
    bottom: -2px;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--loader-color-orange), transparent);
    animation: lineFlow 2s linear infinite;
  }

  @keyframes lineFlow {
    0% {
      left: -100%;
    }

    100% {
      left: 100%;
    }
  }
</style>
