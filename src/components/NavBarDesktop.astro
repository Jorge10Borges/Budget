---
---
<nav class="hidden md:flex items-center justify-between w-full bg-surface-container-low px-6 py-3 shadow-sm border-b border-outline-variant">
	<div class="group flex items-center gap-3">
		<div class="w-10 h-10 rounded-lg overflow-hidden flex items-center justify-center p-1">
			<img
				src="/logo.svg"
				alt="DevJorge"
				class="w-full h-full object-contain group-hover:scale-105 transition-transform"
				loading="eager"
				decoding="async"
			/>
		</div>
		<span id="brand-or-company" class="text-lg font-bold text-primary">Jorge Borges</span>
	</div>
	<div class="flex items-center gap-6">
		<a href="/" data-nav="/" class="text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">Dashboard</a>
		<a href="/projects" data-nav="/projects" class="text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">Proyectos</a>
		<div id="auth-user-box" class="hidden items-center gap-3 rounded-lg border border-outline-variant/60 bg-surface px-3 py-1.5">
			<div class="text-right leading-tight">
				<div id="auth-user-name" class="text-xs font-semibold text-on-surface">Usuario</div>
				<div id="auth-user-role" class="text-[11px] uppercase tracking-wide text-on-surface-variant">rol</div>
			</div>
			<button id="logout-btn" type="button" class="inline-flex items-center gap-1 rounded-md border border-outline-variant px-2.5 py-1 text-xs font-semibold text-on-surface hover:bg-surface-container transition">
				<span class="material-symbols-outlined text-sm">logout</span>
				Salir
			</button>
		</div>
	</div>
</nav>

<script>
	(function(){
		try {
			const path = location.pathname.replace(/\/$/, '') || '/';
			const meta = document.querySelector('meta[name="api-base"]');
			const metaContent = (meta && meta instanceof HTMLMetaElement) ? meta.content : null;
			const apiBase = (metaContent || 'http://192.168.1.200/Budget/api').replace(/\/$/, '');
			document.querySelectorAll('a[data-nav]').forEach(a=>{
				const target = a.getAttribute('data-nav');
				if (target === path) {
					a.classList.add('nav-active-bg');
					a.classList.add('nav-active-underline');
				}
			});

			const userBox = document.getElementById('auth-user-box');
			const userName = document.getElementById('auth-user-name');
			const userRole = document.getElementById('auth-user-role');
			const companyName = document.getElementById('brand-or-company');
			const logoutBtn = document.getElementById('logout-btn');

			fetch(apiBase + '/auth_me.php', { method: 'GET', credentials: 'include' })
				.then(async (res) => {
					if (!res.ok) return;
					const payload = await res.json().catch(() => ({}));
					const data = payload && payload.data ? payload.data : null;
					if (!data) return;

					if (companyName) {
						companyName.textContent = data.company?.trade_name || data.company?.legal_name || 'Budget';
					}
					if (userName) userName.textContent = data.user?.full_name || 'Usuario';
					if (userRole) userRole.textContent = data.user?.role || 'editor';
					if (userBox) userBox.classList.remove('hidden');
				});

			logoutBtn?.addEventListener('click', async () => {
				try {
					await fetch(apiBase + '/auth_logout.php', { method: 'POST', credentials: 'include' });
				} catch (e) {
					/* ignore */
				}
				location.href = '/login';
			});
		} catch(e) { /* ignore in non-browser */ }
	})();
</script>
