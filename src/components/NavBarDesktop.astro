---
<nav class="hidden md:flex items-center justify-between w-full bg-surface-container-low px-6 py-3 shadow-sm border-b border-outline-variant">
	<div class="flex items-center gap-3">
		<div class="w-8 h-8 rounded-full overflow-hidden bg-primary-fixed flex items-center justify-center">
			<!-- placeholder avatar -->
		</div>
		<span class="text-lg font-bold text-primary">Project Ledger</span>
	</div>
	<div class="flex items-center gap-6">
		<a href="/" data-nav="/" class="text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">Dashboard</a>
		<a href="/projects" data-nav="/projects" class="text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">Proyectos</a>
	</div>
</nav>

<script>
	(function(){
		try {
			const path = location.pathname.replace(/\/$/, '') || '/';
			document.querySelectorAll('a[data-nav]').forEach(a=>{
				const target = a.getAttribute('data-nav');
				if (target === path) {
					a.classList.add('nav-active-bg');
					a.classList.add('nav-active-underline');
				}
			});
		} catch(e) { /* ignore in non-browser */ }
	})();
</script>
</nav>
