---
import "../styles/global.css";
import Loader from "../components/Loader.astro";

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL || "http://192.168.1.200/Budget/api";
---

<html lang="es-ES">
	<head>
		<meta charset="utf-8" />
		<!-- API base URL: configurable con PUBLIC_API_BASE_URL en .env -->
		<meta name="api-base" content={API_BASE_URL} />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		
		<title>Budget</title>
	</head>
	<body class="pb-20 md:pb-0">
		<div id="app-loader" class="fixed inset-0 z-50">
			<Loader text="Cargando..." />
		</div>
		<div id="app-shell" style="visibility: hidden;">
    <slot />
		</div>
		<script>
			(function () {
				function showApp() {
					var shell = document.getElementById('app-shell');
					var loader = document.getElementById('app-loader');
					if (shell) shell.style.visibility = 'visible';
					if (loader) loader.style.display = 'none';
				}

				try {
					const path = (location.pathname || '/').replace(/\/$/, '') || '/';
					const publicPaths = new Set(['/', '/login']);
					const shouldCheckSession = path === '/login' || !publicPaths.has(path);
					if (!shouldCheckSession) {
						showApp();
						return;
					}
					const meta = document.querySelector('meta[name="api-base"]') as HTMLMetaElement | null;
					const metaContent = meta ? meta.content : null;
					const apiBase = (metaContent || 'http://192.168.1.200/Budget/api').replace(/\/$/, '');

					fetch(apiBase + '/auth_me.php', {
						method: 'GET',
						credentials: 'include'
					})
						.then(function (res) {
							return res.json().catch(function () { return { authenticated: false }; });
						})
						.then(function (payload) {
							const isAuthenticated = !!(payload && payload.authenticated);

							if (isAuthenticated) {
								if (path === '/login') {
									location.replace('/projects');
									return;
								}
								showApp();
								return;
							}

							if (!publicPaths.has(path)) {
								location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search));
								return;
							}

							showApp();
						})
						.catch(function () {
							if (!publicPaths.has(path)) {
								location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search));
								return;
							}
							showApp();
						});
				} catch (e) {
					showApp();
				}
			})();
		</script>
	</body>
</html>