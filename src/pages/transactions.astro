---
import "../styles/global.css";
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Libro de Movimientos — Architectural Ledger</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>

<body class="bg-surface font-body text-on-surface antialiased pb-28">
  <!-- TopAppBar -->
  <header class="flex justify-between items-center w-full px-4 h-16 sticky top-0 z-50 bg-surface border-b border-outline-variant/15">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full overflow-hidden bg-surface-container-high border border-outline-variant/30">
        <img alt="User" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCqlDhJsD7j2PqBz2why1uTx3dQUvHEsN31mT7c7MVPyHtYnlO8nHZvlF31juI2-iTbTRzzoihCDAH4EYuqP1bbMDHbtiLaW7lAslrJGbb8V86j83n_CrBRdyHDfazTOVZ0UEpStHTqxLGCN-xQeVguXCCYktnsbZ3V7NIKTahQUG__bGCsOo-cTynhgOPbHhMbxBjPu0SoCYnbG0SyHIUeqVYPK6gyFHIn9KxTt5xtoZglPU_uyx9ob9kUK9floeSktrHD9-osnqTj" />
      </div>
      <h1 class="text-lg font-bold tracking-tighter text-primary">Architectural Ledger</h1>
    </div>
    <button class="p-2 transition-colors duration-200 ease-in-out hover:bg-surface-container-low text-primary rounded-lg">
      <span class="material-symbols-outlined">notifications</span>
    </button>
  </header>

  <main class="px-4 py-6">
    <!-- Summary Section -->
    <section class="grid grid-cols-2 gap-3 mb-6">
      <div class="bg-surface-container-low p-4 rounded-xl border-l-4 border-primary">
        <p class="text-[10px] font-medium uppercase tracking-wider text-on-surface-variant mb-1">Total por Cobrar</p>
        <p class="text-xl font-bold tracking-tight text-primary">$1,240,850.00</p>
      </div>
      <div class="bg-surface-container-low p-4 rounded-xl border-l-4 border-error">
        <p class="text-[10px] font-medium uppercase tracking-wider text-on-surface-variant mb-1">Total de Pasivos</p>
        <p class="text-xl font-bold tracking-tight text-error">$452,120.50</p>
      </div>
    </section>

    <!-- Header -->
    <div class="flex justify-between items-end mb-4">
      <div>
        <h2 class="text-sm font-semibold text-on-surface-variant uppercase tracking-[0.1em]">Movimientos del Proyecto</h2>
        <p class="text-[10px] text-outline">Ordenado por Fecha (Reciente)</p>
      </div>
      <div class="flex gap-2">
        <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-surface-container-low border border-outline-variant/15 text-on-surface-variant"><span class="material-symbols-outlined">filter_list</span></button>
        <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-surface-container-low border border-outline-variant/15 text-on-surface-variant"><span class="material-symbols-outlined">search</span></button>
      </div>
    </div>

    <!-- Transactions List -->
    <div class="space-y-3">
      <!-- Txn 1 (Credit) -->
      <article class="bg-surface-container-lowest rounded-xl p-4 shadow-sm transition-transform active:scale-[0.98]">
        <div class="flex justify-between items-start mb-2">
          <div>
            <p class="text-[10px] font-mono text-outline-variant">#TXN-8842 / 12 OCT 2023</p>
            <h3 class="font-semibold text-on-surface text-sm">Cert de Pago #04 - Ala Este</h3>
          </div>
          <div class="px-2 py-0.5 rounded-full bg-tertiary-fixed text-on-tertiary-fixed-variant text-[10px] font-bold">HABER</div>
        </div>
        <div class="grid grid-cols-3 gap-2 pt-3 mt-3 border-t border-outline-variant/10">
          <div>
            <p class="text-[10px] text-outline-variant uppercase">Debe</p>
            <p class="text-sm font-medium text-error-container/80">--</p>
          </div>
          <div>
            <p class="text-[10px] text-outline-variant uppercase">Haber</p>
            <p class="text-sm font-bold text-tertiary">$45,000.00</p>
          </div>
          <div class="text-right">
            <p class="text-[10px] text-outline-variant uppercase">Saldo</p>
            <p class="text-sm font-bold text-primary">$788,729.50</p>
          </div>
        </div>
      </article>

      <!-- Txn 2 (Debit) -->
      <article class="bg-surface-container-lowest rounded-xl p-4 shadow-sm">
        <div class="flex justify-between items-start mb-2">
          <div>
            <p class="text-[10px] font-mono text-outline-variant">#TXN-8840 / 10 OCT 2023</p>
            <h3 class="font-semibold text-on-surface text-sm">Materiales: Acero Reforzado</h3>
          </div>
          <div class="px-2 py-0.5 rounded-full bg-error-container text-on-error-container text-[10px] font-bold">DEBE</div>
        </div>
        <div class="grid grid-cols-3 gap-2 pt-3 mt-3 border-t border-outline-variant/10">
          <div>
            <p class="text-[10px] text-outline-variant uppercase">Debe</p>
            <p class="text-sm font-bold text-error">$12,450.00</p>
          </div>
          <div>
            <p class="text-[10px] text-outline-variant uppercase">Haber</p>
            <p class="text-sm font-medium text-tertiary-fixed-dim">--</p>
          </div>
          <div class="text-right">
            <p class="text-[10px] text-outline-variant uppercase">Saldo</p>
            <p class="text-sm font-bold text-primary">$743,729.50</p>
          </div>
        </div>
      </article>

      <!-- Txn 3 (Negative balance) -->
      <article class="bg-surface-container-lowest rounded-xl p-4 shadow-sm">
        <div class="flex justify-between items-start mb-2">
          <div>
            <p class="text-[10px] font-mono text-outline-variant">#TXN-8835 / 05 OCT 2023</p>
            <h3 class="font-semibold text-on-surface text-sm">Auditoría Ingeniería Estructural</h3>
          </div>
          <div class="px-2 py-0.5 rounded-full bg-error-container text-on-error-container text-[10px] font-bold">DEBE</div>
        </div>
        <div class="grid grid-cols-3 gap-2 pt-3 mt-3 border-t border-outline-variant/10">
          <div>
            <p class="text-[10px] text-outline-variant uppercase">Debe</p>
            <p class="text-sm font-bold text-error">$2,500.00</p>
          </div>
          <div>
            <p class="text-[10px] text-outline-variant uppercase">Haber</p>
            <p class="text-sm font-medium text-tertiary-fixed-dim">--</p>
          </div>
          <div class="text-right">
            <p class="text-[10px] text-outline-variant uppercase">Saldo</p>
            <p class="text-sm font-bold text-error">-$14,200.00</p>
          </div>
        </div>
      </article>

      <!-- Txn 4 (Credit) -->
      <article class="bg-surface-container-lowest rounded-xl p-4 shadow-sm">
        <div class="flex justify-between items-start mb-2">
          <div>
            <p class="text-[10px] font-mono text-outline-variant">#TXN-8832 / 01 OCT 2023</p>
            <h3 class="font-semibold text-on-surface text-sm">Liberación Retención Fase II</h3>
          </div>
          <div class="px-2 py-0.5 rounded-full bg-tertiary-fixed text-on-tertiary-fixed-variant text-[10px] font-bold">HABER</div>
        </div>
        <div class="grid grid-cols-3 gap-2 pt-3 mt-3 border-t border-outline-variant/10">
          <div>
            <p class="text-[10px] text-outline-variant uppercase">Debe</p>
            <p class="text-sm font-medium text-error-container/80">--</p>
          </div>
          <div>
            <p class="text-[10px] text-outline-variant uppercase">Haber</p>
            <p class="text-sm font-bold text-tertiary">$15,250.00</p>
          </div>
          <div class="text-right">
            <p class="text-[10px] text-outline-variant uppercase">Saldo</p>
            <p class="text-sm font-bold text-primary">$731,279.50</p>
          </div>
        </div>
      </article>
    </div>

    <!-- Insight Highlight -->
    <section class="mt-8 mb-6 bg-primary-container p-4 rounded-2xl relative overflow-hidden">
      <div class="relative z-10 flex items-start gap-3">
        <div class="bg-white/20 p-2 rounded-lg backdrop-blur-md">
          <span class="material-symbols-outlined text-white">insights</span>
        </div>
        <div>
          <h4 class="text-white font-bold text-sm">Información del Libro</h4>
          <p class="text-primary-fixed text-xs mt-1 leading-relaxed">La velocidad del flujo de caja ha aumentado un <span class="text-tertiary-fixed font-bold">14.2%</span> este trimestre. Los pasivos actuales están <span class="text-primary-fixed-dim">bajo control</span> en relación con la facturación proyectada.</p>
        </div>
      </div>
    </section>
  </main>

  <!-- BottomNavBar -->
  <nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-safe pt-2 bg-white/80 backdrop-blur-xl rounded-t-2xl shadow-[0_-8px_32px_rgba(13,28,47,0.06)] border-t border-outline-variant/15">
    <a class="flex flex-col items-center justify-center text-[#434655] px-3 py-1.5 hover:text-primary" href="/dashboard">
      <span class="material-symbols-outlined">dashboard</span>
      <span class="text-[10px] font-medium uppercase tracking-wider mt-1">Panel</span>
    </a>
    <a class="flex flex-col items-center justify-center text-[#434655] px-3 py-1.5 hover:text-primary" href="/projects">
      <span class="material-symbols-outlined">architecture</span>
      <span class="text-[10px] font-medium uppercase tracking-wider mt-1">Proyectos</span>
    </a>
    <a class="flex flex-col items-center justify-center text-[#434655] px-3 py-1.5 hover:text-primary" href="/valuations">
      <span class="material-symbols-outlined">assignment_turned_in</span>
      <span class="text-[10px] font-medium uppercase tracking-wider mt-1">Valuaciones</span>
    </a>
    <a class="flex flex-col items-center justify-center bg-primary-fixed text-primary px-3 py-1.5 rounded-xl" href="/ledger">
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">account_balance_wallet</span>
      <span class="text-[10px] font-medium uppercase tracking-wider mt-1">Libro</span>
    </a>
  </nav>

</body>
