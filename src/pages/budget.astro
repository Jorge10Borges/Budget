---
import "../styles/global.css";
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Budgets — Project Ledger</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>

<body class="bg-background text-on-surface antialiased">
  <!-- TopAppBar -->
  <header class="fixed top-0 w-full z-50 bg-surface-container-low flex justify-between items-center px-6 py-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full overflow-hidden bg-surface-container-highest">
        <img class="w-full h-full object-cover" alt="profile" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDE27Ho5CxN0pafTCPYmwwfir-O6W8kYPsVvRBZkVPgAb0W2nHW54JhRdH_-pEO60jB2u6Omtq3CWPGHwa6tcoiRG9DeDb5yw5X-h85hMeLwOKE55fjmL6hOc9EqHULPa8A9fwWneHDJ62iFIAFcDs6MPiMVB1S7Jl35sJM5Ge8jQuV1PSmuGT5XUC297T-IdnoD5ihiNYR3_qf0JlukmnhuU77vLpLKH83ABBHE0Gm5Ph0T9FowiBcwazqcF1NiGMAsikobFrfHaAV" />
      </div>
      <span class="text-xl font-bold tracking-tighter text-primary">Project Ledger</span>
    </div>
    <div class="flex items-center gap-4">
      <button class="material-symbols-outlined text-primary p-2 hover:bg-surface-container-high rounded-xl">notifications</button>
    </div>
  </header>

  <main class="pt-24 pb-32 px-4 max-w-md mx-auto">
    <!-- Project Selector Filter -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-4 px-2">
        <h2 class="font-headline text-on-surface font-semibold text-lg">Estado de Presupuesto</h2>
        <span class="text-primary text-xs font-medium uppercase tracking-widest">Global</span>
      </div>
      <div class="bg-surface-container-low rounded-xl p-1 flex gap-1">
        <button class="flex-1 py-2 px-3 text-sm font-medium rounded-lg bg-surface-container-lowest text-primary shadow-sm">Todos</button>
        <button class="flex-1 py-2 px-3 text-sm font-medium rounded-lg text-on-surface-variant hover:bg-surface-container-high transition-colors">Torre Norte</button>
        <button class="flex-1 py-2 px-3 text-sm font-medium rounded-lg text-on-surface-variant hover:bg-surface-container-high transition-colors">Viaducto Sur</button>
      </div>
    </section>

    <!-- Summary Card -->
    <section class="mb-6">
      <div class="bg-gradient-to-br from-primary to-primary-container rounded-3xl p-6 text-on-primary shadow-xl">
        <div class="flex justify-between items-start mb-6">
          <div>
            <p class="text-on-primary-container text-xs font-medium uppercase tracking-widest mb-1">Gasto Total Ejecutado</p>
            <h1 class="text-3xl font-bold tracking-tight">$2,450,000</h1>
          </div>
          <div class="bg-white/20 backdrop-blur-md rounded-full px-3 py-1 text-xs font-bold">74%</div>
        </div>
        <div class="space-y-2">
          <div class="h-2 w-full bg-white/20 rounded-full overflow-hidden">
            <div class="h-full bg-tertiary-fixed w-[74%] rounded-full"></div>
          </div>
          <div class="flex justify-between text-[11px] font-medium opacity-80">
            <span>PRESUPUESTO: $3,310,000</span>
            <span>REMANENTE: $860,000</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Category Ledger Breakdown -->
    <section class="space-y-4">
      <h3 class="font-headline text-on-surface-variant text-xs font-bold uppercase tracking-widest px-2">Desglose por Categoría</h3>

      <!-- Category: Materiales -->
      <div class="bg-surface-container-lowest p-5 rounded-2xl shadow-sm border border-outline-variant/10">
        <div class="flex justify-between items-center mb-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-primary-fixed flex items-center justify-center">
              <span class="material-symbols-outlined text-primary">precision_manufacturing</span>
            </div>
            <div>
              <h4 class="font-semibold text-on-surface">Materiales</h4>
              <p class="text-[10px] text-on-surface-variant uppercase tracking-wider">Acero, Concreto, Vidrio</p>
            </div>
          </div>
          <div class="text-right">
            <span class="text-sm font-bold text-on-surface">82%</span>
          </div>
        </div>
        <div class="space-y-3">
          <div class="relative h-2.5 w-full bg-surface-container-low rounded-full overflow-hidden">
            <div class="absolute h-full bg-primary w-[82%] rounded-full"></div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-[9px] text-on-surface-variant font-bold uppercase tracking-tighter">Gasto Real</p>
              <p class="text-sm font-semibold text-on-surface">$1,230,000</p>
            </div>
            <div class="text-right">
              <p class="text-[9px] text-on-surface-variant font-bold uppercase tracking-tighter">Presupuesto</p>
              <p class="text-sm font-semibold text-on-surface-variant">$1,500,000</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Category: Mano de Obra -->
      <div class="bg-surface-container-lowest p-5 rounded-2xl shadow-sm border border-outline-variant/10">
        <div class="flex justify-between items-center mb-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-tertiary-fixed flex items-center justify-center">
              <span class="material-symbols-outlined text-tertiary">engineering</span>
            </div>
            <div>
              <h4 class="font-semibold text-on-surface">Mano de Obra</h4>
              <p class="text-[10px] text-on-surface-variant uppercase tracking-wider">Contratistas, Staff, Seguridad</p>
            </div>
          </div>
          <div class="text-right">
            <span class="text-sm font-bold text-tertiary">65%</span>
          </div>
        </div>
        <div class="space-y-3">
          <div class="relative h-2.5 w-full bg-surface-container-low rounded-full overflow-hidden">
            <div class="absolute h-full bg-tertiary w-[65%] rounded-full"></div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-[9px] text-on-surface-variant font-bold uppercase tracking-tighter">Gasto Real</p>
              <p class="text-sm font-semibold text-on-surface">$780,000</p>
            </div>
            <div class="text-right">
              <p class="text-[9px] text-on-surface-variant font-bold uppercase tracking-tighter">Presupuesto</p>
              <p class="text-sm font-semibold text-on-surface-variant">$1,200,000</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Category: Logística -->
      <div class="bg-surface-container-lowest p-5 rounded-2xl shadow-sm border border-outline-variant/10">
        <div class="flex justify-between items-center mb-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-secondary-fixed flex items-center justify-center">
              <span class="material-symbols-outlined text-secondary">local_shipping</span>
            </div>
            <div>
              <h4 class="font-semibold text-on-surface">Logística</h4>
              <p class="text-[10px] text-on-surface-variant uppercase tracking-wider">Fletes, Almacenaje, Aduanas</p>
            </div>
          </div>
          <div class="text-right">
            <span class="text-sm font-bold text-error">94%</span>
          </div>
        </div>
        <div class="space-y-3">
          <div class="relative h-2.5 w-full bg-surface-container-low rounded-full overflow-hidden">
            <div class="absolute h-full bg-error w-[94%] rounded-full"></div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-[9px] text-on-surface-variant font-bold uppercase tracking-tighter">Gasto Real</p>
              <p class="text-sm font-semibold text-error">$440,000</p>
            </div>
            <div class="text-right">
              <p class="text-[9px] text-on-surface-variant font-bold uppercase tracking-tighter">Presupuesto</p>
              <p class="text-sm font-semibold text-on-surface-variant">$468,000</p>
            </div>
          </div>
        </div>

        <!-- Warning Message for Overbudget -->
        <div class="mt-4 p-3 bg-error-container rounded-lg flex items-center gap-2">
          <span class="material-symbols-outlined text-on-error-container text-sm">warning</span>
          <p class="text-[10px] text-on-error-container font-medium">Límite crítico alcanzado en transporte.</p>
        </div>
      </div>
    </section>

    <!-- Architectural Visualization Mini-Banner -->
    <section class="mt-8 mb-4">
      <div class="relative h-32 w-full rounded-2xl overflow-hidden group">
        <img class="w-full h-full object-cover" alt="blueprint" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD-V7Z6lTZcNFz_IniOoCoDCpu36euHAFHhXrlzLZComkZhWmDGuh0ahEWDwJzIExnrabtLoIlaNlGf8ud0E8Xhr_LdMic2eE0LlqRuM8hQg0ruCBG9h_fkc8bjYvruOQxgZ56Pnbbsk0oqtrIfA2rKn2B9I_WeygFShnt6rK3PmQqXXykJ4SfguDMAGKZSi5u0v1k6Bkl9jXZkCb_SKMOILYmP_o8fFB0pqR41vuEiUBG-0r8hscuTi1ZRHwt3aHDd-da1s9SeLnUV" />
        <div class="absolute inset-0 bg-gradient-to-t from-on-surface/80 to-transparent flex items-end p-4">
          <div>
            <p class="text-white font-bold text-sm tracking-tight">Reporte Detallado Q4</p>
            <p class="text-white/70 text-[10px] uppercase">Exportar como PDF Técnico</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- BottomNavBar -->
  <nav class="fixed bottom-0 w-full z-50 bg-white/80 backdrop-blur-xl shadow-[0_-8px_32px_rgba(13,28,47,0.06)] border-t border-outline-variant/15">
    <div class="flex justify-around items-center w-full px-2 pb-6 pt-3">
      <a class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:text-primary transition-transform active:scale-90 duration-200" href="/dashboard">
        <span class="material-symbols-outlined">dashboard</span>
        <span class="text-[11px] font-medium uppercase tracking-wider mt-1">Dashboard</span>
      </a>
      <a class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:text-primary transition-transform active:scale-90 duration-200" href="/transactions">
        <span class="material-symbols-outlined">receipt_long</span>
        <span class="text-[11px] font-medium uppercase tracking-wider mt-1">Transactions</span>
      </a>
      <a class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:text-primary transition-transform active:scale-90 duration-200" href="/accounts">
        <span class="material-symbols-outlined">account_balance</span>
        <span class="text-[11px] font-medium uppercase tracking-wider mt-1">Accounts</span>
      </a>
      <a class="flex flex-col items-center justify-center text-primary bg-primary-fixed px-3 py-1 rounded-xl transition-transform active:scale-90 duration-200" href="/budget">
        <span class="material-symbols-outlined">payments</span>
        <span class="text-[11px] font-medium uppercase tracking-wider mt-1">Budgets</span>
      </a>
      <a class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:text-primary transition-transform active:scale-90 duration-200" href="#">
        <span class="material-symbols-outlined">menu</span>
        <span class="text-[11px] font-medium uppercase tracking-wider mt-1">More</span>
      </a>
    </div>
  </nav>

</body>
