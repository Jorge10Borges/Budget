---
import MainLayout from '../layouts/MainLayout.astro';
import NavBarDesktop from '../components/NavBarDesktop.astro';
import NavBarMobil from '../components/NavBarMobil.astro';

// Datos ficticios para mostrar UI
const projects = [
  {
    id: 1,
    name: 'Construcción Hospital Central',
    client: 'Municipio Central',
    status: 'active',
    budget: 2500000,
    collected: 900000,
    spent: 650000,
    currency: 'USD',
    start_date: '2025-10-01',
    end_date: '2027-03-31',
    last_activity: '2026-03-21'
  },
  {
    id: 2,
    name: 'Instalación Eléctrica Planta A',
    client: 'EnergiaCorp',
    status: 'draft',
    budget: 320000,
    collected: 160000,
    spent: 80000,
    currency: 'USD',
    start_date: '2026-05-15',
    end_date: '2026-11-30',
    last_activity: '2026-02-10'
  },
  {
    id: 3,
    name: 'Rehabilitación del Puente Norte',
    client: 'Dirección de Obras',
    status: 'paused',
    budget: 780000,
    collected: 390000,
    spent: 600000,
    currency: 'USD',
    start_date: '2024-09-01',
    end_date: '2025-12-15',
    last_activity: '2025-11-08'
  }
];
---

<MainLayout>
  <NavBarDesktop />

  <main class="pt-24 px-6 max-w-4xl mx-auto">
    <header class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-extrabold text-on-surface">Proyectos</h1>
        <p class="text-sm text-on-surface-variant">Listado de proyectos (datos ficticios)</p>
      </div>
      <div class="hidden sm:flex items-center gap-3">
        <input type="search" placeholder="Buscar proyecto..." class="px-3 py-2 rounded-md border border-outline-variant bg-surface-container-low text-on-surface focus:outline-none focus:ring-2 focus:ring-surface-tint" />
        <button class="px-3 py-2 bg-primary text-on-primary rounded-md">Nuevo proyecto</button>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {projects.map((p) => (
        <article class="bg-surface-container-low p-4 rounded-xl shadow-[0_8px_24px_rgba(13,28,47,0.04)] border border-outline-variant/10">
          <div class="flex justify-between items-start mb-3">
            <div>
              <h2 class="text-lg font-bold text-on-surface">{p.name}</h2>
              <p class="text-xs text-on-surface-variant">{p.client}</p>
            </div>
            <div class="text-right">
              <div class="text-sm font-semibold text-on-surface-variant">{p.currency} {p.budget.toLocaleString()}</div>
              <div class="text-[11px] mt-1">
                <span class={`inline-block px-2 py-0.5 rounded-full text-[11px] font-medium ${p.status === 'active' ? 'badge-active' : p.status === 'draft' ? 'badge-draft' : p.status === 'paused' ? 'badge-paused' : ''}`}>
                  {p.status}
                </span>
              </div>
            </div>
          </div>

          <!-- Progreso: Cobrado / Gastado -->
          {(() => {
            const collectedPct = p.budget ? Math.min(100, Math.round((p.collected / p.budget) * 100)) : 0;
            const spentPct = p.budget ? Math.min(100, Math.round((p.spent / p.budget) * 100)) : 0;
            return (
              <div class="mt-2 space-y-3">
                <div>
                  <div class="flex justify-between items-center text-xs text-on-surface-variant mb-1">
                    <span>Cobrado</span>
                    <span class="font-medium">{p.currency} {p.collected.toLocaleString()} · {collectedPct}%</span>
                  </div>
                  <div class="w-full h-2 rounded-md bg-surface-dim overflow-hidden">
                    <div class="h-2 bg-primary" style={`width: ${collectedPct}%`}></div>
                  </div>
                </div>

                <div>
                  <div class="flex justify-between items-center text-xs text-on-surface-variant mb-1">
                    <span>Gastado</span>
                    <span class="font-medium">{p.currency} {p.spent.toLocaleString()} · {spentPct}%</span>
                  </div>
                  <div class="w-full h-2 rounded-md bg-surface-dim overflow-hidden">
                    <div class="h-2 bg-error" style={`width: ${spentPct}%`}></div>
                  </div>
                </div>
              </div>
            );
          })()}

          <div class="flex items-center justify-between mt-4">
            <div class="text-xs text-on-surface-variant space-y-0.5">
              <div>Inicio: {p.start_date}</div>
              <div>Última actividad: {p.last_activity}</div>
            </div>
            <div class="flex items-center gap-2">
              <button class="text-[12px] text-primary">Ver</button>
              <button class="text-[12px] text-primary">Editar</button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>

  <NavBarMobil />
</MainLayout>
