---
import "../styles/global.css";
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Proyectos - Architect Ledger</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>

<body class="bg-background text-on-surface antialiased pb-24">
  <!-- TopAppBar -->
  <header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface/80 backdrop-blur-md">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center text-on-primary text-xs font-bold">UP</div>
      <h1 class="text-xl font-bold text-on-surface tracking-tighter">Architect Ledger</h1>
    </div>
    <div class="flex items-center gap-4">
      <button class="material-symbols-outlined text-primary">notifications</button>
    </div>
  </header>

  <main class="pt-20 px-4 max-w-md mx-auto">
    <!-- Page Title -->
    <div class="mb-6 flex justify-between items-end">
      <div>
        <p class="text-[0.6875rem] uppercase tracking-widest text-on-surface-variant font-bold mb-1">Listado Maestro</p>
        <h2 class="text-2xl font-extrabold tracking-tight text-on-surface">Proyectos</h2>
      </div>
      <div class="flex gap-2">
        <span class="bg-primary-fixed text-on-primary-fixed-variant text-[10px] font-bold px-2 py-1 rounded-full">12 ACTIVOS</span>
      </div>
    </div>

    <!-- Search & Filter -->
    <div class="flex gap-3 mb-8">
      <div class="flex-1 relative">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-sm">search</span>
        <input class="w-full pl-10 pr-4 py-3 bg-surface-container-low border-b border-outline-variant/20 focus:bg-surface-container-lowest focus:border-primary focus:ring-0 transition-all text-sm rounded-xl" placeholder="Buscar proyecto..." type="text" />
      </div>
      <button class="w-12 h-12 flex items-center justify-center bg-surface-container-high rounded-xl text-on-surface-variant active:scale-95 transition-transform">
        <span class="material-symbols-outlined">filter_list</span>
      </button>
    </div>

    <!-- Project Cards List -->
    <div class="space-y-4">
      <!-- Card 1 -->
      <article class="bg-surface-container-lowest p-5 rounded-2xl shadow-md border border-outline-variant/10">
        <div class="flex justify-between items-start mb-4">
          <div class="space-y-1">
            <span class="text-[0.6875rem] font-medium text-on-surface-variant tracking-wider">PRJ-2024-001</span>
            <h3 class="text-base font-bold text-on-surface leading-tight">Residencial Skyview</h3>
          </div>
          <button class="material-symbols-outlined text-outline">more_vert</button>
        </div>
        <div class="flex items-center gap-2 mb-4">
          <span class="px-3 py-1 bg-tertiary-fixed text-tertiary text-[10px] font-bold uppercase tracking-wider rounded-full">En curso</span>
        </div>

        <!-- Financial Summary -->
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div>
            <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Presupuesto</p>
            <p class="text-sm font-semibold text-on-surface">$1.240.000</p>
          </div>
          <div class="text-right">
            <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Gastado</p>
            <p class="text-sm font-semibold text-primary">$845.200</p>
          </div>
        </div>

        <!-- Progress Bar -->
        <div>
          <div class="flex justify-between text-[0.6875rem] font-bold text-on-surface-variant mb-2">
            <span>Progreso Visual</span>
            <span>68%</span>
          </div>
          <div class="h-1.5 w-full bg-surface-container rounded-full overflow-hidden">
            <div class="h-full bg-primary rounded-full" style="width:68%"></div>
          </div>
        </div>
      </article>

      <!-- Card 2 -->
      <article class="bg-surface-container-lowest p-5 rounded-2xl shadow-md border border-outline-variant/10">
        <div class="flex justify-between items-start mb-4">
          <div class="space-y-1">
            <span class="text-[0.6875rem] font-medium text-on-surface-variant tracking-wider">PRJ-2023-089</span>
            <h3 class="text-base font-bold text-on-surface leading-tight">Puente Sur</h3>
          </div>
          <button class="material-symbols-outlined text-outline">more_vert</button>
        </div>
        <div class="flex items-center gap-2 mb-4">
          <span class="px-3 py-1 bg-error-container text-error text-[10px] font-bold uppercase tracking-wider rounded-full">Retrasado</span>
        </div>
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div>
            <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Presupuesto</p>
            <p class="text-sm font-semibold text-on-surface">$3.500.000</p>
          </div>
          <div class="text-right">
            <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Gastado</p>
            <p class="text-sm font-semibold text-primary">$3.120.000</p>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-[0.6875rem] font-bold text-on-surface-variant mb-2">
            <span>Progreso Visual</span>
            <span>89%</span>
          </div>
          <div class="h-1.5 w-full bg-surface-container rounded-full overflow-hidden">
            <div class="h-full bg-error rounded-full" style="width:89%"></div>
          </div>
        </div>
      </article>

      <!-- Card 3 -->
      <article class="bg-surface-container-lowest p-5 rounded-2xl shadow-md border border-outline-variant/10">
        <div class="flex justify-between items-start mb-4">
          <div class="space-y-1">
            <span class="text-[0.6875rem] font-medium text-on-surface-variant tracking-wider">PRJ-2024-012</span>
            <h3 class="text-base font-bold text-on-surface leading-tight">Complejo Industrial Norte</h3>
          </div>
          <button class="material-symbols-outlined text-outline">more_vert</button>
        </div>
        <div class="flex items-center gap-2 mb-4">
          <span class="px-3 py-1 bg-secondary-container text-on-secondary-container text-[10px] font-bold uppercase tracking-wider rounded-full">Finalizado</span>
        </div>
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div>
            <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Presupuesto</p>
            <p class="text-sm font-semibold text-on-surface">$850.000</p>
          </div>
          <div class="text-right">
            <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Gastado</p>
            <p class="text-sm font-semibold text-primary">$842.100</p>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-[0.6875rem] font-bold text-on-surface-variant mb-2">
            <span>Progreso Visual</span>
            <span>100%</span>
          </div>
          <div class="h-1.5 w-full bg-surface-container rounded-full overflow-hidden">
            <div class="h-full bg-tertiary rounded-full" style="width:100%"></div>
          </div>
        </div>
      </article>
    </div>
  </main>

  <!-- Floating Action Button (FAB) -->
  <button class="fixed right-6 bottom-24 w-14 h-14 bg-gradient-to-br from-primary to-primary-container text-on-primary rounded-2xl shadow-lg flex items-center justify-center active:scale-95 transition-all z-50">
    <span class="material-symbols-outlined" style="font-size:28px">add</span>
  </button>

  <!-- BottomNavBar -->
  <nav class="fixed bottom-0 w-full z-50 rounded-t-2xl bg-white shadow-[0_-8px_32px_rgba(13,28,47,0.06)] border-t border-outline-variant/15 flex justify-around items-center h-20 px-4 pb-safe">
    <div class="flex flex-col items-center justify-center text-[#434655] px-5 py-2">
      <span class="material-symbols-outlined">dashboard</span>
      <span class="text-[10px] uppercase tracking-widest font-bold mt-1">Panel</span>
    </div>
    <div class="flex flex-col items-center justify-center bg-primary-fixed text-primary px-5 py-2 rounded-2xl">
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">architecture</span>
      <span class="text-[10px] uppercase tracking-widest font-bold mt-1">Proyectos</span>
    </div>
    <div class="flex flex-col items-center justify-center text-[#434655] px-5 py-2">
      <span class="material-symbols-outlined">request_quote</span>
      <span class="text-[10px] uppercase tracking-widest font-bold mt-1">Valuaciones</span>
    </div>
    <div class="flex flex-col items-center justify-center text-[#434655] px-5 py-2">
      <span class="material-symbols-outlined">menu_book</span>
      <span class="text-[10px] uppercase tracking-widest font-bold mt-1">Libro</span>
    </div>
  </nav>

</body>
