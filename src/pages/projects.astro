---
import "../styles/global.css";
export const prerender = false;

const apiToken = process.env.API_TOKEN;
const { request } = Astro;
const base = new URL(request.url);

let projects = [];
let meta = {};

try {
  const url = new URL('/api/projects', base.origin);
  url.searchParams.set('per_page', '100');
  // Build Headers safely so TypeScript/ASTRO doesn't complain about possibly undefined values
  const headers = new Headers();
  if (apiToken) headers.set('x-api-token', apiToken);
  const res = await fetch(url.toString(), { headers });
  if (res.ok) {
    const json = await res.json();
    projects = json.data || [];
    meta = json.meta || {};
  } else {
    console.error('API /api/projects responded', res.status);
  }
} catch (err) {
  console.error('Failed to fetch /api/projects', err);
}

// Serializar para inyección segura en cliente
const PROJECTS_JSON = JSON.stringify(projects ?? []);
// Además preparar una versión codificada (URI) para evitar problemas de escape/HTML
const PROJECTS_ENCODE = encodeURIComponent(PROJECTS_JSON);

// Helper: badge classes and icon mapping for project status
function badgeClasses(status: unknown) {
  const s = String(status || '').toLowerCase();
  if (s === 'active') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant text-xs font-semibold';
  if (s === 'draft') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface-container-low text-on-surface-variant text-xs font-semibold';
  if (s === 'paused') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-error text-on-error text-xs font-semibold';
  if (s === 'completed') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-tertiary text-on-tertiary text-xs font-semibold';
  if (s === 'cancelled') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-error-container text-error text-xs font-semibold';
  return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface-container-low text-on-surface-variant text-xs font-semibold';
}

function badgeIcon(status: unknown) {
  const s = String(status || '').toLowerCase();
  if (s === 'active') return 'check_circle';
  if (s === 'draft') return 'edit';
  if (s === 'paused') return 'pause_circle';
  if (s === 'completed') return 'task_alt';
  if (s === 'cancelled') return 'cancel';
  return 'info';
}
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Proyectos - Architect Ledger</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>

<body class="bg-background text-on-surface antialiased pb-24">
  <!-- TopAppBar -->
  <header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface/80 backdrop-blur-md">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center text-on-primary text-xs font-bold">UP</div>
      <h1 class="text-xl font-bold text-on-surface tracking-tighter">Architect Ledger</h1>
    </div>
    <div class="flex items-center gap-4">
      <button class="material-symbols-outlined text-primary">notifications</button>
    </div>
  </header>

  <main class="pt-20 px-4 max-w-md mx-auto">
    <!-- Page Title -->
    <div class="mb-6 flex justify-between items-end">
      <div>
        <p class="text-[0.6875rem] uppercase tracking-widest text-on-surface-variant font-bold mb-1">Listado Maestro</p>
        <h2 class="text-2xl font-extrabold tracking-tight text-on-surface">Proyectos</h2>
      </div>
      <div class="flex gap-2">
        <span class="bg-primary-fixed text-on-primary-fixed-variant text-[10px] font-bold px-2 py-1 rounded-full">12 ACTIVOS</span>
      </div>
    </div>

    <!-- Search & Filter -->
    <div class="flex gap-3 mb-8">
      <div class="flex-1 relative">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-sm">search</span>
        <input class="w-full pl-10 pr-4 py-3 bg-surface-container-low border-b border-outline-variant/20 focus:bg-surface-container-lowest focus:border-primary focus:ring-0 transition-all text-sm rounded-xl" placeholder="Buscar proyecto..." type="text" />
      </div>
      <button class="w-12 h-12 flex items-center justify-center bg-surface-container-high rounded-xl text-on-surface-variant active:scale-95 transition-transform">
        <span class="material-symbols-outlined">filter_list</span>
      </button>
    </div>

    <!-- Project Cards List -->
    <div id="projects-list" class="space-y-4">
      {projects.length === 0 ? (
        <p class="text-sm text-on-surface-variant">No hay proyectos para mostrar.</p>
      ) : (
        projects.map((p: { external_id: any; id: any; name: unknown; client: unknown; status: unknown; budget_amount: any; start_date: string; }) => (
          <article class="bg-surface-container-lowest p-5 rounded-2xl shadow-md border border-outline-variant/10">
            <div class="flex justify-between items-start mb-4">
              <div class="space-y-1">
                <span class="text-[0.6875rem] font-medium text-on-surface-variant tracking-wider">{p.external_id || p.id}</span>
                <h3 class="text-base font-bold text-on-surface leading-tight">{p.name}</h3>
                {p.client ? <p class="text-[0.75rem] text-on-surface-variant">{p.client}</p> : null}
              </div>
                      <div class="text-right">
                        <button class="more-btn material-symbols-outlined text-outline" data-project-id={p.id} aria-haspopup="true" aria-label="Más opciones">more_vert</button>
                <div class="text-right">
                  <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Fechas</p>
                  <p class="text-sm font-semibold text-primary">{p.start_date ? p.start_date.split('T')[0] : '—'}</p>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-2 mb-4">
              <span class={badgeClasses(p.status)} role="status" aria-label={String(p.status)}>
                <span class="material-symbols-outlined text-[14px] leading-none">{badgeIcon(p.status)}</span>
                <span class="uppercase tracking-wider text-[10px]">{String(p.status)}</span>
              </span>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-6">
              <div>
                <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Presupuesto</p>
                <p class="text-sm font-semibold text-on-surface">{p.budget_amount ? `$${Number(p.budget_amount).toLocaleString('en-US')}` : '—'}</p>
              </div>
              <div class="text-right">
                <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Gastado</p>
                <p class="text-sm font-semibold text-primary">Monto Gastado</p>
              </div>
            </div>

            <div>
              <div class="flex justify-between text-[0.6875rem] font-bold text-on-surface-variant mb-2">
                <span>Progreso Visual</span>
                <span>—</span>
              </div>
              <div class="h-1.5 w-full bg-surface-container rounded-full overflow-hidden">
                <div class="h-full bg-primary rounded-full" style="width:0%"></div>
              </div>
            </div>
          </article>
        ))
      )}
    </div>
  </main>

  <!-- Floating Action Button (FAB) -->
  <button id="fab-create" class="fixed right-6 bottom-24 w-14 h-14 bg-linear-to-br from-primary to-primary-container text-on-primary rounded-2xl shadow-lg flex items-center justify-center active:scale-95 transition-all z-50" aria-label="Crear proyecto">
    <span class="material-symbols-outlined" style="font-size:28px">add</span>
  </button>

  <!-- BottomNavBar -->
  <nav class="fixed bottom-0 w-full z-50 rounded-t-2xl bg-white shadow-[0_-8px_32px_rgba(13,28,47,0.06)] border-t border-outline-variant/15 flex justify-around items-center h-20 px-4 pb-safe">
    <div class="flex flex-col items-center justify-center text-on-surface-variant px-5 py-2">
      <span class="material-symbols-outlined">dashboard</span>
      <span class="text-[10px] uppercase tracking-widest font-bold mt-1">Panel</span>
    </div>
    <div class="flex flex-col items-center justify-center bg-primary-fixed text-primary px-5 py-2 rounded-2xl">
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">architecture</span>
      <span class="text-[10px] uppercase tracking-widest font-bold mt-1">Proyectos</span>
    </div>
    <div class="flex flex-col items-center justify-center text-on-surface-variant px-5 py-2">
      <span class="material-symbols-outlined">request_quote</span>
      <span class="text-[10px] uppercase tracking-widest font-bold mt-1">Valuaciones</span>
    </div>
    <div class="flex flex-col items-center justify-center text-on-surface-variant px-5 py-2">
      <span class="material-symbols-outlined">menu_book</span>
      <span class="text-[10px] uppercase tracking-widest font-bold mt-1">Libro</span>
    </div>
  </nav>

  <!-- Modal: project actions -->
  <div id="project-menu-modal" class="hidden fixed inset-0 z-50 items-end sm:items-center justify-center">
    <div id="modal-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <div id="modal-panel" class="relative w-full sm:max-w-sm bg-surface p-4 rounded-t-2xl sm:rounded-2xl mx-4 mb-6 sm:mb-0 shadow-xl ring-1 ring-black/5 opacity-0 translate-y-6 scale-95 transition-all duration-200 ease-out">
      <header class="flex items-start justify-between gap-4 mb-3">
        <div>
          <h3 class="text-base font-semibold">Opciones del Proyecto</h3>
          <p class="text-[12px] text-on-surface-variant mt-1">Selecciona una acción rápida para el proyecto seleccionado.</p>
        </div>
        <button id="modal-close" aria-label="Cerrar menú" class="text-on-surface-variant hover:text-on-surface transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </header>

      <nav aria-label="Acciones de proyecto">
        <ul class="grid gap-2">
          <li>
            <button id="modal-edit" class="w-full flex items-center gap-3 px-3 py-3 rounded-lg hover:bg-surface-container-lowest transition-colors">
              <span class="material-symbols-outlined text-primary">edit</span>
              <div class="text-left">
                <div class="font-medium text-on-surface">Editar</div>
                <div class="text-[12px] text-on-surface-variant">Modifica los datos del proyecto</div>
              </div>
            </button>
          </li>

          <li>
            <button id="modal-delete" class="w-full flex items-center gap-3 px-3 py-3 rounded-lg hover:bg-error-container/10 transition-colors">
              <span class="material-symbols-outlined text-error">delete</span>
              <div class="text-left">
                <div class="font-medium text-error">Eliminar</div>
                <div class="text-[12px] text-on-surface-variant">Eliminará el proyecto (acción irreversible)</div>
              </div>
            </button>
          </li>
        </ul>
      </nav>
    </div>
  </div>

  <!-- Modal: project form (create / edit) -->
  <div id="project-form-modal" class="hidden fixed inset-0 z-60 items-end sm:items-center justify-center">
    <div id="form-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <div id="form-panel" class="relative w-full sm:max-w-lg bg-surface p-4 rounded-t-2xl sm:rounded-2xl mx-4 mb-6 sm:mb-0 shadow-xl ring-1 ring-black/5 opacity-0 translate-y-6 scale-95 transition-all duration-200 ease-out">
      <header class="flex items-start justify-between gap-4 mb-3">
        <div>
          <h3 id="form-title" class="text-base font-semibold">Nuevo Proyecto</h3>
          <p class="text-[12px] text-on-surface-variant mt-1">Rellena los campos para crear o editar un proyecto.</p>
        </div>
        <button id="form-close" aria-label="Cerrar formulario" class="text-on-surface-variant hover:text-on-surface transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </header>

      <form id="project-form" class="space-y-3">
        <input type="hidden" id="form-id" name="id" />

        <div>
          <label class="text-[12px] font-semibold">Nombre</label>
          <input id="form-name" name="name" required class="w-full mt-1 px-3 py-2 rounded-lg bg-surface-container-low border border-outline-variant/10" />
        </div>

        <div>
          <label class="text-[12px] font-semibold">Cliente</label>
          <input id="form-client" name="client" class="w-full mt-1 px-3 py-2 rounded-lg bg-surface-container-low border border-outline-variant/10" />
        </div>

        <div>
          <label class="text-[12px] font-semibold">Descripción</label>
          <textarea id="form-description" name="description" rows="3" class="w-full mt-1 px-3 py-2 rounded-lg bg-surface-container-low border border-outline-variant/10"></textarea>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-[12px] font-semibold">Presupuesto</label>
            <input id="form-budget" name="budget_amount" type="number" step="0.01" class="w-full mt-1 px-3 py-2 rounded-lg bg-surface-container-low border border-outline-variant/10" />
          </div>
          <div>
            <label class="text-[12px] font-semibold">Moneda</label>
            <input id="form-currency" name="currency" class="w-full mt-1 px-3 py-2 rounded-lg bg-surface-container-low border border-outline-variant/10" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-[12px] font-semibold">Inicio</label>
            <input id="form-start" name="start_date" type="date" class="w-full mt-1 px-3 py-2 rounded-lg bg-surface-container-low border border-outline-variant/10" />
          </div>
          <div>
            <label class="text-[12px] font-semibold">Fin</label>
            <input id="form-end" name="end_date" type="date" class="w-full mt-1 px-3 py-2 rounded-lg bg-surface-container-low border border-outline-variant/10" />
          </div>
        </div>

        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <input id="form-active" name="is_active" type="checkbox" checked />
            <label class="text-[12px]">Activo</label>
          </div>
          <div>
            <label class="text-[12px] font-semibold">Estado</label>
            <select id="form-status" name="status" class="ml-2 px-2 py-1 rounded-lg bg-surface-container-low border border-outline-variant/10">
              <option value="active">active</option>
              <option value="draft">draft</option>
              <option value="paused">paused</option>
              <option value="completed">completed</option>
              <option value="cancelled">cancelled</option>
            </select>
          </div>
        </div>

        <div class="flex justify-end gap-2 pt-2">
          <button type="button" id="form-cancel" class="px-4 py-2 rounded-lg bg-surface-container-high">Cancelar</button>
          <button type="submit" id="form-submit" class="px-4 py-2 rounded-lg bg-primary text-on-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Server-provided initial data (safe JSON blob) -->
  <!-- Server-provided initial data (URI-encoded JSON to avoid template/escaping issues) -->
  <script id="projects-json-enc" type="application/json" set:html={PROJECTS_ENCODE}></script>

  <script type="module">
    // Guard: ensure slot.assignedNodes never returns undefined entries
    (function(){
      try {
        if (typeof HTMLSlotElement !== 'undefined' && HTMLSlotElement.prototype.assignedNodes) {
          const _origAssignedNodes = HTMLSlotElement.prototype.assignedNodes;
          HTMLSlotElement.prototype.assignedNodes = function(opts) {
            try {
              const res = _origAssignedNodes.call(this, opts) || [];
              return Array.isArray(res) ? res.filter(Boolean) : [];
            } catch (e) {
              return [];
            }
          };
        }
      } catch (e) {
        // ignore
      }
    })();
    // Read initial projects from URI-encoded JSON blob and decode safely
    const __projectsEncEl = document.getElementById('projects-json-enc');
    try {
      const enc = __projectsEncEl && __projectsEncEl.textContent ? __projectsEncEl.textContent.trim() : '';
      if (!enc) {
        window.__PROJECTS = [];
      } else {
        const jsonStr = decodeURIComponent(enc);
        window.__PROJECTS = JSON.parse(jsonStr || '[]');
      }
    } catch (err) {
      console.error('Failed to parse initial projects JSON (enc)', err);
      window.__PROJECTS = [];
    }

    // Helper cliente: escapar texto básico
    function esc(s) {
      if (s === null || s === undefined) return '';
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function clientBadgeClasses(status) {
      const s = String(status || '').toLowerCase();
      if (s === 'active') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant text-xs font-semibold';
      if (s === 'draft') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface-container-low text-on-surface-variant text-xs font-semibold';
      if (s === 'paused') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-error text-on-error text-xs font-semibold';
      if (s === 'completed') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-tertiary text-on-tertiary text-xs font-semibold';
      if (s === 'cancelled') return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-error-container text-error text-xs font-semibold';
      return 'inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface-container-low text-on-surface-variant text-xs font-semibold';
    }

    function clientBadgeIcon(status) {
      const s = String(status || '').toLowerCase();
      if (s === 'active') return 'check_circle';
      if (s === 'draft') return 'edit';
      if (s === 'paused') return 'pause_circle';
      if (s === 'completed') return 'task_alt';
      if (s === 'cancelled') return 'cancel';
      return 'info';
    }

    function formatDate(dateStr) {
      if (!dateStr) return '—';
      return String(dateStr).split('T')[0];
    }

    function formatMoney(amount) {
      if (amount === null || amount === undefined || amount === '') return '—';
      return `$${Number(amount).toLocaleString('en-US')}`;
    }

    // Render dinámico del listado de proyectos
    function renderProjects() {
      const container = document.getElementById('projects-list');
      if (!container) return;
      const html = (window.__PROJECTS || []).map(p => `
        <article class="bg-surface-container-lowest p-5 rounded-2xl shadow-md border border-outline-variant/10">
          <div class="flex justify-between items-start mb-4">
            <div class="space-y-1">
              <span class="text-[0.6875rem] font-medium text-on-surface-variant tracking-wider">${esc(p.external_id || p.id)}</span>
              <h3 class="text-base font-bold text-on-surface leading-tight">${esc(p.name)}</h3>
              ${p.client ? `<p class="text-[0.75rem] text-on-surface-variant">${esc(p.client)}</p>` : ''}
            </div>
            <div class="text-right">
              <button class="more-btn material-symbols-outlined text-outline" data-project-id="${esc(p.id)}" aria-haspopup="true" aria-label="Más opciones">more_vert</button>
              <div class="text-right">
                <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Fechas</p>
                <p class="text-sm font-semibold text-primary">${formatDate(p.start_date)}</p>
              </div>
            </div>
          </div>
          <div class="flex items-center gap-2 mb-4">
            <span class="${clientBadgeClasses(p.status)}" role="status" aria-label="${esc(String(p.status))}">
              <span class="material-symbols-outlined text-[14px] leading-none">${clientBadgeIcon(p.status)}</span>
              <span class="uppercase tracking-wider text-[10px]">${esc(String(p.status))}</span>
            </span>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div>
              <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Presupuesto</p>
              <p class="text-sm font-semibold text-on-surface">${formatMoney(p.budget_amount)}</p>
            </div>
            <div class="text-right">
              <p class="text-[0.625rem] text-on-surface-variant uppercase font-bold mb-1">Gastado</p>
              <p class="text-sm font-semibold text-primary">Monto Gastado</p>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-[0.6875rem] font-bold text-on-surface-variant mb-2">
              <span>Progreso Visual</span>
              <span>—</span>
            </div>
            <div class="h-1.5 w-full bg-surface-container rounded-full overflow-hidden">
              <div class="h-full bg-primary rounded-full" style="width:0%"></div>
            </div>
          </div>
        </article>
      `).join('');
      container.innerHTML = html;
    }

    // Render inicial (mantiene markup server si no hay cambios)
    renderProjects();

    // Actions menu modal
    const modal = document.getElementById('project-menu-modal');
    const backdrop = document.getElementById('modal-backdrop');
    const panel = document.getElementById('modal-panel');
    const btnEdit = document.getElementById('modal-edit');
    const btnDelete = document.getElementById('modal-delete');
    const btnClose = document.getElementById('modal-close');
    let currentProjectId = null;

    function openModal(projectId) {
      currentProjectId = projectId;
      modal.classList.add('flex');
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      panel.classList.remove('translate-y-0','opacity-100','scale-100');
      panel.classList.add('translate-y-6','opacity-0','scale-95');
      requestAnimationFrame(() => {
        backdrop.classList.remove('opacity-0');
        backdrop.classList.add('opacity-100');
        panel.classList.remove('translate-y-6','opacity-0','scale-95');
        panel.classList.add('translate-y-0','opacity-100','scale-100');
      });
    }

    function closeModal() {
      currentProjectId = null;
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      panel.classList.remove('translate-y-0','opacity-100','scale-100');
      panel.classList.add('translate-y-6','opacity-0','scale-95');
      const onEnd = (e) => {
        if (e.target !== panel) return;
        panel.removeEventListener('transitionend', onEnd);
        modal.classList.remove('flex');
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      };
      panel.addEventListener('transitionend', onEnd);
    }

    // Delegate click for all more buttons
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('.more-btn');
      if (btn) {
        const id = btn.getAttribute('data-project-id') || btn.dataset.projectId;
        openModal(id);
      }
    });

    backdrop.addEventListener('click', closeModal);
    btnClose.addEventListener('click', closeModal);

    // Form modal (create / edit)
    const formModal = document.getElementById('project-form-modal');
    const formBackdrop = document.getElementById('form-backdrop');
    const formPanel = document.getElementById('form-panel');
    const formClose = document.getElementById('form-close');
    const formEl = document.getElementById('project-form');
    const formId = document.getElementById('form-id');
    const inputName = document.getElementById('form-name');
    const inputClient = document.getElementById('form-client');
    const inputDescription = document.getElementById('form-description');
    const inputBudget = document.getElementById('form-budget');
    const inputCurrency = document.getElementById('form-currency');
    const inputStart = document.getElementById('form-start');
    const inputEnd = document.getElementById('form-end');
    const inputActive = document.getElementById('form-active');
    const inputStatus = document.getElementById('form-status');
    const formSubmit = document.getElementById('form-submit');
    const formCancel = document.getElementById('form-cancel');
    const formTitle = document.getElementById('form-title');

    function openFormModal(project) {
      // project can be id or object
      let obj = null;
      if (!project) obj = null;
      else if (typeof project === 'string' || typeof project === 'number') {
        obj = window.__PROJECTS.find(p => String(p.id) === String(project) || String(p.external_id) === String(project));
      } else obj = project;

      formId.value = obj?.id ?? '';
      inputName.value = obj?.name ?? '';
      inputClient.value = obj?.client ?? '';
      inputDescription.value = obj?.description ?? '';
      inputBudget.value = obj?.budget_amount ?? '';
      inputCurrency.value = obj?.currency ?? '';
      inputStart.value = obj?.start_date ? obj.start_date.split('T')[0] : '';
      inputEnd.value = obj?.end_date ? obj.end_date.split('T')[0] : '';
      inputActive.checked = obj?.is_active === 1 || obj?.is_active === true || obj?.is_active === '1';
      inputStatus.value = obj?.status ?? 'draft';
      formTitle.textContent = obj ? 'Editar Proyecto' : 'Nuevo Proyecto';

      formModal.classList.add('flex');
      formModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      formBackdrop.classList.remove('opacity-100');
      formBackdrop.classList.add('opacity-0');
      formPanel.classList.remove('translate-y-0','opacity-100','scale-100');
      formPanel.classList.add('translate-y-6','opacity-0','scale-95');
      requestAnimationFrame(() => {
        formBackdrop.classList.remove('opacity-0');
        formBackdrop.classList.add('opacity-100');
        formPanel.classList.remove('translate-y-6','opacity-0','scale-95');
        formPanel.classList.add('translate-y-0','opacity-100','scale-100');
      });

      // Si es nuevo proyecto, enfocar el nombre después de la animación
      if (!obj) {
        setTimeout(() => {
          try { inputName.focus(); } catch (e) { /* ignore */ }
        }, 220);
      }
    }

    function closeFormModal() {
      formBackdrop.classList.remove('opacity-100');
      formBackdrop.classList.add('opacity-0');
      formPanel.classList.remove('translate-y-0','opacity-100','scale-100');
      formPanel.classList.add('translate-y-6','opacity-0','scale-95');
      const onEnd = (e) => {
        if (e.target !== formPanel) return;
        formPanel.removeEventListener('transitionend', onEnd);
        formModal.classList.remove('flex');
        formModal.classList.add('hidden');
        document.body.style.overflow = '';
      };
      formPanel.addEventListener('transitionend', onEnd);
    }

    // Wire up edit to open form modal
    btnEdit.addEventListener('click', () => {
      if (!currentProjectId) return closeModal();
      openFormModal(currentProjectId);
      closeModal();
    });

    // Delete via API
    btnDelete.addEventListener('click', async () => {
      if (!currentProjectId) return closeModal();
      const ok = confirm('Confirmar eliminación del proyecto ' + currentProjectId + '?');
      if (!ok) return;
      try {
        const res = await fetch('/api/projects/server?id=' + encodeURIComponent(currentProjectId), { method: 'DELETE' });
        if (!res.ok) throw new Error('Delete failed');
        const data = await res.json();
        // actualizar listado en cliente
        const deletedId = String(data?.data?.id ?? currentProjectId);
        window.__PROJECTS = (window.__PROJECTS || []).filter(p => String(p.id) !== deletedId && String(p.external_id) !== deletedId);
        renderProjects();
        alert('Proyecto eliminado: ' + deletedId);
      } catch (err) {
        console.error('Delete failed', err);
        alert('Error al eliminar');
      }
      closeModal();
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (!formModal.classList.contains('hidden')) closeFormModal();
        else closeModal();
      }
    });

    // FAB opens create form
    const fab = document.getElementById('fab-create');
    if (fab) fab.addEventListener('click', () => openFormModal(null));

    // Form controls
    formClose.addEventListener('click', closeFormModal);
    formCancel.addEventListener('click', (e) => { e.preventDefault(); closeFormModal(); });

    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      formSubmit.disabled = true;
      const payload = {
        id: formId.value || undefined,
        name: inputName.value || undefined,
        client: inputClient.value || undefined,
        description: inputDescription.value || undefined,
        budget_amount: inputBudget.value ? Number(inputBudget.value) : undefined,
        currency: inputCurrency.value || undefined,
        start_date: inputStart.value || undefined,
        end_date: inputEnd.value || undefined,
        is_active: inputActive.checked ? 1 : 0,
        status: inputStatus.value || undefined,
      };

      try {
        const headers = { 'Content-Type': 'application/json' };
        const method = payload.id ? 'PUT' : 'POST';
        const url = '/api/projects/server';
        const res = await fetch(url, { method, headers, body: JSON.stringify(payload) });
        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Unknown' }));
          throw new Error(err.error || 'Request failed');
        }
        const data = await res.json();
        const proj = data?.data;
        if (proj) {
          const idStr = String(proj.id);
          if (method === 'POST') {
            // nuevo: añadir al inicio
            window.__PROJECTS = [proj].concat(window.__PROJECTS || []);
            renderProjects();
            alert('Proyecto creado: ' + idStr);
          } else {
            // update: reemplazar
            window.__PROJECTS = (window.__PROJECTS || []).map(p => (String(p.id) === idStr ? proj : p));
            renderProjects();
            alert('Proyecto actualizado: ' + idStr);
          }
        }
        closeFormModal();
      } catch (err) {
        console.error('Save failed', err);
        alert('Error al guardar: ' + (err.message || '')); 
      } finally {
        formSubmit.disabled = false;
      }
    });

    // Form backdrop click closes
    formBackdrop.addEventListener('click', closeFormModal);
  </script>

</body>
