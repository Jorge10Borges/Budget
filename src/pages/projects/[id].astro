---
import MainLayout from '../../layouts/MainLayout.astro';
import NavBarDesktop from '../../components/NavBarDesktop.astro';
import NavBarMobil from '../../components/NavBarMobil.astro';

export const prerender = false;

const projectId = (Astro.params as Record<string, string> | undefined)?.id ?? null;
export async function getStaticPaths() {
  return [];
}
---

<MainLayout>
  <NavBarDesktop />

  <main class="pt-24 px-6 container mx-auto">
    <a href="/projects" class="text-sm text-primary">← Volver a proyectos</a>
    <div id="project-detail" data-id={projectId} class="mt-4 bg-surface-container-low p-4 rounded-xl shadow-[0_8px_24px_rgba(13,28,47,0.04)] border border-outline-variant/10">
      <div class="text-center text-on-surface-variant">Cargando proyecto...</div>
    </div>
  </main>

  <script type="module">
    const container = document.getElementById('project-detail');
    const _meta = document.querySelector('meta[name="api-base"]');
    const _apiBase = _meta ? _meta.content : 'http://localhost/Budget/api';

    function getProjectIdFromDOMorURL() {
      const idFromDom = container ? container.dataset.id : null;
      if (idFromDom) return idFromDom;
      // fallback: extract from pathname /projects/:id
      const m = window.location.pathname.match(/\/projects\/(\d+)/);
      return m ? m[1] : null;
    }

    function makeApiUrl(id) {
      return `${_apiBase.replace(/\/$/, '')}/projects.php?id=${encodeURIComponent(id)}`;
    }

    async function loadProject() {
      const id = getProjectIdFromDOMorURL();
      if (!id) {
        container.innerHTML = '<div class="text-error">ID de proyecto no disponible.</div>';
        return;
      }
      try {
        const res = await fetch(makeApiUrl(id), { cache: 'no-store' });
        if (!res.ok) throw new Error('Fetch failed');
        const data = await res.json();
        const p = Array.isArray(data) ? data[0] : (data.data || data.project || data);
        renderProject(p);
      } catch (e) {
        console.error(e);
        container.innerHTML = '<div class="text-error">No se pudo cargar el proyecto.</div>';
      }
    }

    // Re-load project when page is shown (covers bfcache / back navigation)
    window.addEventListener('pageshow', (ev) => {
      // If persisted from bfcache, ensure we re-fetch latest data
      if (ev.persisted) loadProject();
    });

    function renderProject(p) {
      if (!p) {
        document.getElementById('project-detail').innerHTML = '<div class="text-on-surface-variant">Proyecto no encontrado.</div>';
        return;
      }

      const fmt = new Intl.NumberFormat(undefined);
      const budget = Number(p.budget ?? p.calculated_budget ?? p.budget_amount ?? 0);
      const collected = Number(p.collected ?? 0);
      const spent = Number(p.spent ?? 0);
      const collectedPct = budget ? Math.min(100, Math.round((collected / budget) * 100)) : 0;
      const spentPct = budget ? Math.min(100, Math.round((spent / budget) * 100)) : 0;
      const status = (p.status ?? p.state ?? '').toString();
      const badge = status === 'active' ? 'badge-active' : status === 'draft' ? 'badge-draft' : status === 'paused' ? 'badge-paused' : '';

      document.getElementById('project-detail').innerHTML = `
        <header class="mb-4">
          <h1 class="text-2xl font-bold text-on-surface">${p.name ?? ''}</h1>
          <div class="text-sm text-on-surface-variant">${p.client ?? ''} · <span class="inline-block px-2 py-0.5 rounded-full text-[11px] font-medium ${badge}">${status}</span></div>
          <div id="kpis" class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-3">
            <!-- Featured KPI (Partidas) -->
            <div class="bg-gradient-to-br from-primary to-primary-container p-4 rounded-xl text-on-primary shadow-lg flex flex-col justify-between">
              <div class="flex items-start justify-between">
                <div>
                  <div class="text-[10px] font-medium uppercase opacity-90">Partidas</div>
                  <div id="kpi-items-total" class="text-2xl font-extrabold mt-2">—</div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined opacity-90">widgets</span>
                </div>
              </div>
              <div class="mt-3 text-sm text-on-primary/90 flex items-center justify-between">
                <div id="kpi-items-closed">Cerradas: —</div>
                <div class="text-xs bg-white/20 px-2 py-0.5 rounded-full">Ver partidas</div>
              </div>
            </div>

            <!-- Expenses KPI (red accent) -->
            <div class="bg-gradient-to-br from-on-error-container to-error-container p-4 rounded-xl text-on-error shadow-sm flex flex-col justify-between">
              <div class="flex items-start justify-between">
                <div>
                  <div class="text-[10px] font-medium uppercase text-white">Gastos</div>
                  <div id="kpi-expenses-total" class="text-2xl font-extrabold mt-2">—</div>
                </div>
                <span class="material-symbols-outlined text-white">receipt_long</span>
              </div>
              <div class="mt-3 text-sm text-white/90 flex items-center justify-between">
                <div id="kpi-expenses-closed">Cerrados: —</div>
                <a href="/projects/${p.id}/expenses" class="text-xs px-2 py-0.5 rounded-full bg-white/20 text-white">Ver gastos</a>
              </div>
            </div>

            <!-- Valuations KPI (green accent) -->
            <div class="bg-gradient-to-br from-tertiary to-tertiary-container p-4 rounded-xl text-on-tertiary shadow-sm flex flex-col justify-between">
              <div class="flex items-start justify-between">
                <div>
                  <div class="text-[10px] font-medium uppercase text-on-tertiary-container">Valuaciones</div>
                  <div id="kpi-vals-total" class="text-2xl font-extrabold mt-2">—</div>
                </div>
                <span class="material-symbols-outlined text-on-tertiary">assignment_turned_in</span>
              </div>
              <div class="mt-3 text-sm text-on-tertiary-container flex items-center justify-between">
                <div id="kpi-vals-closed">Cerradas: —</div>
                <a href="/projects/${p.id}/valuations" class="text-xs px-2 py-0.5 rounded-full bg-white/10 text-on-tertiary">Ver valuaciones</a>
              </div>
            </div>
          </div>
        </header>

        <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <div class="text-xs text-on-surface-variant mb-2">Presupuesto</div>
            <div class="text-lg font-semibold">${p.currency ?? 'USD'} ${fmt.format(budget)}</div>

            <div class="mt-4">
              <div class="text-xs text-on-surface-variant mb-1">Cobrado · ${collectedPct}%</div>
              <div class="w-full h-3 rounded-md bg-surface-dim overflow-hidden">
                <div class="h-3 bg-primary" style="width: ${collectedPct}%"></div>
              </div>
            </div>
          </div>
        </section>
        <section class="mt-6">
          <div>
            <div class="text-xs text-on-surface-variant">Inicio</div>
            <div class="font-medium">${p.start_date ?? p.startDate ?? ''}</div>
            <div class="text-xs text-on-surface-variant mt-3">Última actividad</div>
            <div class="font-medium">${p.last_activity ?? p.lastActivity ?? ''}</div>

            <div class="mt-4 flex items-center gap-2 justify-center">
              <a href="/projects/${p.id}/items" class="px-3 py-2 bg-surface-container-high text-on-surface rounded-md text-center flex items-center justify-start gap-1 rounded-2xl">
                <span class="material-symbols-outlined">widgets</span>
                Ver partidas
              </a>
              <a href="/projects/${p.id}/valuations" class="px-3 py-2 bg-primary text-on-primary rounded-md ml-2 text-center flex items-center justify-start gap-1 rounded-2xl">
                <span class="material-symbols-outlined">assignment_turned_in</span>
                Ver valuaciones
              </a>
              <a href="/projects/${p.id}/expenses/new" class="px-3 py-2 ml-2 border border-outline-variant rounded-md text-center flex items-center justify-start gap-1 rounded-2xl">
                <span class="material-symbols-outlined">receipt_long</span>
                Ver gastos
              </a>
            </div>
          </div>
        </section>

        <section class="mt-6">
          <h2 class="text-lg font-semibold text-on-surface">Detalle</h2>
          <p class="text-sm text-on-surface-variant mt-2">${p.description ?? p.desc ?? '—'}</p>
        </section>
      `;

      // Load KPIs
      (async () => {
        try {
          const _meta = document.querySelector('meta[name="api-base"]');
          const _apiBase = _meta ? _meta.content : 'http://localhost/Budget/api';
          const id = p.id ?? p.id ?? getProjectIdFromDOMorURL();
          if (!id) return;
          const res = await fetch(`${_apiBase.replace(/\/$/, '')}/kpis.php?project_id=${encodeURIComponent(id)}`, { cache: 'no-store' });
          if (!res.ok) throw new Error('KPIs fetch failed');
          const payload = await res.json();
          const d = payload.data || {};
          const items = d.project_items || { total: 0, closed: null };
          const expenses = d.expenses || { total: 0, closed: null };
          const vals = d.valuations || { total: 0, closed: null };
          document.getElementById('kpi-items-total').textContent = items.total ?? 0;
          document.getElementById('kpi-items-closed').textContent = 'Cerradas: ' + (items.closed !== null ? items.closed : '—');
          document.getElementById('kpi-expenses-total').textContent = expenses.total ?? 0;
          document.getElementById('kpi-expenses-closed').textContent = 'Cerrados: ' + (expenses.closed !== null ? expenses.closed : '—');
          document.getElementById('kpi-vals-total').textContent = vals.total ?? 0;
          document.getElementById('kpi-vals-closed').textContent = 'Cerradas: ' + (vals.closed !== null ? vals.closed : '—');
        } catch (e) {
          console.error('Failed to load KPIs', e);
        }
      })();

      
    }

    loadProject();
  </script>

  <NavBarMobil />
</MainLayout>
