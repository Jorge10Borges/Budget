---
import MainLayout from '../../layouts/MainLayout.astro';
import NavBarDesktop from '../../components/NavBarDesktop.astro';
import NavBarMobil from '../../components/NavBarMobil.astro';

export const prerender = false;

const projectId = (Astro.params as Record<string, string> | undefined)?.id ?? null;
export async function getStaticPaths() {
  return [];
}
---

<MainLayout>
  <NavBarDesktop />

  <main class="pt-24 px-6 container mx-auto">
    <a href="/projects" class="text-sm text-primary">← Volver a proyectos</a>
    <div id="project-detail" data-id={projectId} class="mt-4 bg-surface-container-low p-4 rounded-xl shadow-[0_8px_24px_rgba(13,28,47,0.04)] border border-outline-variant/10">
      <div class="text-center text-on-surface-variant">Cargando proyecto...</div>
    </div>
  </main>

  <script type="module">
    const container = document.getElementById('project-detail');
    const projectId = container ? container.dataset.id : null;
    const _meta = document.querySelector('meta[name="api-base"]');
    const _apiBase = _meta ? _meta.content : 'http://localhost/Budget/api';
    const apiUrl = `${_apiBase.replace(/\/$/, '')}/projects.php?id=${projectId}`;

    async function loadProject() {
      try {
        const res = await fetch(apiUrl, { cache: 'no-store' });
        if (!res.ok) throw new Error('Fetch failed');
        const data = await res.json();
        const p = Array.isArray(data) ? data[0] : (data.data || data.project || data);
        renderProject(p);
      } catch (e) {
        console.error(e);
        document.getElementById('project-detail').innerHTML = '<div class="text-error">No se pudo cargar el proyecto.</div>';
      }
    }

    function renderProject(p) {
      if (!p) {
        document.getElementById('project-detail').innerHTML = '<div class="text-on-surface-variant">Proyecto no encontrado.</div>';
        return;
      }

      const fmt = new Intl.NumberFormat(undefined);
      const budget = Number(p.budget ?? p.calculated_budget ?? p.budget_amount ?? 0);
      const collected = Number(p.collected ?? 0);
      const spent = Number(p.spent ?? 0);
      const collectedPct = budget ? Math.min(100, Math.round((collected / budget) * 100)) : 0;
      const spentPct = budget ? Math.min(100, Math.round((spent / budget) * 100)) : 0;
      const status = (p.status ?? p.state ?? '').toString();
      const badge = status === 'active' ? 'badge-active' : status === 'draft' ? 'badge-draft' : status === 'paused' ? 'badge-paused' : '';

      document.getElementById('project-detail').innerHTML = `
        <header class="mb-4">
          <h1 class="text-2xl font-bold text-on-surface">${p.name ?? ''}</h1>
          <div class="text-sm text-on-surface-variant">${p.client ?? ''} · <span class="inline-block px-2 py-0.5 rounded-full text-[11px] font-medium ${badge}">${status}</span></div>
        </header>

        <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <div class="text-xs text-on-surface-variant mb-2">Presupuesto</div>
            <div class="text-lg font-semibold">${p.currency ?? 'USD'} ${fmt.format(budget)}</div>

            <div class="mt-4">
              <div class="text-xs text-on-surface-variant mb-1">Cobrado · ${collectedPct}%</div>
              <div class="w-full h-3 rounded-md bg-surface-dim overflow-hidden">
                <div class="h-3 bg-primary" style="width: ${collectedPct}%"></div>
              </div>
            </div>

            <div class="mt-3">
              <div class="text-xs text-on-surface-variant mb-1">Gastado · ${spentPct}%</div>
              <div class="w-full h-3 rounded-md bg-surface-dim overflow-hidden">
                <div class="h-3 bg-error" style="width: ${spentPct}%"></div>
              </div>
            </div>
          </div>

          <div>
            <div class="text-xs text-on-surface-variant">Inicio</div>
            <div class="font-medium">${p.start_date ?? p.startDate ?? ''}</div>
            <div class="text-xs text-on-surface-variant mt-3">Última actividad</div>
            <div class="font-medium">${p.last_activity ?? p.lastActivity ?? ''}</div>

            <div class="mt-4">
              <button id="toggle-items-btn" class="px-3 py-2 bg-surface-container-high text-on-surface rounded-md">Ver partidas</button>
              <button class="px-3 py-2 bg-primary text-on-primary rounded-md ml-2">Agregar valuación</button>
              <button class="px-3 py-2 ml-2 border border-outline-variant rounded-md">Agregar gasto</button>
            </div>
            <div id="project-items" class="mt-4 hidden bg-surface-container-low p-3 rounded-md border border-outline-variant/10">
              <div class="text-on-surface-variant">Cargando partidas...</div>
            </div>
          </div>
        </section>

        <section class="mt-6">
          <h2 class="text-lg font-semibold text-on-surface">Detalle</h2>
          <p class="text-sm text-on-surface-variant mt-2">${p.description ?? p.desc ?? '—'}</p>
        </section>
      `;

      // Attach toggle handler for partidas
      setTimeout(() => {
        const toggleBtn = document.getElementById('toggle-items-btn');
        const itemsRoot = document.getElementById('project-items');
        let itemsLoaded = false;
        async function fetchItems() {
          if (!p.id) return;
          const _meta = document.querySelector('meta[name="api-base"]');
          const _apiBase = _meta ? _meta.content : 'http://localhost/Budget/api';
          const url = `${_apiBase.replace(/\/$/, '')}/project_items.php?project_id=${p.id}`;
          try {
            const res = await fetch(url, { cache: 'no-store' });
            if (!res.ok) throw new Error('Fetch failed');
            const data = await res.json();
            const items = Array.isArray(data) ? data : (data.data || []);
            renderItemsTable(items, itemsRoot);
            itemsLoaded = true;
          } catch (e) {
            console.error(e);
            itemsRoot.innerHTML = '<div class="text-error">No se pudieron cargar las partidas.</div>';
          }
        }

        function renderItemsTable(items, root) {
          if (!items || items.length === 0) {
            root.innerHTML = '<div class="text-on-surface-variant">No hay partidas asignadas a este proyecto.</div>';
            return;
          }
          const fmt = new Intl.NumberFormat(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
          let total = 0;
          const rows = items.map(it => {
            const qty = Number(it.qty || 0);
            const unitCost = Number(it.unit_cost || 0);
            const totalCost = Number(it.total_cost || (qty * unitCost) || 0);
            total += totalCost;
            return `<tr class="border-b border-outline-variant/10">
              <td class="px-3 py-2 text-sm">${it.item_name || it.item_id}</td>
              <td class="px-3 py-2 text-sm">${it.unit || ''}</td>
              <td class="px-3 py-2 text-sm text-right">${qty}</td>
              <td class="px-3 py-2 text-sm text-right">${fmt.format(unitCost)}</td>
              <td class="px-3 py-2 text-sm text-right font-medium">${fmt.format(totalCost)}</td>
            </tr>`;
          }).join('\n');

          root.innerHTML = `
            <div class="overflow-x-auto">
              <table class="w-full table-fixed text-left">
                <thead>
                  <tr class="text-xs text-on-surface-variant">
                    <th class="px-3 py-2">Partida</th>
                    <th class="px-3 py-2">Unidad</th>
                    <th class="px-3 py-2 text-right">Cantidad</th>
                    <th class="px-3 py-2 text-right">Costo unit.</th>
                    <th class="px-3 py-2 text-right">Total</th>
                  </tr>
                </thead>
                <tbody>
                  ${rows}
                </tbody>
                <tfoot>
                  <tr>
                    <td colspan="4" class="px-3 py-2 text-sm font-semibold text-right">Total presupuestado</td>
                    <td class="px-3 py-2 text-sm font-semibold text-right">${fmt.format(total)}</td>
                  </tr>
                </tfoot>
              </table>
            </div>
          `;
        }

        if (toggleBtn && itemsRoot) {
          toggleBtn.addEventListener('click', async () => {
            const isHidden = itemsRoot.classList.contains('hidden');
            if (isHidden) {
              itemsRoot.classList.remove('hidden');
              toggleBtn.textContent = 'Ocultar partidas';
              if (!itemsLoaded) await fetchItems();
            } else {
              itemsRoot.classList.add('hidden');
              toggleBtn.textContent = 'Ver partidas';
            }
          });
        }
      }, 50);
    }

    loadProject();
  </script>

  <NavBarMobil />
</MainLayout>
