---
import MainLayout from '../../../../layouts/MainLayout.astro';
import NavBarDesktop from '../../../../components/NavBarDesktop.astro';
import NavBarMobil from '../../../../components/NavBarMobil.astro';

export const prerender = false;

const projectId = (Astro.params as Record<string, string> | undefined)?.id ?? null;
export async function getStaticPaths() { return []; }
---

<MainLayout>
  <NavBarDesktop />

  <main class="pt-24 px-6 container mx-auto">
    <a href={`/projects/${projectId}/valuations`} class="text-sm text-primary cursor-pointer">← Volver a valuaciones</a>

    <div class="mt-4 bg-surface p-6 rounded-xl shadow-sm border border-outline-variant/10">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h1 class="text-2xl font-bold">Nueva valuación</h1>
          <p class="text-sm text-on-surface-variant">Crea una nueva valuación para este proyecto. Campos ficticios — sin scripts.</p>
        </div>
        <div>
          <div class="text-sm text-on-surface-variant text-end">
            Proyecto:
          </div>
          <strong id="project-name" class="text-2xl" data-project-id={projectId}>Proyecto</strong>
        </div>
      </div>

      <form class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="text-xs text-on-surface-variant">Fecha</label>
            <input type="date" value="2026-04-12" class="w-full mt-1 px-3 py-2 rounded border border-outline-variant" />
          </div>
          <div>
            <label class="text-xs text-on-surface-variant">Valuador</label>
            <input type="text" placeholder="Nombre del valuador" value="Ing. Laura Pérez" class="w-full mt-1 px-3 py-2 rounded border border-outline-variant" />
          </div>
          <div>
            <label class="text-xs text-on-surface-variant">Estado</label>
            <select class="w-full mt-1 px-3 py-2 rounded border border-outline-variant">
              <option>Borrador</option>
              <option>Aprobada</option>
              <option>En revisión</option>
              <option>Rechazada</option>
            </select>
          </div>
        </div>

        <div>
          <label class="text-xs text-on-surface-variant">Descripción</label>
          <textarea rows="3" class="w-full mt-1 px-3 py-2 rounded border border-outline-variant" placeholder="Notas u observaciones de la valuación">Inspección visual y mediciones de obra. Datos ficticios para diseño.</textarea>
        </div>

        <div>
          <div class="flex items-center justify-between mb-2">
            <div class="text-sm font-medium">Partidas incluidas</div>
            <button id="open-add-item" type="button" data-project-id={projectId} class="text-sm px-3 py-1 bg-primary text-on-primary rounded cursor-pointer">Agregar partida</button>
          </div>

          <div class="overflow-x-auto bg-surface-container-low rounded border border-outline-variant/10">
            <table class="w-full min-w-200">
              <thead class="text-xs text-on-surface-variant">
                <tr>
                  <th class="px-3 py-2 text-left">Partida</th>
                  <th class="px-3 py-2 text-center">Unidad</th>
                  <th class="px-3 py-2 text-right">Cantidad</th>
                  <th class="px-3 py-2 text-right">Costo unit.</th>
                  <th class="px-3 py-2 text-right">Total</th>
                  <th class="px-3 py-2 text-center">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-t border-outline-variant/10">
                  <td class="px-3 py-3 text-sm">Partida 001 - Excavación</td>
                  <td class="px-3 py-3 text-sm text-center">m3</td>
                  <td class="px-3 py-3 text-sm text-right">120.00</td>
                  <td class="px-3 py-3 text-sm text-right">$ 150.00</td>
                  <td class="px-3 py-3 text-sm text-right font-medium">$ 18,000.00</td>
                  <td class="px-3 py-3 text-sm text-center">
                    <button class="p-1 rounded hover:bg-button-hover text-on-surface cursor-pointer" title="Editar">
                      <span class="material-symbols-outlined">edit</span>
                    </button>
                    <button class="p-1 rounded hover:bg-button-hover text-error ml-2 cursor-pointer" title="Eliminar">
                      <span class="material-symbols-outlined">delete</span>
                    </button>
                  </td>
                </tr>
                <tr class="border-t border-outline-variant/10 bg-surface-container-high">
                  <td class="px-3 py-3 text-sm">Partida 012 - Hormigón</td>
                  <td class="px-3 py-3 text-sm text-center">m3</td>
                  <td class="px-3 py-3 text-sm text-right">40.00</td>
                  <td class="px-3 py-3 text-sm text-right">$ 1,200.00</td>
                  <td class="px-3 py-3 text-sm text-right font-medium">$ 48,000.00</td>
                  <td class="px-3 py-3 text-sm text-center">
                    <button class="p-1 rounded hover:bg-button-hover text-on-surface cursor-pointer" title="Editar">
                      <span class="material-symbols-outlined">edit</span>
                    </button>
                    <button class="p-1 rounded hover:bg-button-hover text-error ml-2 cursor-pointer" title="Eliminar">
                      <span class="material-symbols-outlined">delete</span>
                    </button>
                  </td>
                </tr>
              </tbody>
              <tfoot>
                <tr>
                  <td colspan="5" class="px-3 py-2 text-sm font-semibold text-right">Total valuación</td>
                  <td class="px-3 py-2 text-sm font-semibold text-right">$ 66,000.00</td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>

        <div class="flex justify-end gap-2">
          <a href={`/projects/${projectId}/valuations`} class="px-3 py-2 rounded border border-outline-variant cursor-pointer">Cancelar</a>
          <button type="button" class="px-4 py-2 bg-primary text-on-primary rounded cursor-pointer">Crear valuación</button>
        </div>
      </form>
    </div>
  </main>

</MainLayout>

<!-- Modal: seleccionar partida -->
<div id="partida-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center px-4">
  <div class="absolute inset-0 bg-black/40" data-close-modal></div>
  <div class="bg-white dark:bg-surface rounded-lg shadow-lg w-full max-w-3xl relative">
    <header class="flex items-center justify-between p-4 border-b">
      <div>
        <h3 class="text-lg font-semibold">Seleccionar partida para valuar</h3>
        <p id="modal-valuation" class="text-xs text-on-surface-variant">Valuación: nueva</p>
      </div>
      <button data-close-modal class="px-3 py-1">✕</button>
    </header>
    <div class="p-4">
      <!-- Step 1: Selección -->
      <div id="modal-step-1" class="space-y-3">
        <div class="flex gap-2">
          <input id="partida-search" type="search" placeholder="Buscar nombre" class="flex-1 px-3 py-2 rounded border" />
          <div id="partida-count" class="text-sm text-on-surface-variant self-center">0 partidas</div>
        </div>

        <div class="overflow-y-auto max-h-64 border rounded">
          <table id="partida-table" class="w-full text-sm">
            <thead class="text-on-surface-variant text-xs">
              <tr>
                <th class="p-2 w-6">&nbsp;</th>
                <th class="p-2 text-left">Nombre de la partida</th>
                <th class="p-2 text-right">Unidad</th>
                <th class="p-2 text-right">Cantidad</th>
                <th class="p-2 text-right">Cantidad valuada</th>
                <th class="p-2 text-right">Por valuar</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
        <div id="empty-state" class="text-center text-on-surface-variant hidden">No hay partidas disponibles para esta valuación.</div>
      </div>

      <!-- Step 2: Ingresar cantidad a valuar -->
      <div id="modal-step-2" class="hidden space-y-3">
        <div>
          <div class="text-sm text-on-surface-variant">Partida seleccionada</div>
          <div id="selected-name" class="text-base font-medium mt-1">—</div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <div class="text-xs text-on-surface-variant">Unidad</div>
            <div id="selected-unit" class="mt-1">—</div>
          </div>
          <div>
            <div class="text-xs text-on-surface-variant">Cantidad total</div>
            <div id="selected-qty" class="mt-1">0.00</div>
          </div>
          <div>
            <div class="text-xs text-on-surface-variant">Cantidad ya valuada</div>
            <div id="selected-qty-valued" class="mt-1">0.00</div>
          </div>
          <div>
            <div class="text-xs text-on-surface-variant">Por valuar</div>
            <div id="selected-por-valuar" class="mt-1">0.00</div>
          </div>
        </div>

        <div>
          <label class="text-xs text-on-surface-variant">Cantidad a valuar</label>
          <input id="cantidad-a-valuar" type="number" step="0.01" min="0" class="w-full mt-1 px-3 py-2 rounded border" />
          <div id="cantidad-error" class="text-xs text-rose-600 mt-1 hidden">La cantidad no puede ser mayor al disponible.</div>
        </div>
      </div>
    </div>
    <footer class="flex items-center justify-end gap-2 p-4 border-t">
      <button data-close-modal class="px-3 py-2 rounded border">Cancelar</button>
      <button id="back-partida" class="px-3 py-2 rounded border hidden">Atrás</button>
      <button id="next-partida" disabled class="px-3 py-2 bg-primary text-on-primary rounded">Siguiente</button>
      <button id="finish-partida" disabled class="px-3 py-2 bg-primary text-on-primary rounded hidden">Finalizar</button>
    </footer>
  </div>
</div>

<script type="module">
  const _meta = document.querySelector('meta[name="api-base"]');
  const _apiBase = _meta ? _meta.content : 'http://localhost/Budget/api';
  const projectNameEl = document.getElementById('project-name');

  async function loadProjectName() {
    if (!projectNameEl) return;
    const pid = projectNameEl.dataset.projectId;
    if (!pid) return;
    const base = _apiBase.replace(/\/$/, '');

    // Helper to normalize server responses into a single project object
    const extractFirst = (resData) => {
      if (!resData) return null;
      if (Array.isArray(resData)) return resData[0] || null;
      if (resData.data && Array.isArray(resData.data)) return resData.data[0] || null;
      if (typeof resData === 'object') return resData;
      return null;
    };

    try {
      // 1) Try ?id=
      let res = await fetch(`${base}/projects.php?id=${encodeURIComponent(pid)}`, { cache: 'no-store' });
      if (res.ok) {
        const data = await res.json();
        const first = extractFirst(data);
        if (first && (String(first.id) === String(pid) || String(first.project_id) === String(pid))) {
          projectNameEl.textContent = first.name || first.project_name || first.title || `Proyecto #${pid}`;
          return;
        }
      }
    } catch (e) { /* ignore */ }

    try {
      // 2) Try ?project_id=
      let res2 = await fetch(`${base}/projects.php?project_id=${encodeURIComponent(pid)}`, { cache: 'no-store' });
      if (res2.ok) {
        const data2 = await res2.json();
        const first2 = extractFirst(data2);
        if (first2 && (String(first2.id) === String(pid) || String(first2.project_id) === String(pid))) {
          projectNameEl.textContent = first2.name || first2.project_name || first2.title || `Proyecto #${pid}`;
          return;
        }
      }
    } catch (e) { /* ignore */ }

    try {
      // 3) Fallback: fetch all and search locally
      let res3 = await fetch(`${base}/projects.php`, { cache: 'no-store' });
      if (res3.ok) {
        const all = await res3.json();
        const arr = Array.isArray(all) ? all : (all.data && Array.isArray(all.data)) ? all.data : [];
        const found = arr.find(p => String(p.id) === String(pid) || String(p.project_id) === String(pid) || String(p.projectId) === String(pid));
        if (found) {
          projectNameEl.textContent = found.name || found.project_name || found.title || `Proyecto #${pid}`;
          return;
        }
      }
    } catch (e) { /* ignore */ }

    // Last resort: show the id
    projectNameEl.textContent = `Proyecto #${pid}`;
  }

  window.addEventListener('pageshow', () => loadProjectName());
  loadProjectName();

  // --- Modal logic: cargar partidas y filtrar las ya valuadas en la valuación en curso ---
  const openBtn = document.getElementById('open-add-item');
  const modal = document.getElementById('partida-modal');
  const modalOverlayButtons = modal ? modal.querySelectorAll('[data-close-modal]') : [];
  const partidaTableBody = document.querySelector('#partida-table tbody');
  const partidaSearch = document.getElementById('partida-search');
  const partidaCount = document.getElementById('partida-count');
  const emptyState = document.getElementById('empty-state');

  const nextBtn = document.getElementById('next-partida');
  const backBtn = document.getElementById('back-partida');
  const finishBtn = document.getElementById('finish-partida');
  const cantidadInput = document.getElementById('cantidad-a-valuar');
  const cantidadError = document.getElementById('cantidad-error');
  const selectedNameEl = document.getElementById('selected-name');
  const selectedUnitEl = document.getElementById('selected-unit');
  const selectedQtyEl = document.getElementById('selected-qty');
  const selectedQtyValuedEl = document.getElementById('selected-qty-valued');
  const selectedPorValuarEl = document.getElementById('selected-por-valuar');

  let projectItems = [];
  let alreadyValuedIds = [];
  let excludedUiIds = [];
  let valuedQuantities = {}; // map project_item_id -> cantidad valuada
  let selectedPartidaId = null;

  function resetModalSteps() {
    // show step 1
    const step1 = document.getElementById('modal-step-1');
    const step2 = document.getElementById('modal-step-2');
    if (step1) step1.classList.remove('hidden');
    if (step2) step2.classList.add('hidden');
    if (backBtn) backBtn.classList.add('hidden');
    if (finishBtn) { finishBtn.classList.add('hidden'); finishBtn.disabled = true; }
    if (nextBtn) { nextBtn.classList.remove('hidden'); nextBtn.disabled = true; }
    if (cantidadInput) { cantidadInput.value = ''; }
    if (cantidadError) cantidadError.classList.add('hidden');
  }

  function openModal() {
    if (!modal) return;
    modal.classList.remove('hidden');
    resetModalSteps();
    modal.querySelector('input, button')?.focus();
    // cargar datos
    const pid = openBtn?.dataset.projectId || projectNameEl?.dataset.projectId || '';
    loadProjectItems(pid).then(() => {
      excludedUiIds = collectIncludedIdsFromPage();
      renderList('');
    });
  }

  function collectIncludedIdsFromPage() {
    const ids = [];
    // try to find the main table of partidas incluidas (has class min-w-200)
    const mainTbody = document.querySelector('table.min-w-200 tbody');
    if (!mainTbody) return ids;
    mainTbody.querySelectorAll('tr').forEach(tr => {
      const dataId = tr.dataset.projectItemId || tr.getAttribute('data-project-item-id') || tr.getAttribute('data-id');
      if (dataId) {
        ids.push(String(dataId));
      } else {
        // fallback: try to match by name text to known projectItems
        const nameCell = tr.querySelector('td');
        if (nameCell) {
          const txt = nameCell.textContent.replace(/\s+/g, ' ').trim();
          const found = projectItems.find(p => (p.nombre || '').trim() === txt);
          if (found) ids.push(String(found.id));
        }
      }
    });
    return ids;
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.add('hidden');
    selectedPartidaId = null;
    resetModalSteps();
  }

  async function loadProjectItems(projectId) {
    projectItems = [];
    alreadyValuedIds = [];
    valuedQuantities = {};
    try {
      const base = _apiBase.replace(/\/$/, '');
      // 1) obtener todas las partidas del proyecto
      const res = await fetch(`${base}/project_items.php?project_id=${encodeURIComponent(projectId)}`);
      if (res.ok) {
        const data = await res.json();
        const list = Array.isArray(data) ? data : (data.data || []);
        projectItems = list.map(it => ({ id: String(it.id || it.item_id || it.itemId), nombre: it.item_name || it.name || '', unidad: it.unit || '', qty: Number(it.qty || it.Qty || 0) }));
      }

      // 2) si hay una valuación existente (id en querystring ?valuation_id=), intentar obtener las partidas ya valuadas y sus cantidades
      const urlParams = new URLSearchParams(window.location.search);
      const valuationId = urlParams.get('valuation_id');
      if (valuationId) {
        try {
          const r2 = await fetch(`${base}/valuation_items.php?valuation_id=${encodeURIComponent(valuationId)}`);
          if (r2.ok) {
            const d2 = await r2.json();
            const list2 = Array.isArray(d2) ? d2 : (d2.data || []);
            alreadyValuedIds = list2.map(x => String(x.project_item_id || x.item_id || x.id));
            for (const x of list2) {
              const key = String(x.project_item_id || x.item_id || x.id);
              const q = Number(x.qty || x.cantidad || x.qty_valued || x.cantidad_valuada || 0);
              if (!valuedQuantities[key]) valuedQuantities[key] = 0;
              valuedQuantities[key] += q;
            }
          }
        } catch (e) { /* ignore */ }
      }

    } catch (e) {
      console.warn('Error cargando partidas', e);
    }
  }

  function renderList(filter) {
    if (!partidaTableBody) return;
    const q = (filter || '').toLowerCase().trim();
    const filtered = projectItems.filter(p => !alreadyValuedIds.includes(String(p.id)) && !excludedUiIds.includes(String(p.id)) && (q === '' || (`${p.nombre}`).toLowerCase().includes(q)));
    partidaTableBody.innerHTML = '';
    if (filtered.length === 0) {
      emptyState.classList.remove('hidden');
      partidaCount.textContent = '0 partidas';
      return;
    }
    emptyState.classList.add('hidden');
    partidaCount.textContent = `${filtered.length} partida${filtered.length>1?'s':''}`;
    for (const p of filtered) {
      const qtyValued = Number(valuedQuantities[String(p.id)] || 0);
      const porValuar = Number((p.qty || 0) - qtyValued);
      const tr = document.createElement('tr');
      tr.className = 'border-t cursor-pointer hover:bg-surface-dim';
      tr.dataset.id = p.id;
      tr.setAttribute('tabindex', '0');
      tr.innerHTML = `
        <td class="p-2"><input type="radio" name="partida-select" value="${p.id}" /></td>
        <td class="p-2">${p.nombre}</td>
        <td class="p-2 text-right">${p.unidad || ''}</td>
        <td class="p-2 text-right">${Number(p.qty || 0).toFixed(2)}</td>
        <td class="p-2 text-right">${qtyValued.toFixed(2)}</td>
        <td class="p-2 text-right">${porValuar.toFixed(2)}</td>
      `;
      // clicking row selects the radio
      tr.addEventListener('click', (ev) => {
        // avoid double-toggling if clicking the radio itself
        const target = ev.target;
        const radio = tr.querySelector('input[name="partida-select"]');
        if (target && target.tagName === 'INPUT') {
          // handled by radio change
        } else if (radio) {
          radio.checked = true;
          radio.focus();
        }
        // highlight selection
        partidaTableBody.querySelectorAll('tr').forEach(r => r.classList.remove('bg-surface-container-high'));
        tr.classList.add('bg-surface-container-high');
        selectedPartidaId = p.id;
        if (nextBtn) nextBtn.disabled = false;
      });
      partidaTableBody.appendChild(tr);
      // wire radio change to set selection
      const radioEl = tr.querySelector('input[name="partida-select"]');
      if (radioEl) {
        radioEl.addEventListener('change', (e) => {
          if (e.target.checked) {
            partidaTableBody.querySelectorAll('tr').forEach(r => r.classList.remove('bg-surface-container-high'));
            tr.classList.add('bg-surface-container-high');
            selectedPartidaId = e.target.value;
            if (nextBtn) nextBtn.disabled = false;
            // ensure keyboard users see focus on the radio
            e.target.focus();
          }
        });
        // support keyboard selection on the row
        tr.addEventListener('keydown', (ke) => {
          const k = ke.key;
          if (k === 'Enter' || k === ' ') {
            ke.preventDefault();
            radioEl.checked = true;
            radioEl.focus();
            radioEl.dispatchEvent(new Event('change', { bubbles: true }));
          }
          if (k === 'ArrowDown') {
            ke.preventDefault();
            const next = tr.nextElementSibling;
            if (next) next.focus();
          }
          if (k === 'ArrowUp') {
            ke.preventDefault();
            const prev = tr.previousElementSibling;
            if (prev) prev.focus();
          }
        });
      }
    }
  }

  if (openBtn) openBtn.addEventListener('click', openModal);
  modalOverlayButtons.forEach(b => b.addEventListener('click', closeModal));
  partidaSearch?.addEventListener('input', (e) => renderList(e.target.value));

  // Next: abrir paso 2 con datos de la partida seleccionada
  nextBtn?.addEventListener('click', () => {
    if (!selectedPartidaId) return;
    const partida = projectItems.find(p => String(p.id) === String(selectedPartidaId));
    if (!partida) return;
    const qtyValued = Number(valuedQuantities[String(partida.id)] || 0);
    const porValuar = Number((partida.qty || 0) - qtyValued);

    // populate step 2
    if (selectedNameEl) selectedNameEl.textContent = partida.nombre;
    if (selectedUnitEl) selectedUnitEl.textContent = partida.unidad || '';
    if (selectedQtyEl) selectedQtyEl.textContent = (partida.qty || 0).toFixed(2);
    if (selectedQtyValuedEl) selectedQtyValuedEl.textContent = qtyValued.toFixed(2);
    if (selectedPorValuarEl) selectedPorValuarEl.textContent = porValuar.toFixed(2);

    // show step 2
    const step1 = document.getElementById('modal-step-1');
    const step2 = document.getElementById('modal-step-2');
    if (step1) step1.classList.add('hidden');
    if (step2) step2.classList.remove('hidden');
    if (backBtn) backBtn.classList.remove('hidden');
    if (finishBtn) { finishBtn.classList.remove('hidden'); finishBtn.disabled = true; }
    if (nextBtn) nextBtn.classList.add('hidden');

    if (cantidadInput) {
      cantidadInput.value = '';
      cantidadInput.setAttribute('max', String(porValuar));
      cantidadInput.focus();
    }
  });

  backBtn?.addEventListener('click', () => {
    const step1 = document.getElementById('modal-step-1');
    const step2 = document.getElementById('modal-step-2');
    if (step1) step1.classList.remove('hidden');
    if (step2) step2.classList.add('hidden');
    if (backBtn) backBtn.classList.add('hidden');
    if (finishBtn) { finishBtn.classList.add('hidden'); finishBtn.disabled = true; }
    if (nextBtn) { nextBtn.classList.remove('hidden'); nextBtn.disabled = false; }
  });

  cantidadInput?.addEventListener('input', (e) => {
    const v = Number(e.target.value || 0);
    const partida = projectItems.find(p => String(p.id) === String(selectedPartidaId));
    const qtyValued = Number(valuedQuantities[String(selectedPartidaId)] || 0);
    const porValuar = partida ? Number((partida.qty || 0) - qtyValued) : 0;
    if (v > 0 && v <= porValuar) {
      if (cantidadError) cantidadError.classList.add('hidden');
      if (finishBtn) finishBtn.disabled = false;
    } else {
      if (cantidadError) cantidadError.classList.remove('hidden');
      if (finishBtn) finishBtn.disabled = true;
    }
  });

  finishBtn?.addEventListener('click', () => {
    const v = Number(cantidadInput?.value || 0);
    if (!selectedPartidaId || !v || v <= 0) return;
    const partida = projectItems.find(p => String(p.id) === String(selectedPartidaId));
    if (!partida) return closeModal();
    const qtyValuedPrev = Number(valuedQuantities[String(partida.id)] || 0);
    const porValuarPrev = Number((partida.qty || 0) - qtyValuedPrev);
    const porValuarAfter = Number((partida.qty || 0) - (qtyValuedPrev + v));

    // insertar fila en la tabla principal con la cantidad ingresada
    const tbody = document.querySelector('table.min-w-200 tbody');
    if (tbody) {
      const tr = document.createElement('tr');
      tr.className = 'border-t border-outline-variant/10 bg-surface-container-high';
      tr.setAttribute('data-project-item-id', String(partida.id));
      tr.innerHTML = `
        <td class="px-3 py-3 text-sm">${partida.nombre}</td>
        <td class="px-3 py-3 text-sm text-center">${partida.unidad || ''}</td>
        <td class="px-3 py-3 text-sm text-right">${v.toFixed(2)}</td>
        <td class="px-3 py-3 text-sm text-right">${(qtyValuedPrev + v).toFixed(2)}</td>
        <td class="px-3 py-3 text-sm text-right font-medium">${porValuarAfter.toFixed(2)}</td>
        <td class="px-3 py-3 text-sm text-center">
          <button class="p-1 rounded hover:bg-button-hover text-on-surface cursor-pointer" title="Editar">
            <span class="material-symbols-outlined">edit</span>
          </button>
          <button class="p-1 rounded hover:bg-button-hover text-error ml-2 cursor-pointer" title="Eliminar">
            <span class="material-symbols-outlined">delete</span>
          </button>
        </td>
      `;
      tbody.appendChild(tr);
      // update excluded UI ids so modal excludes it if reopened
      excludedUiIds.push(String(partida.id));
    }

    // actualizar estado local (marcar cantidad valuada)
    valuedQuantities[String(partida.id)] = qtyValuedPrev + v;
    // opcional: si ya no queda por valuar, excluirlo de próximas búsquedas
    if (porValuarAfter <= 0) {
      alreadyValuedIds.push(String(partida.id));
    }

    closeModal();
  });
</script>
