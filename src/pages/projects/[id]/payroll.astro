---
import MainLayout from '../../../layouts/MainLayout.astro';
import NavBarDesktop from '../../../components/NavBarDesktop.astro';
import NavBarMobil from '../../../components/NavBarMobil.astro';

export const prerender = false;

const projectId = (Astro.params as Record<string, string> | undefined)?.id ?? null;
export async function getStaticPaths() { return []; }
---

<MainLayout>
  <NavBarDesktop />

  <main class="pt-24 px-6 container mx-auto">
    <a href={`/projects/${projectId}`} class="text-sm text-primary cursor-pointer">← Volver al proyecto</a>

    <section class="mt-4 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h1 id="project-name" data-project-id={projectId} class="text-2xl font-bold text-on-surface">Proyecto #{projectId}</h1>
        <h2 class="mt-1 text-lg font-semibold text-on-surface">Nómina de cuadrillas</h2>
        <p class="text-sm text-on-surface-variant">Marca asistencia semanal (lunes a domingo): Día, Noche y Extra (media jornada adicional).</p>
      </div>

      <div class="flex items-center gap-2">
        <button id="prev-week" type="button" class="rounded-lg border border-outline-variant px-3 py-2 text-on-surface cursor-pointer">◀</button>
        <div class="flex flex-col gap-1">
          <label for="week-picker" class="text-[11px] uppercase tracking-wide text-on-surface-variant">Semana (elige fecha)</label>
          <input id="week-picker" type="date" class="rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
        </div>
        <button id="next-week" type="button" class="rounded-lg border border-outline-variant px-3 py-2 text-on-surface cursor-pointer">▶</button>
      </div>
    </section>

    <section class="mt-5 grid grid-cols-1 md:grid-cols-4 gap-3">
      <article class="rounded-xl border border-outline-variant/10 bg-surface-container-low p-4">
        <div class="text-[10px] uppercase tracking-wide text-on-surface-variant">Empleados activos</div>
        <div id="kpi-employees" class="mt-2 text-2xl font-extrabold text-on-surface">0</div>
      </article>
      <article class="rounded-xl border border-outline-variant/10 bg-surface-container-low p-4">
        <div class="text-[10px] uppercase tracking-wide text-on-surface-variant">Turnos día</div>
        <div id="kpi-day" class="mt-2 text-2xl font-extrabold text-on-surface">0</div>
      </article>
      <article class="rounded-xl border border-outline-variant/10 bg-surface-container-low p-4">
        <div class="text-[10px] uppercase tracking-wide text-on-surface-variant">Turnos noche</div>
        <div id="kpi-night" class="mt-2 text-2xl font-extrabold text-on-surface">0</div>
      </article>
      <article class="rounded-xl border border-outline-variant/10 bg-linear-to-br from-primary to-primary-container text-on-primary p-4">
        <div class="text-[10px] uppercase tracking-wide opacity-90">Total período</div>
        <div id="kpi-total" class="mt-2 text-2xl font-extrabold">$0.00</div>
      </article>
    </section>

    <section class="mt-6 rounded-2xl border border-outline-variant/10 bg-surface-container-low p-4">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h3 class="text-lg font-semibold text-on-surface">Administración de empleados</h3>
          <p class="text-sm text-on-surface-variant">Crea, edita o desactiva empleados desde acciones rápidas.</p>
        </div>
        <div>
          <button id="open-employee-modal" type="button" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-on-primary cursor-pointer">
            <span class="material-symbols-outlined text-[18px] leading-none">person_add</span>
            Agregar empleado
          </button>
          <button id="open-import-employee-modal" type="button" class="inline-flex items-center gap-2 rounded-lg border border-outline-variant px-4 py-2 text-on-surface cursor-pointer">
            <span class="material-symbols-outlined text-[18px] leading-none">upload_file</span>
            Importar empleado
          </button>
        </div>
      </div>
    </section>

    <section class="mt-6 rounded-2xl border border-outline-variant/10 bg-surface-container-low p-4 pb-20">
      <div class="overflow-x-auto">
        <table class="min-w-275 w-full border-collapse" id="payroll-table">
          <thead id="payroll-head"></thead>
          <tbody id="payroll-body">
            <tr><td class="py-6 text-on-surface-variant">Cargando nómina...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <div id="employee-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
      <div class="fixed inset-0 bg-black/40" data-dismiss="employee-modal"></div>
      <div class="z-10 w-full max-w-2xl mx-4 rounded-2xl border border-outline-variant/20 bg-surface p-5 shadow-xl">
        <div class="flex items-center justify-between gap-3">
          <h3 id="employee-modal-title" class="text-lg font-semibold text-on-surface">Agregar empleado</h3>
          <button id="employee-modal-close" type="button" class="rounded-lg border border-outline-variant px-2 py-1 text-sm text-on-surface cursor-pointer">Cerrar</button>
        </div>
        <form id="employee-modal-form" class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
          <input id="employee-modal-id" type="hidden" />
          <div class="md:col-span-2">
            <label for="employee-modal-name" class="text-xs uppercase tracking-wide text-on-surface-variant">Nombre completo</label>
            <input id="employee-modal-name" required placeholder="Nombre completo" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div class="md:col-span-2">
            <label for="employee-modal-id-number" class="text-xs uppercase tracking-wide text-on-surface-variant">Cédula</label>
            <input id="employee-modal-id-number" placeholder="Ej: V-12345678" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div class="md:col-span-2 mt-1">
            <h4 class="text-xs font-semibold uppercase tracking-wide text-on-surface-variant">Datos del Pago Móvil</h4>
          </div>
          <div>
            <label for="employee-modal-mobile-bank" class="text-xs uppercase tracking-wide text-on-surface-variant">Banco</label>
            <input id="employee-modal-mobile-bank" placeholder="Banco" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div>
            <label for="employee-modal-mobile-id" class="text-xs uppercase tracking-wide text-on-surface-variant">Cédula</label>
            <input id="employee-modal-mobile-id" placeholder="Cédula" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div class="md:col-span-2">
            <label for="employee-modal-mobile-phone" class="text-xs uppercase tracking-wide text-on-surface-variant">Teléfono</label>
            <input id="employee-modal-mobile-phone" placeholder="Ej: 0412-1234567" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div class="md:col-span-2 mt-1">
            <h4 class="text-xs font-semibold uppercase tracking-wide text-on-surface-variant">Datos de la Cuenta Bancaria</h4>
          </div>
          <div class="md:col-span-2">
            <label for="employee-modal-bank-account-number" class="text-xs uppercase tracking-wide text-on-surface-variant">Nro de Cuenta</label>
            <input id="employee-modal-bank-account-number" placeholder="Número de cuenta" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div>
            <label for="employee-modal-bank-holder-name" class="text-xs uppercase tracking-wide text-on-surface-variant">Nombre del Titular</label>
            <input id="employee-modal-bank-holder-name" placeholder="Nombre del titular" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div>
            <label for="employee-modal-bank-holder-id" class="text-xs uppercase tracking-wide text-on-surface-variant">Cédula del Titular</label>
            <input id="employee-modal-bank-holder-id" placeholder="Cédula del titular" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div>
            <label for="employee-modal-crew" class="text-xs uppercase tracking-wide text-on-surface-variant">Cuadrilla</label>
            <select id="employee-modal-crew" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface">
              <option value="day">Cuadrilla día</option>
              <option value="night">Cuadrilla noche</option>
            </select>
          </div>
          <div>
            <label for="employee-modal-day-rate" class="text-xs uppercase tracking-wide text-on-surface-variant">Tarifa día</label>
            <input id="employee-modal-day-rate" type="number" min="0" step="0.01" required class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div>
            <label for="employee-modal-night-rate" class="text-xs uppercase tracking-wide text-on-surface-variant">Tarifa noche</label>
            <input id="employee-modal-night-rate" type="number" min="0" step="0.01" required class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div class="md:col-span-2 flex justify-end gap-2 mt-1">
            <button id="employee-modal-cancel" type="button" class="rounded-lg border border-outline-variant px-4 py-2 text-on-surface cursor-pointer">Cancelar</button>
            <button id="employee-modal-submit" type="submit" class="rounded-lg bg-primary px-4 py-2 text-on-primary cursor-pointer">Guardar</button>
          </div>
          <p id="employee-modal-error" class="hidden md:col-span-2 text-sm text-error"></p>
        </form>
      </div>
    </div>

    <div id="employee-delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
      <div class="fixed inset-0 bg-black/40" data-dismiss="employee-delete-modal"></div>
      <div class="z-10 w-full max-w-sm mx-4 rounded-2xl border border-outline-variant/20 bg-surface p-5 shadow-xl">
        <h3 class="text-lg font-semibold text-on-surface">Confirmar eliminación</h3>
        <p class="mt-2 text-sm text-on-surface-variant">
          ¿Deseas eliminar al empleado <span id="employee-delete-name" class="font-semibold text-on-surface">—</span>?
        </p>
        <div class="mt-4 flex justify-end gap-2">
          <button id="employee-delete-cancel" type="button" class="rounded-lg border border-outline-variant px-4 py-2 text-on-surface cursor-pointer">Cancelar</button>
          <button id="employee-delete-confirm" type="button" class="rounded-lg bg-error px-4 py-2 text-on-primary cursor-pointer">Eliminar</button>
        </div>
      </div>
    </div>

    <div id="import-employee-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
      <div class="fixed inset-0 bg-black/40" data-dismiss="import-employee-modal"></div>
      <div class="z-10 w-full max-w-3xl mx-4 rounded-2xl border border-outline-variant/20 bg-surface p-5 shadow-xl">
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-lg font-semibold text-on-surface">Importar empleados</h3>
          <button id="import-employee-modal-close" type="button" class="rounded-lg border border-outline-variant px-2 py-1 text-sm text-on-surface cursor-pointer">Cerrar</button>
        </div>

        <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="md:col-span-2">
            <label for="import-employees-search" class="text-xs uppercase tracking-wide text-on-surface-variant">Buscar empleado global</label>
            <input id="import-employees-search" placeholder="Buscar por nombre o cédula" class="mt-1 w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-on-surface" />
          </div>
          <div class="md:col-span-2">
            <p class="text-xs text-on-surface-variant">Selecciona uno o varios empleados de la tabla global para agregarlos al proyecto actual.</p>
          </div>
          <div class="md:col-span-2">
            <div id="import-employees-list" class="max-h-72 overflow-auto rounded-lg border border-outline-variant/20 p-2">
              <p class="text-sm text-on-surface-variant px-2 py-1">Cargando empleados globales...</p>
            </div>
          </div>
          <p id="import-employee-error" class="hidden md:col-span-2 text-sm text-error"></p>
          <div class="md:col-span-2 flex justify-end gap-2 mt-1">
            <button id="import-employee-cancel" type="button" class="rounded-lg border border-outline-variant px-4 py-2 text-on-surface cursor-pointer">Cancelar</button>
            <button id="import-employee-submit" type="button" class="rounded-lg bg-primary px-4 py-2 text-on-primary cursor-pointer">Importar seleccionados</button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <NavBarMobil />
</MainLayout>

<script type="module">
  const projectNameEl = document.getElementById('project-name');
  const projectId = Number(projectNameEl?.dataset.projectId || 0);
  const weekPicker = document.getElementById('week-picker');
  const prevWeekBtn = document.getElementById('prev-week');
  const nextWeekBtn = document.getElementById('next-week');

  const openEmployeeModalBtn = document.getElementById('open-employee-modal');
  const openImportEmployeeModalBtn = document.getElementById('open-import-employee-modal');
  const employeeModal = document.getElementById('employee-modal');
  const employeeModalTitle = document.getElementById('employee-modal-title');
  const employeeModalForm = document.getElementById('employee-modal-form');
  const employeeModalIdInput = document.getElementById('employee-modal-id');
  const employeeModalNameInput = document.getElementById('employee-modal-name');
  const employeeModalIdNumberInput = document.getElementById('employee-modal-id-number');
  const employeeModalMobileBankInput = document.getElementById('employee-modal-mobile-bank');
  const employeeModalMobileIdInput = document.getElementById('employee-modal-mobile-id');
  const employeeModalMobilePhoneInput = document.getElementById('employee-modal-mobile-phone');
  const employeeModalBankAccountNumberInput = document.getElementById('employee-modal-bank-account-number');
  const employeeModalBankHolderNameInput = document.getElementById('employee-modal-bank-holder-name');
  const employeeModalBankHolderIdInput = document.getElementById('employee-modal-bank-holder-id');
  const employeeModalCrewInput = document.getElementById('employee-modal-crew');
  const employeeModalDayRateInput = document.getElementById('employee-modal-day-rate');
  const employeeModalNightRateInput = document.getElementById('employee-modal-night-rate');
  const employeeModalSubmitBtn = document.getElementById('employee-modal-submit');
  const employeeModalError = document.getElementById('employee-modal-error');
  const employeeModalCloseBtn = document.getElementById('employee-modal-close');
  const employeeModalCancelBtn = document.getElementById('employee-modal-cancel');

  const employeeDeleteModal = document.getElementById('employee-delete-modal');
  const employeeDeleteName = document.getElementById('employee-delete-name');
  const employeeDeleteCancelBtn = document.getElementById('employee-delete-cancel');
  const employeeDeleteConfirmBtn = document.getElementById('employee-delete-confirm');

  const importEmployeeModal = document.getElementById('import-employee-modal');
  const importEmployeeModalCloseBtn = document.getElementById('import-employee-modal-close');
  const importEmployeeCancelBtn = document.getElementById('import-employee-cancel');
  const importEmployeeSubmitBtn = document.getElementById('import-employee-submit');
  const importEmployeesSearchInput = document.getElementById('import-employees-search');
  const importEmployeesList = document.getElementById('import-employees-list');
  const importEmployeeError = document.getElementById('import-employee-error');

  const payrollHead = document.getElementById('payroll-head');
  const payrollBody = document.getElementById('payroll-body');

  const kpiEmployees = document.getElementById('kpi-employees');
  const kpiDay = document.getElementById('kpi-day');
  const kpiNight = document.getElementById('kpi-night');
  const kpiTotal = document.getElementById('kpi-total');

  const _meta = document.querySelector('meta[name="api-base"]');
  const apiBase = (_meta ? _meta.content : 'http://localhost/Budget/api').replace(/\/$/, '');

  let currentWeekDate = new Date();
  let employees = [];
  let attendanceMap = new Map();
  let employeeDeleteTargetId = 0;
  let sourceEmployees = [];
  let importSearchTimer = null;

  function dateValue(date) {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
  }

  function isoDate(date) {
    return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
  }

  function weekRangeFromDate(value) {
    const parsed = new Date(`${String(value || '').slice(0, 10)}T00:00:00`);
    const base = Number.isNaN(parsed.getTime()) ? new Date() : parsed;
    const day = base.getDay();
    const diffToMonday = day === 0 ? -6 : 1 - day;
    const startDate = new Date(base);
    startDate.setDate(base.getDate() + diffToMonday);
    const endDate = new Date(startDate);
    endDate.setDate(startDate.getDate() + 6);

    const dates = Array.from({ length: 7 }, (_, idx) => {
      const d = new Date(startDate);
      d.setDate(startDate.getDate() + idx);
      return isoDate(d);
    });

    return {
      start: isoDate(startDate),
      end: isoDate(endDate),
      startDate,
      endDate,
      dates,
    };
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function money(value) {
    const n = Number(value || 0);
    return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'USD', minimumFractionDigits: 2 }).format(n);
  }

  function qty(value) {
    const n = Number(value || 0);
    return Number.isInteger(n) ? String(n) : n.toFixed(1);
  }

  function keyFor(employeeId, workDate) {
    return `${employeeId}|${workDate}`;
  }

  function showEmployeeModalError(message = '') {
    if (!employeeModalError) return;
    employeeModalError.textContent = message;
    employeeModalError.classList.toggle('hidden', message === '');
  }

  function showImportEmployeeError(message = '') {
    if (!importEmployeeError) return;
    importEmployeeError.textContent = message;
    importEmployeeError.classList.toggle('hidden', message === '');
  }

  function findEmployeeById(employeeId) {
    return employees.find((employee) => String(employee.id) === String(employeeId)) || null;
  }

  function openEmployeeModal(employee = null) {
    if (!employeeModal) return;
    const isEdit = !!employee;
    showEmployeeModalError('');
    employeeModalTitle.textContent = isEdit ? 'Editar empleado' : 'Agregar empleado';
    employeeModalSubmitBtn.textContent = isEdit ? 'Guardar cambios' : 'Crear empleado';

    employeeModalIdInput.value = isEdit ? String(employee.id) : '';
    employeeModalNameInput.value = isEdit ? String(employee.full_name || '') : '';
    employeeModalIdNumberInput.value = isEdit ? String(employee.id_number || '') : '';
    employeeModalMobileBankInput.value = isEdit ? String(employee.mobile_bank || '') : '';
    employeeModalMobileIdInput.value = isEdit ? String(employee.mobile_id_number || '') : '';
    employeeModalMobilePhoneInput.value = isEdit ? String(employee.mobile_phone || '') : '';
    employeeModalBankAccountNumberInput.value = isEdit ? String(employee.bank_account_number || '') : '';
    employeeModalBankHolderNameInput.value = isEdit ? String(employee.bank_account_holder_name || '') : '';
    employeeModalBankHolderIdInput.value = isEdit ? String(employee.bank_account_holder_id || '') : '';
    employeeModalCrewInput.value = isEdit ? String(employee.crew || 'day') : 'day';
    employeeModalDayRateInput.value = Number(isEdit ? employee.day_rate : 0).toFixed(2);
    employeeModalNightRateInput.value = Number(isEdit ? employee.night_rate : 0).toFixed(2);

    employeeModal.classList.remove('hidden');
    employeeModal.classList.add('flex');
    employeeModalNameInput.focus();
  }

  function closeEmployeeModal() {
    if (!employeeModal) return;
    employeeModal.classList.add('hidden');
    employeeModal.classList.remove('flex');
  }

  function openEmployeeDeleteModal(employee) {
    if (!employeeDeleteModal || !employee) return;
    employeeDeleteTargetId = Number(employee.id || 0);
    if (employeeDeleteName) {
      employeeDeleteName.textContent = String(employee.full_name || '—');
    }
    employeeDeleteModal.classList.remove('hidden');
    employeeDeleteModal.classList.add('flex');
  }

  function closeEmployeeDeleteModal() {
    if (!employeeDeleteModal) return;
    employeeDeleteModal.classList.add('hidden');
    employeeDeleteModal.classList.remove('flex');
    employeeDeleteTargetId = 0;
  }

  function closeImportEmployeeModal() {
    if (!importEmployeeModal) return;
    importEmployeeModal.classList.add('hidden');
    importEmployeeModal.classList.remove('flex');
  }

  function renderSourceEmployees() {
    if (!importEmployeesList) return;

    if (!sourceEmployees.length) {
      importEmployeesList.innerHTML = '<p class="text-sm text-on-surface-variant px-2 py-1">No hay empleados globales para mostrar.</p>';
      return;
    }

    const rows = sourceEmployees.map((employee) => {
      const isNightCrew = String(employee?.crew || '').toLowerCase() === 'night';
      const crewIcon = isNightCrew ? 'dark_mode' : 'light_mode';
      const crewLabel = isNightCrew ? 'Noche' : 'Día';
      const alreadyLinked = Number(employee?.linked_to_project || 0) === 1;
      return `
        <label class="flex items-start gap-3 rounded-lg px-2 py-2 ${alreadyLinked ? 'opacity-60 cursor-not-allowed' : 'hover:bg-surface-container-high cursor-pointer'}">
          <input type="checkbox" data-import-employee-id="${employee.id}" class="mt-1" ${alreadyLinked ? 'disabled' : ''} />
          <div class="min-w-0">
            <div class="text-sm font-medium text-on-surface">${escapeHtml(employee.full_name || '')}</div>
            <div class="text-xs text-on-surface-variant flex items-center gap-2 flex-wrap">
              <span class="inline-flex items-center gap-1">
                <span class="material-symbols-outlined text-sm leading-none">${crewIcon}</span>
                ${crewLabel}
              </span>
              <span>Día: ${money(employee.day_rate)}</span>
              <span>Noche: ${money(employee.night_rate)}</span>
              <span>Cédula: ${escapeHtml(employee.id_number || '—')}</span>
              <span>${alreadyLinked ? 'Ya en este proyecto' : 'Disponible'}</span>
            </div>
          </div>
        </label>
      `;
    }).join('');

    importEmployeesList.innerHTML = rows;
  }

  async function loadGlobalEmployeesForImport(searchTerm = '') {
    if (!importEmployeesList) return;
    sourceEmployees = [];
    importEmployeesList.innerHTML = '<p class="text-sm text-on-surface-variant px-2 py-1">Cargando empleados globales...</p>';

    const params = new URLSearchParams({
      scope: 'global',
      project_id: String(projectId),
      q: String(searchTerm || ''),
    });
    const res = await fetch(`${apiBase}/payroll_employees.php?${params.toString()}`, { cache: 'no-store' });
    if (!res.ok) {
      throw new Error('No se pudo cargar la tabla global de empleados');
    }

    const data = await res.json();
    sourceEmployees = Array.isArray(data?.data) ? data.data : [];
    renderSourceEmployees();
  }

  async function openImportEmployeeModal() {
    if (!importEmployeeModal) return;
    showImportEmployeeError('');

    if (importEmployeesSearchInput) {
      importEmployeesSearchInput.value = '';
    }
    sourceEmployees = [];
    if (importEmployeesList) {
      importEmployeesList.innerHTML = '<p class="text-sm text-on-surface-variant px-2 py-1">Cargando empleados globales...</p>';
    }

    try {
      await loadGlobalEmployeesForImport('');
    } catch (error) {
      showImportEmployeeError(error instanceof Error ? error.message : 'No se pudo cargar la tabla global de empleados');
    }

    importEmployeeModal.classList.remove('hidden');
    importEmployeeModal.classList.add('flex');
  }

  async function importSelectedEmployees() {
    showImportEmployeeError('');

    const selectedIds = Array.from(importEmployeesList?.querySelectorAll('input[data-import-employee-id]:checked') || [])
      .map((input) => Number(input.getAttribute('data-import-employee-id') || 0))
      .filter((id) => id > 0);

    if (!selectedIds.length) {
      showImportEmployeeError('Selecciona al menos un empleado para importar.');
      return;
    }

    const selectedEmployees = sourceEmployees.filter((employee) => selectedIds.includes(Number(employee?.id || 0)));
    if (!selectedEmployees.length) {
      showImportEmployeeError('No se pudo resolver la selección de empleados.');
      return;
    }

    const originalText = importEmployeeSubmitBtn?.textContent || 'Importar seleccionados';
    if (importEmployeeSubmitBtn) {
      importEmployeeSubmitBtn.disabled = true;
      importEmployeeSubmitBtn.textContent = 'Importando...';
    }

    let importedCount = 0;
    let skippedCount = 0;
    let failedCount = 0;

    try {
      for (const employee of selectedEmployees) {
        if (Number(employee?.linked_to_project || 0) === 1) {
          skippedCount += 1;
          continue;
        }

        const payload = {
          project_id: projectId,
          employee_id: Number(employee?.id || 0),
        };

        const res = await fetch(`${apiBase}/payroll_employees.php`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          failedCount += 1;
          console.error('Importación fallida', data);
          continue;
        }

        importedCount += 1;
      }

      await loadEmployees();
      renderTable();
      await loadGlobalEmployeesForImport(String(importEmployeesSearchInput?.value || '').trim());

      if (failedCount > 0) {
        showImportEmployeeError(`Importados: ${importedCount}. Omitidos: ${skippedCount}. Fallidos: ${failedCount}.`);
        return;
      }

      closeImportEmployeeModal();
      if (skippedCount > 0) {
        alert(`Importados: ${importedCount}. Omitidos por duplicado: ${skippedCount}.`);
      }
    } catch (error) {
      showImportEmployeeError(error instanceof Error ? error.message : 'No se pudieron importar los empleados');
    } finally {
      if (importEmployeeSubmitBtn) {
        importEmployeeSubmitBtn.disabled = false;
        importEmployeeSubmitBtn.textContent = originalText;
      }
    }
  }

  async function loadProjectName() {
    if (!projectId || !projectNameEl) return;
    try {
      const res = await fetch(`${apiBase}/projects.php?id=${encodeURIComponent(String(projectId))}`, { cache: 'no-store' });
      if (!res.ok) return;
      const data = await res.json();
      const project = Array.isArray(data) ? data[0] : (data.data || data.project || data);
      if (project?.name) {
        projectNameEl.textContent = project.name;
      }
    } catch (error) {
      console.error(error);
    }
  }

  async function loadEmployees() {
    const res = await fetch(`${apiBase}/payroll_employees.php?project_id=${encodeURIComponent(String(projectId))}`, { cache: 'no-store' });
    if (!res.ok) throw new Error('No se pudieron cargar empleados');
    const data = await res.json();
    employees = (Array.isArray(data?.data) ? data.data : []).slice().sort((a, b) => {
      const crewOrder = { day: 0, night: 1 };
      const crewA = String(a?.crew || '').toLowerCase();
      const crewB = String(b?.crew || '').toLowerCase();
      const crewRankA = Object.prototype.hasOwnProperty.call(crewOrder, crewA) ? crewOrder[crewA] : 99;
      const crewRankB = Object.prototype.hasOwnProperty.call(crewOrder, crewB) ? crewOrder[crewB] : 99;

      if (crewRankA !== crewRankB) {
        return crewRankA - crewRankB;
      }

      const nameA = String(a?.full_name || '');
      const nameB = String(b?.full_name || '');
      return nameA.localeCompare(nameB, 'es', { sensitivity: 'base' });
    });
  }

  async function loadAttendance() {
    const range = weekRangeFromDate(weekPicker.value || dateValue(currentWeekDate));
    const url = `${apiBase}/payroll_attendance.php?project_id=${encodeURIComponent(String(projectId))}&start_date=${encodeURIComponent(range.start)}&end_date=${encodeURIComponent(range.end)}`;
    const res = await fetch(url, { cache: 'no-store' });
    if (!res.ok) throw new Error('No se pudo cargar asistencia');
    const data = await res.json();

    attendanceMap = new Map();
    const rows = Array.isArray(data?.data) ? data.data : [];
    rows.forEach((row) => {
      attendanceMap.set(keyFor(row.employee_id, row.work_date), {
        worked_day: Number(row.worked_day || 0),
        worked_night: Number(row.worked_night || 0),
        paid_amount: Number(row.paid_amount || row.total_amount || 0),
      });
    });
  }

  function getDateLabelFromISO(workDate) {
    const d = new Date(`${workDate}T00:00:00`);
    return new Intl.DateTimeFormat('es-MX', { weekday: 'short', day: 'numeric' }).format(d);
  }

  function rowStats(employee, dates) {
    let dayCount = 0;
    let nightCount = 0;
    let redouble = 0;
    let total = 0;

    dates.forEach((date) => {
      const item = attendanceMap.get(keyFor(employee.id, date));
      const workedDay = Number(item?.worked_day || 0);
      const workedNight = Number(item?.worked_night || 0);
      const paidAmount = Number(item?.paid_amount || 0);
      const calculatedAmount = (workedDay * Number(employee.day_rate || 0)) + (workedNight * Number(employee.night_rate || 0));

      dayCount += workedDay;
      nightCount += workedNight;
      if (workedDay >= 1 && workedNight >= 1) redouble += 1;
      total += paidAmount > 0 ? paidAmount : calculatedAmount;
    });

    return { dayCount, nightCount, redouble, total };
  }

  function renderTable() {
    const range = weekRangeFromDate(weekPicker.value || dateValue(currentWeekDate));
    const dates = range.dates;
    const totalColumns = 9 + dates.length;

    const dayHeaders = dates.map((workDate) => `<th class="border border-outline-variant/20 px-2 py-2 text-[11px] text-on-surface-variant">${escapeHtml(getDateLabelFromISO(workDate))}</th>`).join('');
    payrollHead.innerHTML = `
      <tr>
        <th class="border border-outline-variant/20 px-3 py-2 text-left text-xs text-on-surface-variant">Empleado</th>
        <th class="border border-outline-variant/20 px-3 py-2 text-left text-xs text-on-surface-variant">Cuadrilla</th>
        <th class="border border-outline-variant/20 px-3 py-2 text-right text-xs text-on-surface-variant">Tarifa día</th>
        <th class="border border-outline-variant/20 px-3 py-2 text-right text-xs text-on-surface-variant">Tarifa noche</th>
        ${dayHeaders}
        <th class="border border-outline-variant/20 px-3 py-2 text-right text-xs text-on-surface-variant">Días</th>
        <th class="border border-outline-variant/20 px-3 py-2 text-right text-xs text-on-surface-variant">Noches</th>
        <th class="border border-outline-variant/20 px-3 py-2 text-right text-xs text-on-surface-variant">Redobles</th>
        <th class="border border-outline-variant/20 px-3 py-2 text-right text-xs text-on-surface-variant">Total</th>
        <th class="border border-outline-variant/20 px-3 py-2 text-center text-xs text-on-surface-variant">Acción</th>
      </tr>
    `;

    if (!employees.length) {
      payrollBody.innerHTML = `<tr><td colspan="${totalColumns}" class="py-6 text-on-surface-variant">No hay empleados en este proyecto.</td></tr>`;
      kpiEmployees.textContent = '0';
      kpiDay.textContent = '0';
      kpiNight.textContent = '0';
      kpiTotal.textContent = money(0);
      return;
    }

    let globalDay = 0;
    let globalNight = 0;
    let globalTotal = 0;

    const rows = employees.map((employee) => {
      const dayCells = dates.map((workDate) => {
        const item = attendanceMap.get(keyFor(employee.id, workDate));
        const workedDay = Number(item?.worked_day || 0);
        const workedNight = Number(item?.worked_night || 0);
        const checkedDay = workedDay >= 1;
        const checkedNight = workedNight >= 1;
        const checkedExtra = workedDay === 1.5 || workedNight === 1.5;

        return `
          <td class="border border-outline-variant/20 px-1 py-1">
            <div class="flex items-center justify-center gap-1" data-cell="1" data-employee-id="${employee.id}" data-work-date="${workDate}">
              <label class="text-[10px] text-on-surface-variant inline-flex items-center gap-1">
                D
                <input type="checkbox" data-shift="day" class="cursor-pointer" ${checkedDay ? 'checked' : ''} />
              </label>
              <label class="text-[10px] text-on-surface-variant inline-flex items-center gap-1">
                N
                <input type="checkbox" data-shift="night" class="cursor-pointer" ${checkedNight ? 'checked' : ''} />
              </label>
              <label class="text-[10px] text-on-surface-variant inline-flex items-center gap-1">
                +
                <input type="checkbox" data-shift="extra" class="cursor-pointer" ${checkedExtra ? 'checked' : ''} />
              </label>
            </div>
          </td>
        `;
      }).join('');

      const stats = rowStats(employee, dates);
      globalDay += stats.dayCount;
      globalNight += stats.nightCount;
      globalTotal += stats.total;

      const isNightCrew = employee.crew === 'night';
      const crewLabel = isNightCrew ? 'Noche' : 'Día';
      const crewIcon = isNightCrew ? 'dark_mode' : 'light_mode';

      return `
        <tr>
          <td class="border border-outline-variant/20 px-3 py-2 text-sm font-medium">${escapeHtml(employee.full_name)}</td>
          <td class="border border-outline-variant/20 px-3 py-2 text-sm">
            <span class="inline-flex items-center gap-1">
              <span class="material-symbols-outlined text-base leading-none">${crewIcon}</span>
              ${crewLabel}
            </span>
          </td>
          <td class="border border-outline-variant/20 px-3 py-2 text-right text-sm">${money(employee.day_rate)}</td>
          <td class="border border-outline-variant/20 px-3 py-2 text-right text-sm">${money(employee.night_rate)}</td>
          ${dayCells}
          <td class="border border-outline-variant/20 px-3 py-2 text-right text-sm">${qty(stats.dayCount)}</td>
          <td class="border border-outline-variant/20 px-3 py-2 text-right text-sm">${qty(stats.nightCount)}</td>
          <td class="border border-outline-variant/20 px-3 py-2 text-right text-sm">${stats.redouble}</td>
          <td class="border border-outline-variant/20 px-3 py-2 text-right text-sm font-semibold">${money(stats.total)}</td>
          <td class="border border-outline-variant/20 px-3 py-2 text-center">
            <div class="inline-flex items-center gap-2">
              <button type="button" data-action="edit-employee" data-employee-id="${employee.id}" class="rounded p-1 text-primary transition hover:bg-button-hover cursor-pointer" title="Editar" aria-label="Editar empleado">
                <span class="material-symbols-outlined">edit</span>
              </button>
              <button type="button" data-action="delete-employee" data-employee-id="${employee.id}" class="rounded p-1 text-error transition hover:bg-button-hover cursor-pointer" title="Eliminar" aria-label="Eliminar empleado">
                <span class="material-symbols-outlined">delete</span>
              </button>
            </div>
          </td>
        </tr>
      `;
    }).join('');

    payrollBody.innerHTML = rows;

    kpiEmployees.textContent = String(employees.length);
    kpiDay.textContent = String(globalDay);
    kpiNight.textContent = String(globalNight);
    kpiTotal.textContent = money(globalTotal);
  }

  async function saveAttendance(employeeId, workDate, workedDay, workedNight) {
    const payload = {
      project_id: projectId,
      employee_id: employeeId,
      work_date: workDate,
      worked_day: workedDay,
      worked_night: workedNight,
    };

    const res = await fetch(`${apiBase}/payroll_attendance.php`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      throw new Error(data.error || data.message || 'No se pudo guardar la asistencia');
    }

    if (data?.data?.deleted) {
      attendanceMap.delete(keyFor(employeeId, workDate));
    } else {
      attendanceMap.set(keyFor(employeeId, workDate), {
        worked_day: Number(data?.data?.worked_day || 0),
        worked_night: Number(data?.data?.worked_night || 0),
        paid_amount: Number(data?.data?.paid_amount || data?.data?.total_amount || 0),
      });
    }
  }

  payrollBody.addEventListener('change', async (event) => {
    const input = event.target instanceof HTMLInputElement ? event.target : null;
    if (!input || !input.matches('input[type="checkbox"][data-shift]')) return;

    const cell = input.closest('[data-cell="1"]');
    if (!(cell instanceof HTMLElement)) return;

    const employeeId = Number(cell.dataset.employeeId || 0);
    const workDate = String(cell.dataset.workDate || '');
    const dayCheckbox = cell.querySelector('input[data-shift="day"]');
    const nightCheckbox = cell.querySelector('input[data-shift="night"]');
    const extraCheckbox = cell.querySelector('input[data-shift="extra"]');

    if (!(dayCheckbox instanceof HTMLInputElement) || !(nightCheckbox instanceof HTMLInputElement) || !(extraCheckbox instanceof HTMLInputElement)) return;

    const hasDay = dayCheckbox.checked;
    const hasNight = nightCheckbox.checked;
    const hasExtra = extraCheckbox.checked;

    if (hasExtra && ((hasDay && hasNight) || (!hasDay && !hasNight))) {
      alert('El extra solo aplica con un turno: Día o Noche.');
      const current = attendanceMap.get(keyFor(employeeId, workDate));
      const currentDay = Number(current?.worked_day || 0);
      const currentNight = Number(current?.worked_night || 0);
      dayCheckbox.checked = currentDay >= 1;
      nightCheckbox.checked = currentNight >= 1;
      extraCheckbox.checked = currentDay === 1.5 || currentNight === 1.5;
      return;
    }

    let workedDay = hasDay ? 1 : 0;
    let workedNight = hasNight ? 1 : 0;
    if (hasExtra && hasDay && !hasNight) workedDay = 1.5;
    if (hasExtra && hasNight && !hasDay) workedNight = 1.5;

    try {
      await saveAttendance(employeeId, workDate, workedDay, workedNight);
      renderTable();
    } catch (error) {
      alert(error instanceof Error ? error.message : 'No se pudo guardar la asistencia');
      const current = attendanceMap.get(keyFor(employeeId, workDate));
      const currentDay = Number(current?.worked_day || 0);
      const currentNight = Number(current?.worked_night || 0);
      dayCheckbox.checked = currentDay >= 1;
      nightCheckbox.checked = currentNight >= 1;
      extraCheckbox.checked = currentDay === 1.5 || currentNight === 1.5;
    }
  });

  payrollBody.addEventListener('click', async (event) => {
    const btn = event.target instanceof HTMLElement ? event.target.closest('button[data-action]') : null;
    if (!(btn instanceof HTMLButtonElement)) return;

    const employeeId = Number(btn.dataset.employeeId || 0);
    if (!employeeId) return;

    if (btn.dataset.action === 'edit-employee') {
      const employee = findEmployeeById(employeeId);
      if (employee) {
        openEmployeeModal(employee);
      }
      return;
    }

    if (btn.dataset.action === 'delete-employee') {
      const employee = findEmployeeById(employeeId);
      if (employee) {
        openEmployeeDeleteModal(employee);
      }
    }
  });

  employeeModalForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    showEmployeeModalError('');

    const employeeId = Number(employeeModalIdInput.value || 0);
    const isEdit = employeeId > 0;

    const payload = {
      project_id: projectId,
      full_name: String(employeeModalNameInput?.value || '').trim(),
      id_number: String(employeeModalIdNumberInput?.value || '').trim(),
      mobile_bank: String(employeeModalMobileBankInput?.value || '').trim(),
      mobile_id_number: String(employeeModalMobileIdInput?.value || '').trim(),
      mobile_phone: String(employeeModalMobilePhoneInput?.value || '').trim(),
      bank_account_number: String(employeeModalBankAccountNumberInput?.value || '').trim(),
      bank_account_holder_name: String(employeeModalBankHolderNameInput?.value || '').trim(),
      bank_account_holder_id: String(employeeModalBankHolderIdInput?.value || '').trim(),
      crew: String(employeeModalCrewInput?.value || 'day').trim(),
      day_rate: Number(employeeModalDayRateInput?.value || 0),
      night_rate: Number(employeeModalNightRateInput?.value || 0),
    };

    if (!payload.full_name) {
      showEmployeeModalError('Ingresa el nombre del empleado');
      return;
    }

    const oldText = employeeModalSubmitBtn.textContent;
    employeeModalSubmitBtn.disabled = true;
    employeeModalSubmitBtn.textContent = isEdit ? 'Guardando...' : 'Creando...';

    try {
      const res = await fetch(`${apiBase}/payroll_employees.php${isEdit ? `?id=${encodeURIComponent(String(employeeId))}` : ''}`, {
        method: isEdit ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(isEdit ? { ...payload, id: employeeId } : payload),
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        throw new Error(data.error || data.message || (isEdit ? 'No se pudo actualizar empleado' : 'No se pudo crear empleado'));
      }

      closeEmployeeModal();
      await loadEmployees();
      renderTable();
    } catch (error) {
      showEmployeeModalError(error instanceof Error ? error.message : (isEdit ? 'No se pudo actualizar empleado' : 'No se pudo crear empleado'));
    } finally {
      employeeModalSubmitBtn.disabled = false;
      employeeModalSubmitBtn.textContent = oldText;
    }
  });

  openEmployeeModalBtn?.addEventListener('click', () => {
    openEmployeeModal(null);
  });

  openImportEmployeeModalBtn?.addEventListener('click', async () => {
    await openImportEmployeeModal();
  });

  employeeModalCloseBtn?.addEventListener('click', closeEmployeeModal);
  employeeModalCancelBtn?.addEventListener('click', closeEmployeeModal);
  importEmployeeModalCloseBtn?.addEventListener('click', closeImportEmployeeModal);
  importEmployeeCancelBtn?.addEventListener('click', closeImportEmployeeModal);
  importEmployeeSubmitBtn?.addEventListener('click', async () => {
    await importSelectedEmployees();
  });

  importEmployeesSearchInput?.addEventListener('input', () => {
    showImportEmployeeError('');
    if (importSearchTimer) {
      clearTimeout(importSearchTimer);
    }
    importSearchTimer = setTimeout(async () => {
      try {
        await loadGlobalEmployeesForImport(String(importEmployeesSearchInput?.value || '').trim());
      } catch (error) {
        sourceEmployees = [];
        if (importEmployeesList) {
          importEmployeesList.innerHTML = '<p class="text-sm text-error px-2 py-1">No se pudo cargar la tabla global de empleados.</p>';
        }
        showImportEmployeeError(error instanceof Error ? error.message : 'No se pudo cargar la tabla global de empleados');
      }
    }, 250);
  });

  employeeDeleteCancelBtn?.addEventListener('click', closeEmployeeDeleteModal);

  employeeDeleteConfirmBtn?.addEventListener('click', async () => {
    if (!employeeDeleteTargetId) return;

    const oldText = employeeDeleteConfirmBtn.textContent;
    employeeDeleteConfirmBtn.disabled = true;
    employeeDeleteConfirmBtn.textContent = 'Eliminando...';

    try {
      const res = await fetch(`${apiBase}/payroll_employees.php?id=${encodeURIComponent(String(employeeDeleteTargetId))}&project_id=${encodeURIComponent(String(projectId))}`, {
        method: 'DELETE',
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        throw new Error(data.error || data.message || 'No se pudo eliminar empleado');
      }

      closeEmployeeDeleteModal();
      await loadEmployees();
      renderTable();
    } catch (error) {
      alert(error instanceof Error ? error.message : 'No se pudo eliminar empleado');
    } finally {
      employeeDeleteConfirmBtn.disabled = false;
      employeeDeleteConfirmBtn.textContent = oldText;
    }
  });

  document.addEventListener('click', (event) => {
    const target = event.target instanceof HTMLElement ? event.target : null;
    if (!target) return;

    const dismissType = target.getAttribute('data-dismiss');
    if (dismissType === 'employee-modal') {
      closeEmployeeModal();
    }
    if (dismissType === 'employee-delete-modal') {
      closeEmployeeDeleteModal();
    }
    if (dismissType === 'import-employee-modal') {
      closeImportEmployeeModal();
    }
  });

  function moveWeek(offset) {
    const base = new Date(`${String(weekPicker.value || dateValue(new Date())).slice(0, 10)}T00:00:00`);
    base.setDate(base.getDate() + (offset * 7));
    weekPicker.value = dateValue(base);
  }

  prevWeekBtn?.addEventListener('click', async () => {
    moveWeek(-1);
    await reloadAll();
  });

  nextWeekBtn?.addEventListener('click', async () => {
    moveWeek(1);
    await reloadAll();
  });

  weekPicker?.addEventListener('change', async () => {
    await reloadAll();
  });

  async function reloadAll() {
    try {
      await Promise.all([loadEmployees(), loadAttendance()]);
      renderTable();
    } catch (error) {
      payrollBody.innerHTML = `<tr><td class="py-6 text-error">${escapeHtml(error instanceof Error ? error.message : 'No se pudo cargar nómina')}</td></tr>`;
    }
  }

  async function init() {
    weekPicker.value = dateValue(currentWeekDate);
    await loadProjectName();
    await reloadAll();
  }

  init();
</script>
