---
import MainLayout from '../../../layouts/MainLayout.astro';
import NavBarDesktop from '../../../components/NavBarDesktop.astro';
import NavBarMobil from '../../../components/NavBarMobil.astro';

export const prerender = false;

const projectId = (Astro.params as Record<string, string> | undefined)?.id ?? null;
export async function getStaticPaths() { return []; }
---

<MainLayout>
  <NavBarDesktop />

  <main class="pt-24 px-6 container mx-auto">
    <a href={`/projects/${projectId}`} class="text-sm text-primary cursor-pointer">← Volver al proyecto</a>

    <div class="flex flex-row justify-between mt-4">
      <div>
        <h1 id="project-name" data-project-id={projectId} class="text-2xl font-bold">Proyecto</h1>
        <h3 class="text-lg font-semibold mt-1">Valuaciones</h3>
        <p class="text-sm text-on-surface-variant">Registro de valuaciones realizadas sobre el proyecto.</p>
      </div>
      <div class="flex items-end gap-2">
        <button id="new-valuation-btn" data-project-id={projectId} type="button" class="px-3 py-2 bg-primary text-on-primary rounded cursor-pointer shadow-sm hover:brightness-95 transition">
          Nueva valuación
        </button>
      </div>
    </div>

    <section class="mt-6 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
      <article class="bg-linear-to-br from-primary to-primary-container text-on-primary rounded-xl p-4 shadow-lg border border-outline-variant/10 transition-transform duration-200 hover:scale-[1.02] cursor-pointer">
        <div class="flex items-start justify-between">
          <div>
            <div class="text-[10px] uppercase tracking-wide opacity-90">Total valuado</div>
            <div id="kpi-total-valued" class="text-2xl font-extrabold mt-2">$ 0.00</div>
          </div>
          <span class="material-symbols-outlined opacity-90">payments</span>
        </div>
        <div id="kpi-total-valued-badge" class="mt-3 text-xs bg-white/20 inline-flex px-2 py-0.5 rounded-full">Cobrado total: $ 0.00 · 0% del presupuesto</div>
      </article>

      <article class="bg-linear-to-br from-emerald-500 to-emerald-600 text-white rounded-xl p-4 shadow-sm border border-outline-variant/10 transition-transform duration-200 hover:scale-[1.02] cursor-pointer">
        <div class="flex items-start justify-between">
          <div>
            <div class="text-[10px] uppercase tracking-wide text-white/90">Aprobadas</div>
            <div id="kpi-approved" class="text-2xl font-extrabold mt-2">0</div>
          </div>
          <span class="material-symbols-outlined text-white">verified</span>
        </div>
        <div class="mt-3 text-xs bg-white/20 inline-flex px-2 py-0.5 rounded-full">Valuaciones aprobadas</div>
      </article>

      <article class="bg-linear-to-br from-amber-400 to-amber-500 text-amber-950 rounded-xl p-4 shadow-sm border border-outline-variant/10 transition-transform duration-200 hover:scale-[1.02] cursor-pointer">
        <div class="flex items-start justify-between">
          <div>
            <div class="text-[10px] uppercase tracking-wide text-amber-900/80">Pendientes</div>
            <div id="kpi-pending" class="text-2xl font-extrabold mt-2">0</div>
          </div>
          <span class="material-symbols-outlined text-amber-900">hourglass_top</span>
        </div>
        <div class="mt-3 text-xs bg-white/30 inline-flex px-2 py-0.5 rounded-full">En revisión o por aprobar</div>
      </article>

      <article class="bg-linear-to-br from-sky-500 to-sky-600 text-white rounded-xl p-4 shadow-sm border border-outline-variant/10 transition-transform duration-200 hover:scale-[1.02] cursor-pointer">
        <div class="flex items-start justify-between">
          <div>
            <div class="text-[10px] uppercase tracking-wide text-white/90">Cobradas</div>
            <div id="kpi-collected" class="text-2xl font-extrabold mt-2">0</div>
          </div>
          <span class="material-symbols-outlined text-white">receipt_long</span>
        </div>
        <div class="mt-3 text-xs bg-white/20 inline-flex px-2 py-0.5 rounded-full">Valuaciones marcadas como cobradas</div>
      </article>
    </section>

    <div id="valuations-root" class="mt-6 bg-surface-container-low p-4 rounded-xl shadow-[0_8px_24px_rgba(13,28,47,0.04)] border border-outline-variant/10 overflow-x-auto">
      <div class="text-on-surface-variant">Cargando valuaciones...</div>
    </div>
  </main>

  <div id="valuation-delete-modal" class="fixed inset-0 z-60 hidden items-center justify-center px-4">
    <button id="valuation-delete-modal-backdrop" type="button" data-close-valuation-delete-modal class="absolute inset-0 bg-black/45 opacity-0 transition-opacity duration-200 ease-out" aria-label="Cerrar confirmación"></button>
    <section id="valuation-delete-modal-panel" class="relative z-10 w-full max-w-md rounded-2xl border border-outline-variant/20 bg-surface shadow-xl transform-gpu opacity-0 translate-y-4 scale-95 transition-all duration-200 ease-out will-change-transform will-change-opacity">
      <div class="border-b border-outline-variant/15 px-5 py-4">
        <h3 class="text-lg font-semibold text-on-surface">Confirmar eliminación</h3>
        <p class="mt-1 text-sm text-on-surface-variant">Esta acción elimina la valuación y sus partidas asociadas.</p>
      </div>

      <div class="space-y-3 px-5 py-4">
        <div class="rounded-xl border border-error/20 bg-error/10 px-3 py-3 text-sm text-on-surface">
          <p class="font-medium text-error">¿Deseas eliminar esta valuación?</p>
          <p id="delete-valuation-summary" class="mt-1 text-on-surface-variant"></p>
        </div>
      </div>

      <div class="flex flex-col-reverse gap-2 border-t border-outline-variant/15 px-5 py-4 sm:flex-row sm:justify-end">
        <button id="cancel-valuation-delete" type="button" data-close-valuation-delete-modal class="rounded-lg border border-outline-variant px-4 py-2 text-on-surface cursor-pointer">Cancelar</button>
        <button id="confirm-valuation-delete" type="button" class="inline-flex items-center justify-center gap-2 rounded-lg bg-error px-4 py-2 text-on-error shadow-sm transition hover:brightness-95 cursor-pointer">
          <span class="material-symbols-outlined text-base">delete</span>
          Eliminar valuación
        </button>
      </div>
    </section>
  </div>

  <script type="module">
    const _meta = document.querySelector('meta[name="api-base"]');
    const _apiBase = _meta ? _meta.content : 'http://localhost/Budget/api';
    const projectNameEl = document.getElementById('project-name');
    async function loadProjectName() {
      if (!projectNameEl) return;
      const pid = projectNameEl.dataset.projectId || null;
      if (!pid) return;
      const tryFetch = async (paramName) => {
        try {
          const res = await fetch(`${_apiBase.replace(/\/$/, '')}/projects.php?${paramName}=${encodeURIComponent(pid)}`, { cache: 'no-store' });
          if (!res.ok) return null;
          const data = await res.json();
          const first = Array.isArray(data) ? data[0] : (data.data && data.data[0]) ? data.data[0] : null;
          if (!first) return null;
          const returnedId = first.id ?? first.project_id ?? first.ID ?? null;
          if (returnedId != null && String(returnedId) !== String(pid)) return null;
          return first.name || first.project_name || first.title || null;
        } catch (e) { return null; }
      };
      let name = await tryFetch('id');
      if (!name) name = await tryFetch('project_id');
      if (!name) {
        try {
          const resAll = await fetch(`${_apiBase.replace(/\/$/, '')}/projects.php`, { cache: 'no-store' });
          if (resAll.ok) {
            const dataAll = await resAll.json();
            const list = Array.isArray(dataAll) ? dataAll : (dataAll.data || []);
            const found = list.find(p => String(p.id) === String(pid) || String(p.project_id) === String(pid) || String(p.ID) === String(pid));
            if (found) name = found.name || found.project_name || found.title || null;
          }
        } catch (e) { /* ignore */ }
      }
      if (name) projectNameEl.textContent = name; else projectNameEl.textContent = `Proyecto #${pid}`;
    }

    loadProjectName();

    const btn = document.getElementById('new-valuation-btn');
    if (btn) {
      btn.addEventListener('click', () => {
        const pid = btn.dataset.projectId || '';
        window.location.href = `/projects/${pid}/valuations/new`;
      });
    }

    // --- Load valuations from API ---
    const valuationsRoot = document.getElementById('valuations-root');
    const kpiTotalEl = document.getElementById('kpi-total-valued');
    const kpiTotalBadgeEl = document.getElementById('kpi-total-valued-badge');
    const kpiApprovedEl = document.getElementById('kpi-approved');
    const kpiPendingEl = document.getElementById('kpi-pending');
    const kpiCollectedEl = document.getElementById('kpi-collected');
    const deleteModal = document.getElementById('valuation-delete-modal');
    const deleteModalBackdrop = document.getElementById('valuation-delete-modal-backdrop');
    const deleteModalPanel = document.getElementById('valuation-delete-modal-panel');
    const deleteSummaryEl = document.getElementById('delete-valuation-summary');
    const confirmDeleteBtn = document.getElementById('confirm-valuation-delete');

    let currentValuations = [];
    let projectBudgetAmount = 0;
    let projectCollectedAmount = 0;
    let projectCollectedRatio = 0;
    let projectCurrency = 'USD';
    let pendingDeleteId = null;
    let pendingDeleteResolve = null;

    function formatCurrency(value, currency = 'USD') {
      try {
        return new Intl.NumberFormat(undefined, {
          style: 'currency',
          currency,
          minimumFractionDigits: 2
        }).format(Number(value || 0));
      } catch (e) {
        return `${Number(value || 0).toFixed(2)} ${currency || ''}`;
      }
    }

    async function loadProjectFinancialMeta() {
      const pid = projectNameEl ? projectNameEl.dataset.projectId : null;
      if (!pid) return;

      try {
        const base = _apiBase.replace(/\/$/, '');

        const [projectRes, collectionsRes] = await Promise.all([
          fetch(`${base}/projects.php?id=${encodeURIComponent(pid)}`, { cache: 'no-store' }),
          fetch(`${base}/project_collections.php?project_id=${encodeURIComponent(pid)}`, { cache: 'no-store' })
        ]);

        if (!projectRes.ok) return;

        const projectPayload = await projectRes.json();
        const project = projectPayload?.data || (Array.isArray(projectPayload) ? projectPayload[0] : null);
        if (!project) return;

        projectCurrency = String(project.currency || 'USD');
        projectBudgetAmount = Number(project.budget ?? project.calculated_budget ?? project.budget_amount ?? 0) || 0;

        let directCollectionsTotal = 0;
        if (collectionsRes.ok) {
          const collectionsPayload = await collectionsRes.json().catch(() => ({}));
          const directCollections = Array.isArray(collectionsPayload?.data) ? collectionsPayload.data : [];
          directCollectionsTotal = directCollections.reduce((acc, row) => acc + Number(row.amount || 0), 0);
        }

        // Cobrado en esta vista = anticipos/cobros directos, sin incluir valuaciones cobradas.
        projectCollectedAmount = directCollectionsTotal;

        if (projectBudgetAmount > 0) {
          projectCollectedRatio = Math.max(0, Math.min(1, projectCollectedAmount / projectBudgetAmount));
        } else {
          projectCollectedRatio = 0;
        }
      } catch (e) {
        projectBudgetAmount = 0;
        projectCollectedAmount = 0;
        projectCollectedRatio = 0;
      }
    }

    function updateKpis(items) {
      const list = Array.isArray(items) ? items : [];
      const total = list.reduce((acc, v) => acc + Number(v.amount || 0), 0);

      let approved = 0;
      let pending = 0;
      let collected = 0;
      for (const v of list) {
        const status = String(v.status || '').toLowerCase();
        if (status.includes('cobrad') || status.includes('paid')) {
          collected += 1;
          continue;
        }
        if (status.includes('aprob')) {
          approved += 1;
          continue;
        }
        if (status.includes('rechaz')) {
          continue;
        }
        pending += 1;
      }

      const defaultCurrency = list[0]?.currency || 'USD';
      if (kpiTotalEl) kpiTotalEl.textContent = formatCurrency(total, defaultCurrency);
      if (kpiTotalBadgeEl) {
        const pct = Math.round(projectCollectedRatio * 100);
        kpiTotalBadgeEl.textContent = `Cobrado total: ${formatCurrency(projectCollectedAmount, projectCurrency)} · ${pct}% del presupuesto`;
      }
      if (kpiApprovedEl) kpiApprovedEl.textContent = String(approved);
      if (kpiPendingEl) kpiPendingEl.textContent = String(pending);
      if (kpiCollectedEl) kpiCollectedEl.textContent = String(collected);
    }

    async function loadValuations() {
      if (!valuationsRoot) return;
      valuationsRoot.innerHTML = '<div class="text-on-surface-variant">Cargando valuaciones...</div>';
      const pid = projectNameEl ? projectNameEl.dataset.projectId : null;
      if (!pid) { valuationsRoot.innerHTML = '<div class="text-error">Proyecto no especificado</div>'; return; }
      try {
        const base = _apiBase.replace(/\/$/, '');
        const res = await fetch(`${base}/valuations.php?project_id=${encodeURIComponent(pid)}`, { cache: 'no-store' });
        if (!res.ok) throw new Error('Fetch failed');
        const data = await res.json();
        const items = (data && data.data) ? data.data : [];
        currentValuations = items;
        updateKpis(items);
        renderValuations(items);
      } catch (e) {
        console.error(e);
        currentValuations = [];
        updateKpis([]);
        valuationsRoot.innerHTML = '<div class="text-error">No se pudieron cargar las valuaciones.</div>';
      }
    }

    function setDeleteModalVisibility(visible) {
      if (!deleteModal) return;

      if (visible) {
        deleteModal.classList.remove('hidden');
        deleteModal.classList.add('flex');
        document.body.style.overflow = 'hidden';

        requestAnimationFrame(() => {
          deleteModalBackdrop?.classList.remove('opacity-0');
          deleteModalBackdrop?.classList.add('opacity-100');
          deleteModalPanel?.classList.remove('opacity-0', 'translate-y-4', 'scale-95');
          deleteModalPanel?.classList.add('opacity-100', 'translate-y-0', 'scale-100');
        });

        setTimeout(() => confirmDeleteBtn?.focus(), 170);
        return;
      }

      deleteModalBackdrop?.classList.remove('opacity-100');
      deleteModalBackdrop?.classList.add('opacity-0');
      deleteModalPanel?.classList.remove('opacity-100', 'translate-y-0', 'scale-100');
      deleteModalPanel?.classList.add('opacity-0', 'translate-y-4', 'scale-95');

      let closed = false;
      const finishClose = () => {
        if (closed) return;
        closed = true;
        deleteModal.classList.add('hidden');
        deleteModal.classList.remove('flex');
        document.body.style.overflow = '';
      };

      deleteModalPanel?.addEventListener('transitionend', finishClose, { once: true });
      setTimeout(finishClose, 230);
    }

    function closeDeleteModal(confirmed) {
      setDeleteModalVisibility(false);
      if (pendingDeleteResolve) {
        pendingDeleteResolve(Boolean(confirmed));
      }
      pendingDeleteResolve = null;
      pendingDeleteId = null;
    }

    function askDeleteConfirmation(valuation) {
      if (!deleteModal || !deleteSummaryEl) {
        return Promise.resolve(window.confirm('¿Eliminar esta valuación?'));
      }

      const date = valuation?.date || 'Sin fecha';
      const amount = formatCurrency(valuation?.amount || 0, valuation?.currency || 'USD');
      const status = valuation?.status || 'Sin estado';
      deleteSummaryEl.textContent = `${date} · ${amount} · ${status}`;
      pendingDeleteId = String(valuation?.id || '');

      return new Promise((resolve) => {
        pendingDeleteResolve = resolve;
        setDeleteModalVisibility(true);
      });
    }

    async function handleDeleteValuation(id) {
      if (!id) return;
      const base = _apiBase.replace(/\/$/, '');

      if (confirmDeleteBtn) {
        confirmDeleteBtn.disabled = true;
        confirmDeleteBtn.classList.add('opacity-70', 'cursor-not-allowed');
      }

      try {
        const res = await fetch(`${base}/valuations.php?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
        const payload = await res.json().catch(() => ({}));
        if (!res.ok) {
          throw new Error(payload.error || payload.message || 'No se pudo eliminar la valuación');
        }
        await loadValuations();
      } catch (error) {
        alert(error instanceof Error ? error.message : 'No se pudo eliminar la valuación');
      } finally {
        if (confirmDeleteBtn) {
          confirmDeleteBtn.disabled = false;
          confirmDeleteBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        }
      }
    }

    function renderValuations(items) {
      const escapeHtml = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

      const extractValuatorAndObservation = (rawNotes) => {
        const source = String(rawNotes ?? '');
        const match = source.match(/^\s*valuador\s*:\s*(.+?)(?:\r?\n\r?\n|\r?\n|$)([\s\S]*)$/i);

        if (!match) {
          return {
            valuator: '',
            observation: source.trim()
          };
        }

        return {
          valuator: String(match[1] || '').trim(),
          observation: String(match[2] || '').trim()
        };
      };

      const fmtNumber = new Intl.NumberFormat(undefined, { minimumFractionDigits: 2 });
      const fmtCurrency = (value, currency) => {
        try {
          return new Intl.NumberFormat(undefined, { style: 'currency', currency: (currency || 'USD'), minimumFractionDigits: 2 }).format(Number(value || 0));
        } catch (e) {
          return `${fmtNumber.format(Number(value || 0))} ${currency || ''}`;
        }
      };

      if (!items || items.length === 0) {
        valuationsRoot.innerHTML = '<div class="text-on-surface-variant">No hay valuaciones registradas para este proyecto.</div>';
        return;
      }

      const badgeFor = (s) => {
        const label = s || 'estimada';
        const lower = String(label).toLowerCase();
        if (lower.includes('aprob')) return `<span class="inline-block px-2 py-1 rounded-full bg-emerald-100 text-emerald-800 text-xs font-semibold">${label}</span>`;
        if (lower.includes('revision') || lower.includes('revisión')) return `<span class="inline-block px-2 py-1 rounded-full bg-amber-100 text-amber-800 text-xs font-semibold">${label}</span>`;
        if (lower.includes('rechaz')) return `<span class="inline-block px-2 py-1 rounded-full bg-rose-100 text-rose-800 text-xs font-semibold">${label}</span>`;
        return `<span class="inline-block px-2 py-1 rounded-full bg-primary/10 text-primary text-xs font-semibold">${label}</span>`;
      };

      const sortedItems = [...(items || [])].sort((a, b) => {
        const aDateRaw = a?.date || a?.created_at || '';
        const bDateRaw = b?.date || b?.created_at || '';
        const aDate = new Date(String(aDateRaw).replace(' ', 'T'));
        const bDate = new Date(String(bDateRaw).replace(' ', 'T'));
        const aTime = Number.isNaN(aDate.getTime()) ? 0 : aDate.getTime();
        const bTime = Number.isNaN(bDate.getTime()) ? 0 : bDate.getTime();

        if (aTime !== bTime) return aTime - bTime;

        const aId = Number(a?.id || 0);
        const bId = Number(b?.id || 0);
        return aId - bId;
      });

      const rows = sortedItems.map((v, idx) => {
        const id = v.id || '';
        const pid = projectNameEl?.dataset.projectId || '';
        const editHref = `/projects/${encodeURIComponent(pid)}/valuations/${encodeURIComponent(String(id))}/edit`;
        const viewHref = `/projects/${encodeURIComponent(pid)}/valuations/${encodeURIComponent(String(id))}/view`;
        const printHref = `/projects/${encodeURIComponent(pid)}/valuations/${encodeURIComponent(String(id))}/print`;
        const date = v.date || (v.created_at ? v.created_at.split(' ')[0] : '');
        const createdAt = v.created_at || '';
        const parsed = extractValuatorAndObservation(v.notes);
        const valuator = String(v.valuator || '').trim() || parsed.valuator || (v.created_by != null ? `User ${v.created_by}` : '—');
        const amount = Number(v.amount || 0);
        const amountToCollect = Math.max(0, amount * (1 - projectCollectedRatio));
        const currency = v.currency || 'USD';
        const status = v.status || 'estimada';
        const observation = parsed.observation;
        const observationShort = observation.length > 120 ? observation.slice(0, 117) + '...' : observation;

        return `
          <tr class="bg-surface-container-low border-b border-outline-variant/10 hover:bg-surface-dim">
            <td class="px-3 py-3 text-sm font-mono text-on-surface-variant">${idx + 1}</td>
            <td class="px-3 py-3 text-sm">${escapeHtml(date)}</td>
            <td class="px-3 py-3 text-sm">${escapeHtml(valuator)}</td>
            <td class="px-3 py-3 text-sm text-right font-medium">${fmtCurrency(amount, currency)}</td>
            <td class="px-3 py-3 text-sm text-right font-semibold">${fmtCurrency(amountToCollect, currency)}</td>
            <td class="px-3 py-3 text-sm">${badgeFor(status)}</td>
            <td class="px-3 py-3 text-sm text-muted">${escapeHtml(observationShort || '—')}</td>
            <td class="px-3 py-3 text-sm text-center">
                <a href="${viewHref}" class="inline-flex items-center p-1 rounded hover:bg-button-hover text-on-surface cursor-pointer" title="Ver valuación">
                  <span class="material-symbols-outlined">visibility</span>
                </a>
                <a href="${printHref}" target="_blank" class="inline-flex items-center p-1 rounded hover:bg-button-hover text-on-surface ml-2 cursor-pointer" title="Imprimir valuación">
                  <span class="material-symbols-outlined">picture_as_pdf</span>
                </a>
                <a href="${editHref}" class="inline-flex items-center p-1 rounded hover:bg-button-hover text-on-surface ml-2 cursor-pointer" title="Editar">
                  <span class="material-symbols-outlined">edit</span>
                </a>
                <button type="button" data-action="delete" data-id="${escapeHtml(String(id))}" class="inline-flex items-center p-1 rounded hover:bg-button-hover text-error ml-2 cursor-pointer" title="Eliminar">
                  <span class="material-symbols-outlined">delete</span>
                </button>
            </td>
            <td class="px-3 py-3 text-xs text-on-surface-variant">${escapeHtml(createdAt)}</td>
          </tr>`;
      }).join('\n');

      const tableHtml = `
        <div class="overflow-x-auto">
          <table class="w-full table-auto text-left">
            <thead>
              <tr class="text-xs text-on-surface-variant border border-outline-variant">
                <th class="px-3 py-2">Item</th>
                <th class="px-3 py-2">Fecha</th>
                <th class="px-3 py-2">Valuador</th>
                <th class="px-3 py-2 text-right">Monto</th>
                <th class="px-3 py-2 text-right">A Cobrar</th>
                <th class="px-3 py-2">Estado</th>
                <th class="px-3 py-2">Observaciones</th>
                <th class="px-3 py-2 text-center">Acciones</th>
                <th class="px-3 py-2">Creado</th>
              </tr>
            </thead>
            <tbody>
              ${rows}
            </tbody>
          </table>
        </div>`;

      valuationsRoot.innerHTML = tableHtml;
    }

    document.querySelectorAll('[data-close-valuation-delete-modal]').forEach((element) => {
      element.addEventListener('click', () => {
        closeDeleteModal(false);
      });
    });

    confirmDeleteBtn?.addEventListener('click', () => {
      closeDeleteModal(true);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      if (!deleteModal?.classList.contains('hidden')) {
        closeDeleteModal(false);
      }
    });

    valuationsRoot?.addEventListener('click', (event) => {
      const target = event.target instanceof HTMLElement ? event.target.closest('button[data-action="delete"]') : null;
      if (!target) return;

      const id = target.getAttribute('data-id');
      if (!id) return;

      const valuation = currentValuations.find((entry) => String(entry.id) === String(id));
      if (!valuation) return;

      askDeleteConfirmation(valuation).then((confirmed) => {
        if (!confirmed) return;
        handleDeleteValuation(id);
      });
    });

    // cargar metadatos de proyecto y luego valuaciones
    (async () => {
      await loadProjectFinancialMeta();
      await loadValuations();
    })();
  </script>
</MainLayout>
