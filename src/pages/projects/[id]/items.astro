---
import MainLayout from '../../../layouts/MainLayout.astro';
import NavBarDesktop from '../../../components/NavBarDesktop.astro';
import NavBarMobil from '../../../components/NavBarMobil.astro';

export const prerender = false;

const projectId = (Astro.params as Record<string, string> | undefined)?.id ?? null;
export async function getStaticPaths() { return []; }
---

<MainLayout>
  <NavBarDesktop />

  <main class="pt-24 px-6 max-w-4xl mx-auto">
    <a href="/projects/${projectId}" class="text-sm text-primary">← Volver al proyecto</a>
    <h1 class="text-2xl font-bold mt-4">Partidas asignadas</h1>

    <div id="items-root" data-id={projectId} class="mt-4 bg-surface-container-low p-4 rounded-xl shadow-[0_8px_24px_rgba(13,28,47,0.04)] border border-outline-variant/10 overflow-y-auto" style="max-height: calc(100vh - 220px);">
      <div class="text-on-surface-variant">Cargando partidas...</div>
    </div>
  </main>

  <script type="module">
    const root = document.getElementById('items-root');
    const projectId = root ? root.dataset.id : null;
    const _meta = document.querySelector('meta[name="api-base"]');
    const _apiBase = _meta ? _meta.content : 'http://localhost/Budget/api';
    const apiUrl = `${_apiBase.replace(/\/$/, '')}/project_items.php?project_id=${projectId}`;

    async function loadItems() {
      try {
        const res = await fetch(apiUrl, { cache: 'no-store' });
        if (!res.ok) throw new Error('Fetch failed');
        let data = await res.json();
        const items = Array.isArray(data) ? data : (data.data || []);
        renderItems(items);
      } catch (e) {
        console.error(e);
        root.innerHTML = '<div class="text-error">No se pudieron cargar las partidas.</div>';
      }
    }

    function renderItems(items) {
      if (!items || items.length === 0) {
        root.innerHTML = '<div class="text-on-surface-variant">No hay partidas asignadas a este proyecto.</div>';
        return;
      }
      const fmt = new Intl.NumberFormat(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      let total = 0;
      const rows = items.map(it => {
        const qty = Number(it.qty || 0);
        const unitCost = Number(it.unit_cost || 0);
        const totalCost = Number(it.total_cost || (qty * unitCost) || 0);
        total += totalCost;
        return `<tr class="border-b border-outline-variant/10">
          <td class="px-3 py-2 text-sm">${it.item_name || it.item_id}</td>
          <td class="px-3 py-2 text-sm">${it.unit || ''}</td>
          <td class="px-3 py-2 text-sm text-right">${qty}</td>
          <td class="px-3 py-2 text-sm text-right">${fmt.format(unitCost)}</td>
          <td class="px-3 py-2 text-sm text-right font-medium">${fmt.format(totalCost)}</td>
          <td class="px-3 py-2 text-sm text-right">
            <button class="p-2 rounded hover:bg-surface-dim text-on-surface" title="Editar">
              <span class="material-symbols-outlined">edit</span>
            </button>
            <button class="p-2 rounded hover:bg-surface-dim text-error ml-2" title="Eliminar">
              <span class="material-symbols-outlined">delete</span>
            </button>
          </td>
        </tr>`;
      }).join('\n');

      root.innerHTML = `
        <div class="overflow-x-auto">
          <div class="overflow-x-auto">
          <table class="w-full min-w-[900px] table-fixed text-left">
            <thead>
              <tr class="text-xs text-on-surface-variant">
                <th class="px-3 py-2">Partida</th>
                <th class="px-3 py-2">Unidad</th>
                <th class="px-3 py-2 text-right">Cantidad</th>
                <th class="px-3 py-2 text-right">Costo unit.</th>
                <th class="px-3 py-2 text-right">Total</th>
                <th class="px-3 py-2 text-right"><span class="sr-only">Acciones</span></th>
              </tr>
            </thead>
            <tbody>
              ${rows}
            </tbody>
            <tfoot>
              <tr>
                <td colspan="5" class="px-3 py-2 text-sm font-semibold text-right">Total presupuestado</td>
                <td class="px-3 py-2 text-sm font-semibold text-right">${fmt.format(total)}</td>
              </tr>
            </tfoot>
          </table>
          </div>
        </div>
      `;
    }

    loadItems();
  </script>

  <NavBarMobil />
</MainLayout>
