---
import MainLayout from '../../../layouts/MainLayout.astro';
import NavBarDesktop from '../../../components/NavBarDesktop.astro';
import NavBarMobil from '../../../components/NavBarMobil.astro';

export const prerender = false;

const projectId = (Astro.params as Record<string, string> | undefined)?.id ?? null;
export async function getStaticPaths() { return []; }
---

<MainLayout>
  <NavBarDesktop />

  <main class="pt-24 px-6 container mx-auto">
    <a href={`/projects/${projectId}`} class="text-sm text-primary cursor-pointer">← Volver al proyecto</a>
    <div class="flex flex-row justify-between mt-4">
      <div>
        <h1 id="project-name" data-project-id={projectId} class="text-2xl font-bold">Proyecto #{projectId}</h1>
        <h3 class="text-lg font-semibold mt-1">Partidas asignadas</h3>
        <p class="text-sm text-on-surface-variant">Listado de partidas asociadas a este proyecto.</p>
        <p id="items-lock-message" class="hidden text-sm text-on-surface-variant mt-2"></p>
      </div>
      <div class="flex items-end gap-2">
        <button id="add-item-btn" type="button" class="px-3 py-2 bg-primary text-on-primary rounded cursor-pointer shadow-sm hover:brightness-95 transition">
          <span class="material-symbols-outlined mr-2 align-middle">add</span>Agregar partida
        </button>
      </div>
    </div>

    <div id="items-root" data-id={projectId} class="mt-4 bg-surface-container-low p-4 rounded-xl shadow-[0_8px_24px_rgba(13,28,47,0.04)] border border-outline-variant/10 overflow-y-auto" style="max-height: calc(100vh - 220px);">
      <div class="text-on-surface-variant">Cargando partidas...</div>
    </div>
  </main>

  <script type="module">
    const root = document.getElementById('items-root');
    const projectId = root ? root.dataset.id : null;
    const _meta = document.querySelector('meta[name="api-base"]');
    const _apiBase = _meta ? _meta.content : 'http://localhost/Budget/api';
    const apiUrl = `${_apiBase.replace(/\/$/, '')}/project_items.php?project_id=${projectId}`;
    const numFmt = new Intl.NumberFormat(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const addBtn = document.getElementById('add-item-btn');
    const lockMessageEl = document.getElementById('items-lock-message');
    let projectStatus = 'draft';

    function isProjectLocked() {
      return projectStatus !== 'draft';
    }

    function applyProjectLockUI() {
      if (lockMessageEl) {
        if (isProjectLocked()) {
          lockMessageEl.textContent = `Proyecto bloqueado por estado ${projectStatus}. Solo se puede modificar en draft.`;
          lockMessageEl.classList.remove('hidden');
        } else {
          lockMessageEl.textContent = '';
          lockMessageEl.classList.add('hidden');
        }
      }

      if (addBtn instanceof HTMLButtonElement) {
        addBtn.disabled = isProjectLocked();
        addBtn.classList.toggle('opacity-60', isProjectLocked());
        addBtn.classList.toggle('cursor-not-allowed', isProjectLocked());
        addBtn.classList.toggle('hover:brightness-95', !isProjectLocked());
        addBtn.title = isProjectLocked() ? 'Solo se puede modificar un proyecto en draft' : '';
      }
    }

    // attempt to load project name to display in header
    const projectNameEl = document.getElementById('project-name');
    async function loadProjectName() {
      if (!projectNameEl) return;
      const pid = projectId || projectNameEl.dataset.projectId || null;
      if (!pid) return; // nothing to do

      try {
        const res = await fetch(`${_apiBase.replace(/\/$/, '')}/projects.php?id=${encodeURIComponent(pid)}`, { cache: 'no-store' });
        if (!res.ok) throw new Error('Project fetch failed');
        const data = await res.json();
        const project = Array.isArray(data) ? data[0] : (data.data || data.project || data);
        projectStatus = (project?.status ?? project?.state ?? 'draft').toString() || 'draft';
        applyProjectLockUI();
        const name = project?.name || project?.project_name || project?.title || null;
        if (name) {
          projectNameEl.textContent = name;
          return;
        }
      } catch (e) {
        applyProjectLockUI();
      }

      if (!projectNameEl.textContent || projectNameEl.textContent.startsWith('Proyecto #')) {
        projectNameEl.textContent = `Proyecto #${pid}`;
      }
    }

    // enhanced toast helper with slide animation and simple icon
    function showToast(message, type = 'info', timeout = 3500) {
      let container = document.getElementById('toast-container');
      if (!container) {
        container = document.createElement('div');
        container.id = 'toast-container';
        container.className = 'fixed top-6 right-6 flex flex-col gap-2 z-50';
        document.body.appendChild(container);
      }
      const toast = document.createElement('div');
      const base = 'px-4 py-2 rounded-lg shadow-lg text-sm flex items-center gap-3 max-w-xs';
      const color = type === 'success' ? 'bg-emerald-600 text-white' : (type === 'error' ? 'bg-rose-600 text-white' : 'bg-gray-800 text-white');
      toast.className = `${base} ${color}`;
      toast.style.transform = 'translateX(16px)';
      toast.style.opacity = '0';
      toast.style.transition = 'transform 220ms cubic-bezier(.2,.9,.2,1), opacity 220ms ease';

      const icon = document.createElement('span');
      icon.className = 'text-lg';
      icon.textContent = type === 'success' ? '✓' : (type === 'error' ? '✕' : 'ℹ');
      icon.setAttribute('aria-hidden', 'true');

      const text = document.createElement('div');
      text.textContent = message;

      toast.appendChild(icon);
      toast.appendChild(text);
      container.appendChild(toast);

      // force frame then animate in
      requestAnimationFrame(() => {
        toast.style.transform = 'translateX(0)';
        toast.style.opacity = '1';
      });

      // remove with slide-out
      setTimeout(() => {
        toast.style.transform = 'translateX(16px)';
        toast.style.opacity = '0';
        setTimeout(() => { toast.remove(); }, 300);
      }, timeout);
    }

    // simple confirm modal that returns a Promise<boolean>
    function confirmDialog(message = '¿Confirmar?') {
      return new Promise((resolve) => {
        let modal = document.getElementById('confirm-modal');
        if (!modal) return resolve(false);
        const msg = modal.querySelector('.confirm-message');
        const yes = modal.querySelector('#confirm-yes');
        const no = modal.querySelector('#confirm-no');
        msg.textContent = message;
        modal.classList.remove('hidden'); modal.classList.add('flex');
        document.documentElement.classList.add('modal-open');

        const cleanup = () => {
          modal.classList.add('hidden'); modal.classList.remove('flex');
          document.documentElement.classList.remove('modal-open');
          yes.removeEventListener('click', onYes);
          no.removeEventListener('click', onNo);
        };

        const onYes = () => { cleanup(); resolve(true); };
        const onNo = () => { cleanup(); resolve(false); };

        yes.addEventListener('click', onYes);
        no.addEventListener('click', onNo);
      });
    }

    async function loadItems() {
      try {
        const res = await fetch(apiUrl, { cache: 'no-store' });
        if (!res.ok) throw new Error('Fetch failed');
        let data = await res.json();
        const items = Array.isArray(data) ? data : (data.data || []);
        renderItems(items);
      } catch (e) {
        console.error(e);
        root.innerHTML = '<div class="text-error">No se pudieron cargar las partidas.</div>';
      }
    }

    function renderItems(items) {
      if (!items || items.length === 0) {
        root.innerHTML = '<div class="text-on-surface-variant">No hay partidas asignadas a este proyecto.</div>';
        return;
      }
      const fmt = numFmt;
      let total = 0;
      const rows = items.map((it, idx) => {
        const rowBg = idx % 2 === 0 ? 'bg-surface-container-low' : 'bg-surface-container-high';
          const qty = Number(it.qty || 0);
          const unitCost = Number(it.unit_cost || 0);
          const totalCost = Number(it.total_cost || (qty * unitCost) || 0);
        total += totalCost;
          return `<tr class="${rowBg} border border-outline-variant/90 hover:bg-surface-dim cursor-pointer" data-row-index="${idx}" data-item-id="${it.id || it.item_id}" data-qty="${qty}" data-unit-cost="${unitCost}">
            <td class="px-3 py-1 align-center text-sm border-r border-outline-variant/10">${it.item_name || it.item_id}</td>
          <td class="px-3 py-1 align-center text-sm text-center border-r border-outline-variant/10">${it.unit || ''}</td>
          <td class="px-3 py-1 align-center text-sm text-center border-r border-outline-variant/10">${fmt.format(qty)}</td>
          <td class="px-3 py-1 align-center text-sm text-center border-r border-outline-variant/10">${fmt.format(unitCost)}</td>
          <td class="px-3 py-1 align-center text-sm text-center border-r border-outline-variant/10 font-medium">${fmt.format(totalCost)}</td>
          <td class="px-3 py-1 align-center text-sm text-center">
            ${isProjectLocked()
              ? '<span class="text-xs text-on-surface-variant">Bloqueado</span>'
              : `<button class="p-1 rounded hover:bg-button-hover text-on-surface cursor-pointer " title="Editar">
              <span class="material-symbols-outlined">edit</span>
            </button>
            <button class="p-1 rounded hover:bg-button-hover text-error ml-2 cursor-pointer" title="Eliminar">
              <span class="material-symbols-outlined">delete</span>
            </button>`}
          </td>
        </tr>`;
      }).join('\n');

      const tableHtml = `
        <div class="overflow-x-auto">
          <div class="overflow-x-auto">
            <table class="w-full min-w-[900px] table-auto text-left">
              <colgroup>
                <col style="min-width:33%" />
                <col />
                <col />
                <col />
                <col />
                <col style="width:128px" />
              </colgroup>
              <thead>
                <tr class="text-xs text-on-surface-variant border border-outline-variant">
                  <th class="px-3 py-1">Partida</th>
                  <th class="px-3 py-1 text-center">Unidad</th>
                  <th class="px-3 py-1 text-center">Cantidad</th>
                  <th class="px-3 py-1 text-center">Costo unit.</th>
                  <th class="px-3 py-1 text-center">Total</th>
                  <th class="px-3 py-1 text-center">Acciones</th>
                </tr>
              </thead>
              <tbody>
                ${rows}
              </tbody>
              <tfoot>
                <tr>
                  <td colspan="5" class="px-3 py-1 text-sm font-semibold text-right">Total presupuestado</td>
                  <td class="px-3 py-1 text-sm font-semibold text-right">${fmt.format(total)}</td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      `;

      root.innerHTML = tableHtml;
      // after rendering table, initialize behaviors
      initTableBehavior();
    }
    
    // define initialization function for table behaviors
    function initTableBehavior() {
      const tbl = root.querySelector('table');
      if (!tbl) return;
      tbl.classList.add('items-table');

      // inyectar estilo CSS específico (una sola vez)
      if (!document.getElementById('items-table-styles')) {
        const s = document.createElement('style');
        s.id = 'items-table-styles';
        s.textContent = `
          .items-table tr.selected { background-color: rgba(14,165,233,0.08) !important; }
          .items-table tr:hover { filter: brightness(0.985); }
          .items-table td { vertical-align: top; }
          .items-table td.border-r { border-right: 1px solid rgba(13,28,47,0.08); }
          .modal-open { overflow: hidden; }
        `;
        document.head.appendChild(s);
      }

      const tbody = tbl.querySelector('tbody');
      if (!tbody) return;
      let selectedIdx = null;

      // selección por fila (evitar clicks en botones)
      tbody.querySelectorAll('tr[data-row-index]').forEach(tr => {
        tr.addEventListener('click', (ev) => {
          if (ev.target.closest('button')) return; // no seleccionar si se hizo click en botón
          const idx = tr.dataset.rowIndex;
          if (selectedIdx !== null) {
            const prev = tbody.querySelector(`tr[data-row-index="${selectedIdx}"]`);
            if (prev) prev.classList.remove('selected');
          }
          tr.classList.add('selected');
          selectedIdx = idx;
        });
      });

      // Modal handlers: abrir al pulsar botón Editar
      const modal = document.getElementById('edit-item-modal');
      const form = document.getElementById('edit-item-form');
      const errorEl = document.getElementById('edit-item-error');
      const inputQty = form ? form.querySelector('input[name="qty"]') : null;
      const inputUnit = form ? form.querySelector('input[name="unit_cost"]') : null;
      let editingRow = null;

      tbody.querySelectorAll('button[title="Editar"]').forEach(btn => {
        btn.addEventListener('click', (ev) => {
          ev.stopPropagation();
          const tr = btn.closest('tr');
          if (!tr) return;
          editingRow = tr;
          const d = tr.dataset;
          if (inputQty) inputQty.value = d.qty ?? '';
          if (inputUnit) inputUnit.value = d.unitCost ?? d.unitCost === undefined ? tr.dataset.unitCost : tr.dataset.unitCost;
          if (errorEl) {
            errorEl.textContent = '';
            errorEl.classList.add('hidden');
          }
          // show modal
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          document.documentElement.classList.add('modal-open');
        });
      });

      // Delete handler: eliminar de project_items
      tbody.querySelectorAll('button[title="Eliminar"]').forEach(btn => {
        btn.addEventListener('click', async (ev) => {
          ev.stopPropagation();
          const tr = btn.closest('tr');
          if (!tr) return;
          const id = tr.dataset.itemId;
          if (!id) return;
          // use custom confirm dialog
          const ok = await confirmDialog('¿Eliminar esta partida del proyecto?');
          if (!ok) return;
          try {
            const resp = await fetch(`${_apiBase.replace(/\/$/, '')}/project_items.php?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (!resp.ok) throw new Error('Delete failed: ' + resp.status);
            await resp.json();
            // eliminar fila y recalcular total
            tr.remove();
            const allRows = tbody.querySelectorAll('tr[data-row-index]');
            let sum = 0;
            allRows.forEach(r => {
              const cells = r.querySelectorAll('td');
              if (cells && cells.length >= 5) {
                const val = Number(cells[4].textContent.replace(/[^0-9.,-]/g, '').replace(',', '.')) || 0;
                sum += val;
              }
            });
            const footerTotal = root.querySelector('tfoot td:last-child');
            if (footerTotal) footerTotal.textContent = numFmt.format(sum);
            // mostrar notificación
            try { showToast('Partida eliminada', 'success'); } catch (e) { console.log('toast error', e); }
          } catch (err) {
            console.error('Delete failed', err);
            showToast('No se pudo eliminar la partida.', 'error');
          }
        });
      });

      const closeModal = () => {
        if (!modal) return;
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.documentElement.classList.remove('modal-open');
        editingRow = null;
      };

      const cancelBtn = document.getElementById('edit-item-cancel');
      if (cancelBtn) cancelBtn.addEventListener('click', closeModal);

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (!editingRow) return closeModal();
          const itemId = Number(editingRow.dataset.itemId || 0);
          const newQty = Number.parseFloat(inputQty?.value || '0');
          const newUnit = Number.parseFloat(inputUnit?.value || '0');

          if (!itemId) {
            if (errorEl) {
              errorEl.textContent = 'No se encontró el identificador de la partida.';
              errorEl.classList.remove('hidden');
            }
            return;
          }

          if (!Number.isFinite(newQty) || newQty < 0 || !Number.isFinite(newUnit) || newUnit < 0) {
            if (errorEl) {
              errorEl.textContent = 'Cantidad y costo unitario deben ser números válidos mayores o iguales a cero.';
              errorEl.classList.remove('hidden');
            }
            return;
          }

          const saveBtn = document.getElementById('edit-item-save');
          if (saveBtn instanceof HTMLButtonElement) {
            saveBtn.disabled = true;
            saveBtn.textContent = 'Guardando...';
          }

          try {
            const resp = await fetch(`${_apiBase.replace(/\/$/, '')}/project_items.php`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: itemId, qty: newQty, unit_cost: newUnit })
            });
            const result = await resp.json().catch(() => ({}));
            if (!resp.ok) {
              throw new Error(result.error || result.message || 'No se pudo guardar la partida');
            }

            const savedQty = Number(result?.data?.qty ?? newQty);
            const savedUnit = Number(result?.data?.unit_cost ?? newUnit);
            const savedTotal = Number(result?.data?.total_cost ?? (savedQty * savedUnit));

            editingRow.dataset.qty = String(savedQty);
            editingRow.dataset.unitCost = String(savedUnit);

            const tds = editingRow.querySelectorAll('td');
            if (tds && tds.length >= 5) {
              tds[2].textContent = numFmt.format(savedQty);
              tds[3].textContent = numFmt.format(savedUnit);
              tds[4].textContent = numFmt.format(savedTotal);
            }

            const allRows = tbody.querySelectorAll('tr[data-row-index]');
            let sum = 0;
            allRows.forEach(r => {
              const rowQty = Number.parseFloat(r.dataset.qty || '0');
              const rowUnit = Number.parseFloat(r.dataset.unitCost || '0');
              sum += rowQty * rowUnit;
            });
            const footerTotal = root.querySelector('tfoot td:last-child');
            if (footerTotal) footerTotal.textContent = numFmt.format(sum);

            closeModal();
            try { showToast('Cambios guardados', 'success'); } catch (toastErr) { console.log('toast error', toastErr); }
          } catch (err) {
            console.error('Update failed', err);
            if (errorEl) {
              errorEl.textContent = err instanceof Error ? err.message : 'No se pudo guardar la partida';
              errorEl.classList.remove('hidden');
            }
          } finally {
            if (saveBtn instanceof HTMLButtonElement) {
              saveBtn.disabled = false;
              saveBtn.textContent = 'Guardar';
            }
          }
        });
      }
    }
    
    // carga inicial y revalidación desde bfcache
    // primero intentar cargar nombre del proyecto y luego las partidas
    async function initializePage() {
      await loadProjectName();
      await loadItems();
    }

    initializePage();
    window.addEventListener('pageshow', (e) => { if (e.persisted) { initializePage(); } });

    // --- Modal Agregar Partida: abrir y cargar partidas desde la tabla `items` (API)
    // endpoint para lista de partidas (debe existir en backend)
    const itemsApiUrl = `${_apiBase.replace(/\/$/, '')}/items.php`;

    async function openAddModal() {
      if (isProjectLocked()) {
        showToast('Solo se puede modificar un proyecto en draft.', 'error');
        return;
      }
      console.log('[items] openAddModal called');
      let modal = document.getElementById('add-item-modal');
      if (!modal) return;
      const content = modal.querySelector('.add-items-list');
      modal.classList.remove('hidden'); modal.classList.add('flex');
      document.documentElement.classList.add('modal-open');
      if (content) content.innerHTML = '<div class="text-on-surface-variant">Cargando partidas...</div>';
      console.log('[items] fetching items from', itemsApiUrl);
      try {
        const res = await fetch(itemsApiUrl, { cache: 'no-store' });
        console.log('[items] items fetch status', res.status);
        if (!res.ok) throw new Error('Fetch failed: ' + res.status);
        const data = await res.json();
        const list = Array.isArray(data) ? data : (data.data || []);
        const controlsHtml = `
          <div class="space-y-3 mb-3">
            <button type="button" id="open-catalog-item-form" class="px-3 py-2 bg-primary text-on-primary rounded cursor-pointer">Crear partida en catálogo</button>
            <form id="catalog-item-form" class="hidden space-y-2 border border-outline-variant/20 rounded-lg p-3 bg-surface-container-low">
              <div>
                <label class="block text-xs text-on-surface-variant mb-1" for="catalog-item-name">Nombre</label>
                <input id="catalog-item-name" name="name" required class="w-full px-3 py-2 rounded-md border border-outline-variant bg-surface text-on-surface" />
              </div>
              <div class="grid grid-cols-2 gap-2">
                <div>
                  <label class="block text-xs text-on-surface-variant mb-1" for="catalog-item-unit">Unidad</label>
                  <input id="catalog-item-unit" name="unit" placeholder="m2, ml, pza..." class="w-full px-3 py-2 rounded-md border border-outline-variant bg-surface text-on-surface" />
                </div>
                <div>
                  <label class="block text-xs text-on-surface-variant mb-1" for="catalog-item-unit-cost">Costo unit.</label>
                  <input id="catalog-item-unit-cost" name="unit_cost" type="number" min="0" step="0.01" value="0" class="w-full px-3 py-2 rounded-md border border-outline-variant bg-surface text-on-surface" />
                </div>
              </div>
              <div id="catalog-item-feedback" class="text-xs text-on-surface-variant"></div>
              <div class="flex justify-end gap-2 pt-1">
                <button type="button" id="cancel-catalog-item-form" class="px-3 py-2 rounded border border-outline-variant cursor-pointer">Cancelar</button>
                <button type="submit" id="submit-catalog-item-form" class="px-3 py-2 bg-primary text-on-primary rounded cursor-pointer">Guardar partida</button>
              </div>
            </form>
          </div>
        `;

        const listHtml = (!list || list.length === 0)
          ? '<div class="text-on-surface-variant">No hay partidas disponibles.</div>'
          : `<div class="max-h-64 overflow-y-auto">${list.map(it => `
          <button data-item-id="${it.id}" data-unit-cost="${it.unit_cost}" data-item-name="${(it.name||it.item_name||'').replace(/"/g,'&quot;')}" type="button" class="add-item-row w-full text-left p-2 border-b border-outline-variant/10 flex justify-between items-center hover:bg-surface-dim">
            <div>
              <div class="font-medium">${it.name || it.item_name || it.item_id}</div>
              <div class="text-sm text-on-surface-variant">${it.unit || ''}</div>
            </div>
            <div class="text-sm">${numFmt.format(Number(it.unit_cost || 0))}</div>
          </button>
        `).join('')}</div>`;

        if (content) {
          content.innerHTML = `${controlsHtml}${listHtml}`;

          const openFormBtn = content.querySelector('#open-catalog-item-form');
          const form = content.querySelector('#catalog-item-form');
          const cancelFormBtn = content.querySelector('#cancel-catalog-item-form');
          const feedbackEl = content.querySelector('#catalog-item-feedback');

          const setFormVisible = (visible) => {
            if (openFormBtn) openFormBtn.classList.toggle('hidden', visible);
            if (form) form.classList.toggle('hidden', !visible);
            if (!visible && feedbackEl) {
              feedbackEl.textContent = '';
              feedbackEl.className = 'text-xs text-on-surface-variant';
            }
          };

          if (openFormBtn) openFormBtn.addEventListener('click', () => setFormVisible(true));
          if (cancelFormBtn) cancelFormBtn.addEventListener('click', () => setFormVisible(false));

          if (form) {
            form.addEventListener('submit', async (ev) => {
              ev.preventDefault();
              const fd = new FormData(form);
              const payload = {
                name: (fd.get('name') || '').toString().trim(),
                unit: (fd.get('unit') || '').toString().trim(),
                unit_cost: Number(fd.get('unit_cost') || 0)
              };

              if (!payload.name) {
                if (feedbackEl) {
                  feedbackEl.textContent = 'El nombre es obligatorio.';
                  feedbackEl.className = 'text-xs text-error';
                }
                return;
              }

              const submitBtn = form.querySelector('#submit-catalog-item-form');
              if (submitBtn instanceof HTMLButtonElement) {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Guardando...';
              }

              try {
                const createRes = await fetch(itemsApiUrl, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(payload)
                });
                const createData = await createRes.json().catch(() => ({}));
                if (!createRes.ok) {
                  throw new Error(createData.error || createData.message || 'No se pudo crear la partida');
                }
                showToast('Partida creada en catálogo', 'success');
                await openAddModal();
              } catch (createErr) {
                console.error('Catalog item create failed', createErr);
                if (feedbackEl) {
                  feedbackEl.textContent = createErr instanceof Error ? createErr.message : 'No se pudo crear la partida';
                  feedbackEl.className = 'text-xs text-error';
                }
              } finally {
                if (submitBtn instanceof HTMLButtonElement) {
                  submitBtn.disabled = false;
                  submitBtn.textContent = 'Guardar partida';
                }
              }
            });
          }
        }

        // attach click handlers to each row to add it to the project
        setTimeout(() => {
          const rows = modal.querySelectorAll('.add-item-row');
          rows.forEach(r => {
            r.addEventListener('click', async () => {
              const itemId = r.dataset.itemId;
              const unitCost = Number(r.dataset.unitCost || 0);
              const qty = 1;
              // POST to project_items.php to create relation
              try {
                const resp = await fetch(`${_apiBase.replace(/\/$/, '')}/project_items.php`, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ project_id: projectId, item_id: itemId, qty, unit_cost: unitCost })
                });
                if (!resp.ok) throw new Error('Create failed');
                await resp.json();
                closeAddModal();
                loadItems();
              } catch (err) {
                console.error('Failed to add item to project', err);
                const errEl = modal.querySelector('.add-items-list');
                if (errEl) errEl.innerHTML = '<div class="text-error">No se pudo agregar la partida.</div>';
              }
            });
          });
        }, 20);
      } catch (err) {
        console.error(err);
        if (content) content.innerHTML = '<div class="text-error">No se pudieron cargar las partidas.</div>';
      }
    }

    if (addBtn) addBtn.addEventListener('click', openAddModal);
    function closeAddModal() {
      const modal = document.getElementById('add-item-modal');
      if (!modal) return;
      modal.classList.add('hidden'); modal.classList.remove('flex');
      document.documentElement.classList.remove('modal-open');
    }

    const addCancel = document.getElementById('add-item-cancel'); if (addCancel) addCancel.addEventListener('click', closeAddModal);
  </script>

    <!-- Edit item modal (UI) -->
    <div id="edit-item-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
      <div class="fixed inset-0 bg-black/40"></div>
      <div class="bg-surface p-4 rounded-xl shadow-lg w-full max-w-md mx-4 z-10">
        <h3 class="text-lg font-semibold mb-2">Editar partida</h3>
        <form id="edit-item-form" class="space-y-3">
          <div id="edit-item-error" class="text-sm text-error hidden"></div>
          <div>
            <label class="text-xs text-on-surface-variant">Cantidad</label>
            <input name="qty" type="number" min="0" step="0.01" class="w-full mt-1 px-3 py-2 rounded border border-outline-variant" />
          </div>
          <div>
            <label class="text-xs text-on-surface-variant">Costo unit.</label>
            <input name="unit_cost" type="number" step="0.01" class="w-full mt-1 px-3 py-2 rounded border border-outline-variant" />
          </div>
          <div class="flex justify-end gap-2 mt-2">
            <button type="button" id="edit-item-cancel" class="px-3 py-2 rounded border border-outline-variant cursor-pointer">Cancelar</button>
            <button type="submit" id="edit-item-save" class="px-3 py-2 bg-primary text-on-primary rounded cursor-pointer">Guardar</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Add item modal (UI) -->
    <div id="add-item-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
      <div class="fixed inset-0 bg-black/40"></div>
      <div class="bg-surface p-4 rounded-xl shadow-lg w-full max-w-lg mx-4 z-10">
        <h3 class="text-lg font-semibold mb-2">Agregar partida</h3>
        <div class="add-items-list text-sm text-on-surface-variant">Cargando partidas...</div>
        <div class="flex justify-end gap-2 mt-4">
          <button type="button" id="add-item-cancel" class="px-3 py-2 rounded border border-outline-variant cursor-pointer">Cerrar</button>
        </div>
      </div>
    </div>

    <!-- Confirm modal (used instead of native confirm) -->
    <div id="confirm-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
      <div class="fixed inset-0 bg-black/40"></div>
      <div class="bg-surface p-4 rounded-xl shadow-lg w-full max-w-sm mx-4 z-10">
        <h3 class="text-lg font-semibold mb-2">Confirmar acción</h3>
        <div class="confirm-message text-sm text-on-surface-variant mb-4">¿Confirmar?</div>
        <div class="flex justify-end gap-2">
          <button type="button" id="confirm-no" class="px-3 py-2 rounded border border-outline-variant cursor-pointer">Cancelar</button>
          <button type="button" id="confirm-yes" class="px-3 py-2 bg-primary text-on-primary rounded cursor-pointer">Eliminar</button>
        </div>
      </div>
    </div>
</MainLayout>
